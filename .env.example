# Banco de dados SQLite (Prisma)
# Local: relativo à pasta prisma/
DATABASE_URL="file:../database/rifas.db"
# Docker: definido automaticamente no docker-compose (file:/app/database/rifas.db)

# Servidor
PORT=3000
NODE_ENV=development

# Sessão (OBRIGATÓRIO em produção — string aleatória longa, mín. 32 chars)
SESSION_SECRET=altere-esta-chave-em-producao

# Webhook de pagamento (token secreto para confirmar pagamentos automaticamente)
WEBHOOK_SECRET=webhook-secreto-local

# Google OAuth (opcional — https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://seu-dominio.com/auth/google/organizador/callback

# Google Ads API (campanhas — node scripts/google-ads-auth.js)
# Ative "Google Ads API" no Cloud Console. Redirect OAuth: http://localhost:8765/callback
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_API_VERSION=v22
# GOOGLE_ADS_AUTH_PORT=8765
# Criar campanha: npm run google-ads:create-campaign
# Ideias de keywords: npm run google-ads:keyword-ideas
# Com conta de teste: node scripts/google-ads-create-campaign.js --customer-id 1234567890

# URL pública com HTTPS em produção
APP_URL=http://localhost:3000

# Mercado Pago — credencial da plataforma VouRifar
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
# Marketplace split (OAuth por organizador — recomendado)
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# MERCADOPAGO_CALLBACK_URL=https://seu-dominio.com/auth/mercadopago/callback
# Webhook MP (configure também no painel Mercado Pago):
# https://SEU_DOMINIO/webhooks/mercadopago
# Redirect OAuth (painel MP → Suas integrações → Redirect URI):
# https://SEU_DOMINIO/auth/mercadopago/callback

# Woovi (OpenPix) — DESATIVADO por padrão (legado)
WOOVI_ENABLED=false
WOOVI_APP_ID=
# WOOVI_API_BASE=https://api.woovi.com/api/v1

# E-mail SMTP (Hostinger ou qualquer SMTP compatível)
# Hostinger: smtp.hostinger.com porta 465 (SSL) ou 587 (TLS)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@vourifar.com.br
SMTP_PASS=

# --- Docker (docker-compose) ---
# RUN_SEED=true          # só na 1ª subida ou ambiente demo (cria admin/admin123)
# Copie este arquivo para .env antes de: docker compose up --build -d
