{
  "name": "rifas-online",
  "version": "2.0.0",
  "description": "VouRifar — plataforma SaaS de rifas online",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "node app.js",
    "seed": "node database/seed.js",
    "migrate:saas": "node database/migrate-saas.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "postinstall": "prisma generate",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "webhook:simular": "node scripts/simular-webhook.js",
    "google-ads:auth": "node scripts/google-ads-auth.js",
    "google-ads:test": "node scripts/google-ads-auth.js --test",
    "google-ads:create-campaign": "node scripts/google-ads-create-campaign.js",
    "google-ads:keyword-ideas": "node scripts/google-ads-keyword-ideas.js",
    "google-ads:keywords": "node scripts/google-ads-print-keywords.js",
    "google-ads:generate-keywords": "node scripts/google-ads-generate-keywords.js",
    "google-ads:ad-copy": "node scripts/google-ads-print-ad-copy.js",
    "google-ads:sitelinks": "node scripts/google-ads-print-sitelinks.js"
  },
  "keywords": [
    "rifas",
    "express",
    "prisma",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "prisma": "^6.4.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "services/**/*.js",
      "lib/**/*.js"
    ]
  }
}
