<%- include('partials/page-start') %>
<%- include('partials/alerts') %>

<section class="super-panel">
  <div class="super-panel-head">
    <div>
      <h2 class="super-panel-title">Rifas na plataforma</h2>
      <p class="super-panel-sub"><%= total %> rifa<%= total !== 1 ? 's' : '' %> · página <%= page %> de <%= paginas %></p>
    </div>
    <form method="GET" action="/super/rifas" class="super-filters">
      <input type="text" name="q" value="<%= busca %>" placeholder="Buscar rifa ou sistema…" class="super-input">
      <select name="status" class="super-select">
        <option value="todos" <%= statusFiltro === 'todos' ? 'selected' : '' %>>Todas</option>
        <option value="ativa" <%= statusFiltro === 'ativa' ? 'selected' : '' %>>Ativas</option>
        <option value="encerrada" <%= statusFiltro === 'encerrada' ? 'selected' : '' %>>Encerradas</option>
        <option value="cancelada" <%= statusFiltro === 'cancelada' ? 'selected' : '' %>>Canceladas</option>
      </select>
      <button type="submit" class="super-btn super-btn--primary"><i data-lucide="search" class="w-4 h-4"></i> Filtrar</button>
    </form>
  </div>
  <div class="super-table-wrap">
    <table class="super-table">
      <thead>
        <tr><th>Rifa</th><th>Sistema</th><th>Cota</th><th>Reservas</th><th>Sorteio</th><th>Status</th><th>Ações</th></tr>
      </thead>
      <tbody>
        <% if (!rifas.length) { %><tr><td colspan="7" class="super-empty">Nenhuma rifa encontrada.</td></tr><% } %>
        <% rifas.forEach(function(r) { %>
          <tr>
            <td class="super-tenant-name"><%= r.titulo %></td>
            <td><a href="/<%= r.tenant.slug %>/" target="_blank" rel="noopener" class="super-action-link"><%= r.tenant.nome %></a></td>
            <td>R$ <%= r.valorFmt %></td>
            <td><%= r._count.reservas %></td>
            <td><%= r.sorteioFmt %></td>
            <td><span class="super-badge super-badge--<%= r.status === 'ativa' ? 'ativo' : 'suspenso' %>"><%= r.status %></span></td>
            <td><a href="/<%= r.tenant.slug %>/rifas/<%= r.id %>" target="_blank" rel="noopener" class="super-action-link">Ver rifa</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (paginas > 1) { %>
    <div class="super-pagination">
      <span><%= total %> rifas</span>
      <div class="super-pagination-links">
        <% if (page > 1) { %><a class="super-page-link" href="/super/rifas?page=<%= page - 1 %><%= busca ? '&q=' + encodeURIComponent(busca) : '' %><%= statusFiltro !== 'todos' ? '&status=' + statusFiltro : '' %>">←</a><% } %>
        <% for (var p = Math.max(1, page - 2); p <= Math.min(paginas, page + 2); p++) { %>
          <a class="super-page-link <%= p === page ? 'is-active' : '' %>" href="/super/rifas?page=<%= p %><%= busca ? '&q=' + encodeURIComponent(busca) : '' %><%= statusFiltro !== 'todos' ? '&status=' + statusFiltro : '' %>"><%= p %></a>
        <% } %>
        <% if (page < paginas) { %><a class="super-page-link" href="/super/rifas?page=<%= page + 1 %><%= busca ? '&q=' + encodeURIComponent(busca) : '' %><%= statusFiltro !== 'todos' ? '&status=' + statusFiltro : '' %>">→</a><% } %>
      </div>
    </div>
  <% } %>
</section>

<%- include('partials/page-end') %>
