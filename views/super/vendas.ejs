<%- include('partials/page-start') %>
<%- include('partials/alerts') %>

<section class="super-panel">
  <div class="super-panel-head">
    <div>
      <h2 class="super-panel-title">Vendas e reservas</h2>
      <p class="super-panel-sub"><%= total %> registro<%= total !== 1 ? 's' : '' %> · página <%= page %> de <%= paginas %></p>
    </div>
    <form method="GET" action="/super/vendas" class="super-filters">
      <select name="status" class="super-select">
        <option value="todos" <%= statusFiltro === 'todos' ? 'selected' : '' %>>Todas</option>
        <option value="confirmado" <%= statusFiltro === 'confirmado' ? 'selected' : '' %>>Confirmadas</option>
        <option value="pendente" <%= statusFiltro === 'pendente' ? 'selected' : '' %>>Pendentes</option>
      </select>
      <button type="submit" class="super-btn super-btn--primary">Filtrar</button>
    </form>
  </div>
  <div class="super-table-wrap">
    <table class="super-table">
      <thead>
        <tr><th>Data</th><th>Comprador</th><th>Rifa</th><th>Sistema</th><th>Cotas</th><th>Valor</th><th>Taxa 10%</th><th>Status</th></tr>
      </thead>
      <tbody>
        <% if (!vendas.length) { %><tr><td colspan="8" class="super-empty">Nenhuma venda encontrada.</td></tr><% } %>
        <% vendas.forEach(function(v) { %>
          <tr>
            <td><%= v.createdAtFmt %></td>
            <td>
              <span class="super-tenant-name"><%= v.usuario.nome %></span>
              <span class="super-tenant-email"><%= v.usuario.email %></span>
            </td>
            <td><%= v.rifa.titulo %></td>
            <td><a href="/<%= v.rifa.tenant.slug %>/" target="_blank" rel="noopener" class="super-action-link"><%= v.rifa.tenant.nome %></a></td>
            <td><%= v.cotas %></td>
            <td>R$ <%= v.valorFmt %></td>
            <td>R$ <%= v.taxaFmt %></td>
            <td><span class="super-badge super-badge--<%= v.statusPagamento === 'confirmado' ? 'ativo' : 'suspenso' %>"><%= v.statusPagamento %></span></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (paginas > 1) { %>
    <div class="super-pagination">
      <span><%= total %> vendas</span>
      <div class="super-pagination-links">
        <% if (page > 1) { %><a class="super-page-link" href="/super/vendas?page=<%= page - 1 %><%= statusFiltro !== 'todos' ? '&status=' + statusFiltro : '' %>">←</a><% } %>
        <% for (var p = Math.max(1, page - 2); p <= Math.min(paginas, page + 2); p++) { %>
          <a class="super-page-link <%= p === page ? 'is-active' : '' %>" href="/super/vendas?page=<%= p %><%= statusFiltro !== 'todos' ? '&status=' + statusFiltro : '' %>"><%= p %></a>
        <% } %>
        <% if (page < paginas) { %><a class="super-page-link" href="/super/vendas?page=<%= page + 1 %><%= statusFiltro !== 'todos' ? '&status=' + statusFiltro : '' %>">→</a><% } %>
      </div>
    </div>
  <% } %>
</section>

<%- include('partials/page-end') %>
