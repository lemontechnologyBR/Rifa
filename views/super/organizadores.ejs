<%- include('partials/page-start') %>
<%- include('partials/alerts') %>

<section class="super-panel">
  <div class="super-panel-head">
    <div>
      <h2 class="super-panel-title">Organizadores</h2>
      <p class="super-panel-sub"><%= total %> cadastro<%= total !== 1 ? 's' : '' %> · página <%= page %> de <%= paginas %></p>
    </div>
    <form method="GET" action="/super/organizadores" class="super-filters">
      <input type="text" name="q" value="<%= busca %>" placeholder="Buscar nome, e-mail ou sistema…" class="super-input">
      <button type="submit" class="super-btn super-btn--primary"><i data-lucide="search" class="w-4 h-4"></i> Filtrar</button>
      <% if (busca) { %><a href="/super/organizadores" class="super-btn super-btn--ghost">Limpar</a><% } %>
    </form>
  </div>
  <div class="super-table-wrap">
    <table class="super-table">
      <thead>
        <tr>
          <th>Nome</th>
          <th>E-mail</th>
          <th>Sistema</th>
          <th>Saldo confirmado</th>
          <th>Pendente</th>
          <th>Modalidade</th>
          <th>Disponível</th>
          <th>Login</th>
          <th>Cadastro</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        <% if (!organizadores.length) { %>
          <tr><td colspan="10" class="super-empty">Nenhum organizador encontrado.</td></tr>
        <% } %>
        <% organizadores.forEach(function(o) {
          const saldoConf = o.saldo ? o.saldo.confirmado : 0;
          const saldoPend = o.saldo ? o.saldo.pendente : 0;
          const payment = o.payment || {};
          const pct = payment.organizadorPercentual || 0.93;
          const pctLabel = Math.round(pct * 100);
          const saldoDisp = o.saldoDisponivel != null ? o.saldoDisponivel : saldoConf * pct;
          const temPix = !!(o.tenant.pixChave);
          const isMp = payment.gateway === 'mercadopago';
          const isWoovi = payment.gateway === 'woovi';
        %>
          <tr>
            <td class="super-tenant-name"><%= o.nome %></td>
            <td><%= o.email %></td>
            <td>
              <a href="/<%= o.tenant.slug %>/" target="_blank" rel="noopener" class="super-action-link"><%= o.tenant.nome %></a>
              <span class="super-tenant-email">/<%= o.tenant.slug %></span>
            </td>

            <!-- Saldo confirmado -->
            <td>
              <% if (saldoConf > 0) { %>
                <span class="font-bold text-emerald-600 dark:text-emerald-400">
                  R$ <%= saldoConf.toFixed(2).replace('.', ',') %>
                </span>
              <% } else { %>
                <span class="text-gray-400">R$ 0,00</span>
              <% } %>
            </td>

            <!-- Pendente -->
            <td>
              <% if (saldoPend > 0) { %>
                <span class="text-amber-600 dark:text-amber-400">
                  R$ <%= saldoPend.toFixed(2).replace('.', ',') %>
                </span>
              <% } else { %>
                <span class="text-gray-400">—</span>
              <% } %>
            </td>

            <!-- Modalidade -->
            <td>
              <% if (isMp) { %>
                <span class="super-badge super-badge--modalidade-mp">MP Direto · <%= pctLabel %>%</span>
              <% } else if (isWoovi) { %>
                <span class="super-badge super-badge--modalidade-woovi">Plataforma · <%= pctLabel %>%</span>
              <% } else { %>
                <span class="super-badge super-badge--modalidade-none"><%= payment.gatewayLabel || 'Não configurado' %></span>
              <% } %>
            </td>

            <!-- Disponível / recebido -->
            <td>
              <% if (saldoDisp >= 50 && isWoovi) { %>
                <span class="super-badge <%= saldoDisp >= 500 ? 'super-badge--saldo-ok' : 'super-badge--saldo-medio' %>">
                  <%= saldoDisp >= 500 ? '✓' : '$' %> R$ <%= saldoDisp.toFixed(2).replace('.', ',') %>
                </span>
                <span class="super-valor-hint">para saque</span>
              <% } else if (saldoDisp > 0 && isMp) { %>
                <span class="super-valor-mp">R$ <%= saldoDisp.toFixed(2).replace('.', ',') %></span>
                <span class="super-valor-hint">creditado no MP</span>
              <% } else if (saldoDisp > 0) { %>
                <span class="super-valor-muted">R$ <%= saldoDisp.toFixed(2).replace('.', ',') %></span>
              <% } else { %>
                <span class="super-valor-muted">—</span>
              <% } %>
            </td>

            <td>
              <span class="super-badge <%= o.viaGoogle ? 'super-badge--pix-ok' : 'super-badge--pix-no' %>">
                <%= o.viaGoogle ? 'Google' : 'E-mail' %>
              </span>
            </td>
            <td><%= o.createdAtFmt %></td>
            <td>
              <div class="flex items-center gap-2">
                <a href="/<%= o.tenant.slug %>/admin" target="_blank" rel="noopener" class="super-action-link">Painel</a>
                <% if (!temPix && !isMp) { %>
                  <span class="text-[10px] text-red-500 font-bold">Sem PIX</span>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% if (paginas > 1) { %>
    <div class="super-pagination">
      <span><%= total %> organizadores</span>
      <div class="super-pagination-links">
        <% if (page > 1) { %><a class="super-page-link" href="/super/organizadores?page=<%= page - 1 %><%= busca ? '&q=' + encodeURIComponent(busca) : '' %>">←</a><% } %>
        <% for (var p = Math.max(1, page - 2); p <= Math.min(paginas, page + 2); p++) { %>
          <a class="super-page-link <%= p === page ? 'is-active' : '' %>" href="/super/organizadores?page=<%= p %><%= busca ? '&q=' + encodeURIComponent(busca) : '' %>"><%= p %></a>
        <% } %>
        <% if (page < paginas) { %><a class="super-page-link" href="/super/organizadores?page=<%= page + 1 %><%= busca ? '&q=' + encodeURIComponent(busca) : '' %>">→</a><% } %>
      </div>
    </div>
  <% } %>
</section>

<%- include('partials/page-end') %>
