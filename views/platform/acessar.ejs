<%- include('../partials/header') %>

<div class="max-w-md mx-auto px-4 py-12">
  <div class="bg-white dark:bg-gray-800/80 rounded-2xl shadow-xl p-8 border border-gray-100 dark:border-gray-700/60 animate-fade-up">
    <div class="text-center mb-8">
      <div class="w-14 h-14 rounded-2xl btn-brand flex items-center justify-center mx-auto mb-4 shadow-lg">
        <i data-lucide="layout-dashboard" class="w-7 h-7 text-white"></i>
      </div>
      <h1 class="text-2xl font-extrabold dark:text-white">Acessar painel</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Entre com seu e-mail — não precisa lembrar a URL do sistema</p>
    </div>

    <% if (msg) { %><div class="bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-300 p-3 rounded-xl mb-4 text-sm border border-green-200 dark:border-green-800"><%= msg %></div><% } %>
    <% if (erro) { %><div class="bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-300 p-3 rounded-xl mb-4 text-sm border border-red-200 dark:border-red-800"><%= erro %></div><% } %>

    <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
      <a href="/acessar/auth/google" class="w-full flex items-center justify-center gap-3 border border-gray-300 dark:border-gray-600 rounded-xl py-3 mb-4 font-semibold text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700/50 transition">
        <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Entrar com Google
      </a>
      <div class="relative my-4"><div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200 dark:border-gray-700"></div></div><div class="relative flex justify-center text-xs uppercase"><span class="bg-white dark:bg-gray-800 px-2 text-gray-400">ou</span></div></div>
    <% } %>

    <form method="POST" action="/acessar" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">E-mail</label>
        <input type="email" name="email" required autocomplete="email" class="input-field" placeholder="seu@email.com">
      </div>
      <div>
        <label class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Senha</label>
        <input type="password" name="senha" required autocomplete="current-password" class="input-field" placeholder="••••••">
      </div>
      <button type="submit" class="w-full btn-brand font-bold py-3.5 rounded-xl shadow-md">Entrar no painel</button>
    </form>

    <p class="mt-6 text-center text-sm text-gray-500">
      Ainda não tem sistema?
      <a href="/cadastro" class="text-indigo-600 font-semibold hover:underline">Criar grátis</a>
    </p>
  </div>
</div>

<%- include('../partials/footer', { platformLanding: true }) %>
