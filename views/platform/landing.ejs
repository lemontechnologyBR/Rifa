<%- include('../partials/header') %>

<style>
/* ═══════════════════════════════════════════
   LANDING — ESTILO IMPÉRIO PRÊMIOS
   Fundo preto, verde vibrante, gold accent
═══════════════════════════════════════════ */
:root {
  --imp-green: #22c55e;
  --imp-green-dark: #16a34a;
  --imp-green-glow: rgba(34,197,94,.35);
  --imp-gold: #f59e0b;
  --imp-bg: #0d0d0d;
  --imp-card: #161616;
  --imp-border: #1f1f1f;
  --imp-muted: #6b7280;
}

.imp-page { background: var(--imp-bg); color: #fff; }

/* Navbar desta página — override para preto total */
.imp-page ~ * .glass-nav,
body.landing-body .glass-nav {
  background: rgba(13,13,13,.95) !important;
  border-color: var(--imp-border) !important;
}

@keyframes imp-glow {
  0%,100% { box-shadow: 0 0 24px 0 var(--imp-green-glow); }
  50%      { box-shadow: 0 0 48px 8px var(--imp-green-glow); }
}
@keyframes imp-float {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-10px); }
}
@keyframes imp-ticker {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
@keyframes imp-pulse-ring {
  0%   { transform: scale(1); opacity:.7; }
  100% { transform: scale(1.6); opacity:0; }
}
@keyframes imp-slide-up {
  from { opacity:0; transform:translateY(24px); }
  to   { opacity:1; transform:translateY(0); }
}
@keyframes imp-counter {
  from { opacity:0; transform: scale(.8); }
  to   { opacity:1; transform: scale(1); }
}
@keyframes shimmer-gold {
  0%   { background-position: -200% center; }
  100% { background-position:  200% center; }
}

.imp-glow-btn { animation: imp-glow 2.5s ease-in-out infinite; }
.imp-float    { animation: imp-float 4s ease-in-out infinite; }
.imp-slide-up { animation: imp-slide-up .6s ease forwards; opacity:0; }
.imp-slide-up-1 { animation-delay:.1s; }
.imp-slide-up-2 { animation-delay:.22s; }
.imp-slide-up-3 { animation-delay:.34s; }
.imp-slide-up-4 { animation-delay:.46s; }

.text-gold {
  background: linear-gradient(90deg, #f59e0b, #fcd34d, #f59e0b);
  background-size: 200% auto;
  -webkit-background-clip: text; background-clip: text; color: transparent;
  animation: shimmer-gold 3s linear infinite;
}
.text-imp-green { color: var(--imp-green); }

.imp-card {
  background: var(--imp-card);
  border: 1px solid var(--imp-border);
  border-radius: 16px;
  transition: border-color .2s, transform .2s;
}
.imp-card:hover {
  border-color: var(--imp-green);
  transform: translateY(-3px);
}

.imp-badge {
  background: rgba(34,197,94,.12);
  border: 1px solid rgba(34,197,94,.3);
  color: var(--imp-green);
  border-radius: 9999px;
  padding: 4px 14px;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
  display: inline-block;
}

.imp-tag {
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 8px;
  padding: 6px 12px;
  font-size: 12px;
  font-weight: 700;
  color: #d1d5db;
}

.imp-stat-card {
  background: var(--imp-card);
  border: 1px solid var(--imp-border);
  border-radius: 16px;
  padding: 24px 20px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.imp-stat-card::before {
  content:'';
  position:absolute; top:0; left:50%; transform:translateX(-50%);
  width:60%; height:2px;
  background: linear-gradient(90deg,transparent,var(--imp-green),transparent);
}

.imp-step-num {
  width: 48px; height: 48px;
  border-radius: 50%;
  background: var(--imp-green);
  color: #000;
  font-weight: 900;
  font-size: 20px;
  display: flex; align-items:center; justify-content:center;
  margin: 0 auto 16px;
  box-shadow: 0 0 20px var(--imp-green-glow);
}

.imp-ticker-wrap { overflow:hidden; white-space:nowrap; }
.imp-ticker-inner { display:inline-flex; animation: imp-ticker 28s linear infinite; }

.imp-separator {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--imp-border), transparent);
}

.imp-field {
  background: #111;
  border: 1px solid var(--imp-border);
  border-radius: 12px;
  color: #fff;
  font-weight: 700;
  padding: 14px 18px;
  width: 100%;
  transition: border-color .2s;
}
.imp-field:focus { outline: none; border-color: var(--imp-green); }
input[type=range].imp-range { accent-color: var(--imp-green); width:100%; }

.live-dot {
  width:10px; height:10px; border-radius:50%;
  background: var(--imp-green);
  position:relative; display:inline-block;
}
.live-dot::after {
  content:''; position:absolute; inset:-4px; border-radius:50%;
  background: var(--imp-green);
  opacity:.4;
  animation: imp-pulse-ring 1.4s ease-out infinite;
}

/* Notification badge glassmorphism */
.imp-notify {
  background: rgba(22,22,22,.85);
  border: 1px solid rgba(34,197,94,.25);
  backdrop-filter: blur(16px);
  border-radius: 14px;
  padding: 10px 16px;
}

.prize-card {
  background: var(--imp-card);
  border: 1px solid var(--imp-border);
  border-radius: 14px;
  padding: 18px 12px;
  text-align:center;
  transition: border-color .2s, transform .2s;
  cursor: default;
}
.prize-card:hover {
  border-color: var(--imp-green);
  transform: translateY(-4px);
}

.winner-row {
  display:flex; align-items:center; gap:14px;
  padding: 14px 16px;
  border-bottom: 1px solid var(--imp-border);
}
.winner-row:last-child { border-bottom: none; }
.winner-avatar {
  width:42px; height:42px; border-radius:50%;
  background: linear-gradient(135deg,#22c55e,#16a34a);
  display:flex; align-items:center; justify-content:center;
  font-weight:900; font-size:16px; color:#000; flex-shrink:0;
}
</style>

<div class="imp-page" x-data="{
  valorCota: 10,
  cotasVendidas: 500,
  get comissao()        { return Math.max(0, this.valorCota) * 0.05; },
  get organizadorRecebe(){ return Math.max(0, this.valorCota) * 0.95; },
  get totalOrganizador(){ return Math.max(0, this.valorCota) * 0.95 * Math.max(0, this.cotasVendidas); },
  get totalTaxa()       { return Math.max(0, this.valorCota) * 0.05 * Math.max(0, this.cotasVendidas); },
  get totalCompradores(){ return Math.max(0, this.valorCota) * Math.max(0, this.cotasVendidas); },
  fmt(v){ return (Math.max(0,v)||0).toFixed(2).replace('.',','); }
}">

  <!-- ══════════════════════════════════════════════
       HERO
  ══════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="min-height:100vh;display:flex;align-items:center;">
    <!-- Background -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 60% 20%, rgba(34,197,94,.12) 0%, transparent 70%), radial-gradient(ellipse 50% 40% at 10% 80%, rgba(245,158,11,.06) 0%, transparent 60%), #0d0d0d;"></div>
    <!-- Grid decorativo -->
    <div class="absolute inset-0 opacity-[.04]" style="background-image: linear-gradient(rgba(255,255,255,.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.3) 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 w-full">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Esquerda -->
        <div>
          <div class="imp-badge mb-6 imp-slide-up imp-slide-up-1">
            <span class="live-dot mr-2" style="vertical-align:middle;"></span>
            Plataforma 100% Gratuita
          </div>

          <h1 class="font-black leading-[1.06] tracking-tight mb-6 imp-slide-up imp-slide-up-2"
              style="font-size:clamp(2.4rem,5.5vw,4rem);color:#fff;">
            Crie seus sorteios<br>
            <span class="text-gold">online e arrecade</span><br>
            <span style="color:#e5e7eb;">direto no PIX</span>
          </h1>

          <p class="mb-10 leading-relaxed imp-slide-up imp-slide-up-3"
             style="font-size:1.1rem;color:#9ca3af;max-width:480px;">
            Monte seu sistema de sorteios em <strong style="color:#fff;">minutos</strong>. Link exclusivo,
            cotas ilimitadas, <strong style="color:var(--imp-green);">receba na hora</strong> — sem mensalidade.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-10 imp-slide-up imp-slide-up-3">
            <a href="/cadastro"
               class="imp-glow-btn inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-2xl font-black text-lg text-black transition-all hover:-translate-y-1"
               style="background:var(--imp-green);font-size:1rem;">
              🚀 Criar grátis agora
            </a>
            <a href="/demo"
               class="inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-2xl font-bold text-lg transition-all hover:-translate-y-1"
               style="border:2px solid rgba(255,255,255,.15);color:#fff;font-size:1rem;">
              <i data-lucide="play-circle" class="w-5 h-5" style="color:var(--imp-green);"></i>
              Ver demo ao vivo
            </a>
          </div>

          <div class="flex flex-wrap gap-3 imp-slide-up imp-slide-up-4">
            <span class="imp-tag">✅ Sem cartão</span>
            <span class="imp-tag">✅ Sorteios ilimitados</span>
            <span class="imp-tag">✅ PIX automático</span>
            <span class="imp-tag">✅ Grátis para começar</span>
          </div>
        </div>

        <!-- Direita: card mockup + badges flutuantes -->
        <div class="relative flex items-center justify-center" style="min-height:460px;">

          <!-- Card central mockup -->
          <div class="imp-float relative z-10" style="width:260px;">
            <div class="imp-card p-0 overflow-hidden shadow-2xl" style="box-shadow:0 0 60px rgba(34,197,94,.2);">
              <!-- Header do card -->
              <div style="background:linear-gradient(135deg,#1a1a1a,#0d0d0d);padding:20px 20px 16px;">
                <div class="flex items-center gap-2 mb-3">
                  <span class="live-dot"></span>
                  <span style="font-size:11px;color:var(--imp-green);font-weight:800;letter-spacing:.06em;">SORTEIO ATIVO</span>
                </div>
                <div style="background:#222;border-radius:10px;padding:12px;font-size:13px;font-weight:700;color:#fff;margin-bottom:8px;">
                  🏍️ Moto 0km Honda
                </div>
                <!-- Barra de progresso -->
                <div style="background:#222;border-radius:9999px;height:8px;overflow:hidden;margin-bottom:6px;">
                  <div style="background:linear-gradient(90deg,var(--imp-green),#16a34a);width:73%;height:100%;border-radius:9999px;"></div>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:11px;color:#6b7280;">
                  <span>730 vendidas</span><span style="color:var(--imp-green);font-weight:700;">73%</span>
                </div>
              </div>
              <!-- Footer do card -->
              <div style="background:#111;padding:14px 20px;display:flex;align-items:center;justify-content:space-between;">
                <div>
                  <div style="font-size:10px;color:#6b7280;text-transform:uppercase;letter-spacing:.05em;">Valor por cota</div>
                  <div style="font-size:18px;font-weight:900;color:#fff;">R$ 10,00</div>
                </div>
                <div style="background:var(--imp-green);color:#000;font-weight:900;font-size:12px;padding:8px 14px;border-radius:10px;">Participar</div>
              </div>
            </div>
          </div>

          <!-- Badge: PIX confirmado -->
          <div class="imp-notify absolute" style="top:20px;left:-10px;animation:imp-float 4s ease-in-out infinite;">
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-size:20px;">💰</span>
              <div>
                <div style="font-size:12px;font-weight:800;color:#fff;">PIX confirmado!</div>
                <div style="font-size:11px;font-weight:700;color:var(--imp-green);">+ R$ 10,00 recebido</div>
              </div>
            </div>
          </div>

          <!-- Badge: nova venda -->
          <div class="imp-notify absolute" style="top:30%;right:-10px;animation:imp-float 5s ease-in-out infinite .8s;">
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-size:20px;">🎉</span>
              <div>
                <div style="font-size:12px;font-weight:800;color:#fff;">Cota vendida!</div>
                <div style="font-size:11px;font-weight:700;color:#c4b5fd;">Nº 0437 reservado</div>
              </div>
            </div>
          </div>

          <!-- Badge: saque -->
          <div class="imp-notify absolute" style="bottom:30px;right:-5px;animation:imp-float 6s ease-in-out infinite 1.5s;">
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-size:20px;">🏆</span>
              <div>
                <div style="font-size:12px;font-weight:800;color:#fff;">Sorteio encerrado</div>
                <div style="font-size:11px;font-weight:700;color:var(--imp-gold);">R$ 7.300 arrecadado</div>
              </div>
            </div>
          </div>

          <!-- Badge: ganhador -->
          <div class="imp-notify absolute" style="bottom:20px;left:-10px;animation:imp-float 4.5s ease-in-out infinite 2s;">
            <div style="display:flex;align-items:center;gap:10px;">
              <span style="font-size:20px;">🏦</span>
              <div>
                <div style="font-size:12px;font-weight:800;color:#fff;">Saque realizado</div>
                <div style="font-size:11px;font-weight:700;color:#7dd3fc;">PIX na hora</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       TICKER
  ══════════════════════════════════════════════ -->
  <div style="background:var(--imp-green);padding:10px 0;overflow:hidden;">
    <div class="imp-ticker-wrap">
      <div class="imp-ticker-inner" style="gap:0;">
        <% const tItems = [
          ['🏍️','Moto 0km'],['📱','iPhone'],['🎮','PS5'],['💻','Notebook'],['🚗','Carro'],['💰','Dinheiro'],
          ['📺','Smart TV'],['🌴','Viagem'],['💎','Jóias'],['👟','Tênis Nike'],['🏠','Eletrônicos'],['🎸','Guitarra'],
          ['🏍️','Moto 0km'],['📱','iPhone'],['🎮','PS5'],['💻','Notebook'],['🚗','Carro'],['💰','Dinheiro'],
          ['📺','Smart TV'],['🌴','Viagem'],['💎','Jóias'],['👟','Tênis Nike'],['🏠','Eletrônicos'],['🎸','Guitarra']
        ]; %>
        <% tItems.forEach(([e,n]) => { %>
          <span style="display:inline-flex;align-items:center;gap:6px;padding:0 20px;font-size:13px;font-weight:900;color:#000;white-space:nowrap;">
            <%= e %> <%= n %> <span style="color:rgba(0,0,0,.35);margin-left:10px;">•</span>
          </span>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       STATS
  ══════════════════════════════════════════════ -->
  <section style="padding:60px 0;border-bottom:1px solid var(--imp-border);">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="imp-stat-card">
          <div style="font-size:2.4rem;font-weight:900;color:var(--imp-green);line-height:1;">∞</div>
          <div style="font-size:14px;font-weight:700;color:#fff;margin-top:6px;">Sorteios</div>
          <div style="font-size:12px;color:var(--imp-muted);margin-top:2px;">Crie sem limite</div>
        </div>
        <div class="imp-stat-card">
          <div style="font-size:2.4rem;font-weight:900;color:#8b5cf6;line-height:1;">∞</div>
          <div style="font-size:14px;font-weight:700;color:#fff;margin-top:6px;">Cotas</div>
          <div style="font-size:12px;color:var(--imp-muted);margin-top:2px;">Por sorteio</div>
        </div>
        <div class="imp-stat-card">
          <div style="font-size:2.4rem;font-weight:900;color:var(--imp-gold);line-height:1;">R$0</div>
          <div style="font-size:14px;font-weight:700;color:#fff;margin-top:6px;">Para criar</div>
          <div style="font-size:12px;color:var(--imp-muted);margin-top:2px;">Sem mensalidade</div>
        </div>
        <div class="imp-stat-card">
          <div style="font-size:2.4rem;font-weight:900;line-height:1;" class="text-imp-green">PIX</div>
          <div style="font-size:14px;font-weight:700;color:#fff;margin-top:6px;">Automático</div>
          <div style="font-size:12px;color:var(--imp-muted);margin-top:2px;">Confirmação na hora</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       PRÊMIOS QUE PODE SORTEAR
  ══════════════════════════════════════════════ -->
  <section style="padding:80px 0;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="text-align:center;margin-bottom:48px;">
        <div class="imp-badge mb-4">🎯 Possibilidades infinitas</div>
        <h2 style="font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;color:#fff;margin-top:12px;">
          Sorteie <span class="text-gold">qualquer coisa</span>
        </h2>
        <p style="color:var(--imp-muted);margin-top:10px;font-size:15px;">Você escolhe o prêmio, a quantidade de cotas e o valor. Sem restrição de categoria.</p>
      </div>

      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3">
        <% const prizes = [
          {e:'📱', n:'iPhone'},    {e:'🏍️', n:'Moto 0km'},  {e:'🎮', n:'PS5 / Xbox'},
          {e:'💻', n:'Notebook'},  {e:'📺', n:'Smart TV'},   {e:'🚗', n:'Carro'},
          {e:'💰', n:'Dinheiro'},  {e:'🌴', n:'Viagem'},     {e:'💎', n:'Jóias'},
          {e:'👟', n:'Tênis'},     {e:'🎸', n:'Guitarra'},   {e:'🏠', n:'Eletrônicos'}
        ]; %>
        <% prizes.forEach(p => { %>
        <div class="prize-card">
          <div style="font-size:2rem;margin-bottom:8px;"><%= p.e %></div>
          <div style="font-size:12px;font-weight:700;color:#d1d5db;"><%= p.n %></div>
        </div>
        <% }) %>
      </div>

      <p style="text-align:center;color:var(--imp-muted);font-size:13px;margin-top:28px;">e muito mais — o limite é a sua criatividade 🚀</p>
    </div>
  </section>

  <div class="imp-separator max-w-6xl mx-auto"></div>

  <!-- ══════════════════════════════════════════════
       COMO FUNCIONA (3 PASSOS)
  ══════════════════════════════════════════════ -->
  <section style="padding:80px 0;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-start">

        <!-- Esquerda: copy -->
        <div>
          <div class="imp-badge mb-4">⚡ Simples e rápido</div>
          <h2 style="font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;color:#fff;margin-top:12px;line-height:1.1;">
            Do cadastro à<br><span class="text-imp-green">primeira venda em minutos</span>
          </h2>
          <p style="color:var(--imp-muted);margin-top:16px;font-size:15px;line-height:1.7;">
            Plataforma 100% online. Você cria, divulga e recebe — tudo no mesmo lugar, 
            sem precisar de técnico ou conhecimento avançado.
          </p>

          <div style="margin-top:32px;display:flex;flex-direction:column;gap:12px;">
            <div style="display:flex;align-items:center;gap:12px;padding:14px 0;border-bottom:1px solid var(--imp-border);">
              <span style="font-size:1.4rem;">🔗</span>
              <div>
                <div style="font-weight:800;color:#fff;font-size:14px;">Link exclusivo para o seu sorteio</div>
                <div style="color:var(--imp-muted);font-size:12px;margin-top:2px;">vourifar.com.br/<strong style="color:var(--imp-green);">seu-nome</strong></div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;padding:14px 0;border-bottom:1px solid var(--imp-border);">
              <span style="font-size:1.4rem;">🎫</span>
              <div>
                <div style="font-weight:800;color:#fff;font-size:14px;">Cotas ilimitadas, você define o preço</div>
                <div style="color:var(--imp-muted);font-size:12px;margin-top:2px;">De R$ 1,00 a qualquer valor</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;padding:14px 0;border-bottom:1px solid var(--imp-border);">
              <span style="font-size:1.4rem;">💸</span>
              <div>
                <div style="font-weight:800;color:#fff;font-size:14px;">Receba via PIX automaticamente</div>
                <div style="color:var(--imp-muted);font-size:12px;margin-top:2px;">Confirmação instantânea, sem espera</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;padding:14px 0;">
              <span style="font-size:1.4rem;">🏆</span>
              <div>
                <div style="font-weight:800;color:#fff;font-size:14px;">Sorteio transparente e auditável</div>
                <div style="color:var(--imp-muted);font-size:12px;margin-top:2px;">Números sorteados com rastreabilidade</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Direita: como funciona (3 passos) -->
        <div>
          <div class="imp-badge mb-4">⚡ Como funciona</div>
          <h2 style="font-size:clamp(1.4rem,3vw,2rem);font-weight:900;color:#fff;margin-top:12px;margin-bottom:28px;">Pronto em <span class="text-imp-green">3 passos</span></h2>

          <div style="display:flex;flex-direction:column;gap:4px;">
            <div class="imp-card" style="padding:20px;display:flex;gap:16px;align-items:flex-start;">
              <div class="imp-step-num" style="flex-shrink:0;width:44px;height:44px;font-size:18px;">1</div>
              <div>
                <div style="font-weight:800;color:#fff;font-size:15px;margin-bottom:4px;">🚀 Crie sua conta grátis</div>
                <div style="color:var(--imp-muted);font-size:13px;line-height:1.6;">Cadastro rápido com Google. Painel pronto na hora, sem burocracia.</div>
              </div>
            </div>
            <div style="width:2px;height:20px;background:linear-gradient(to bottom,var(--imp-green),transparent);margin:0 auto;"></div>
            <div class="imp-card" style="padding:20px;display:flex;gap:16px;align-items:flex-start;">
              <div class="imp-step-num" style="flex-shrink:0;width:44px;height:44px;font-size:18px;">2</div>
              <div>
                <div style="font-weight:800;color:#fff;font-size:15px;margin-bottom:4px;">🎯 Monte seu sorteio</div>
                <div style="color:var(--imp-muted);font-size:13px;line-height:1.6;">Defina o prêmio, valor da cota e total de números. Adicione foto e publique.</div>
              </div>
            </div>
            <div style="width:2px;height:20px;background:linear-gradient(to bottom,var(--imp-green),transparent);margin:0 auto;"></div>
            <div class="imp-card" style="padding:20px;display:flex;gap:16px;align-items:flex-start;">
              <div class="imp-step-num" style="flex-shrink:0;width:44px;height:44px;font-size:18px;">3</div>
              <div>
                <div style="font-weight:800;color:#fff;font-size:15px;margin-bottom:4px;">💸 Compartilhe e receba</div>
                <div style="color:var(--imp-muted);font-size:13px;line-height:1.6;">Manda o link no zap, as cotas vendem e o dinheiro cai direto na sua conta via PIX.</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="imp-separator max-w-6xl mx-auto"></div>

  <!-- ══════════════════════════════════════════════
       DIFERENCIAIS
  ══════════════════════════════════════════════ -->
  <section style="padding:80px 0;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="text-align:center;margin-bottom:48px;">
        <div class="imp-badge mb-4">💎 Por que a VouRifar?</div>
        <h2 style="font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;color:#fff;margin-top:12px;">
          Tudo que você precisa,<br><span class="text-gold">em um só lugar</span>
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <% const features = [
          { e:'🆓', t:'100% Grátis para criar', d:'Nenhum plano, nenhuma assinatura. Comece hoje sem gastar nada.', c:'var(--imp-green)' },
          { e:'♾️', t:'Sorteios & cotas ilimitados', d:'Crie quantos sorteios quiser com qualquer quantidade de cotas.', c:'#8b5cf6' },
          { e:'⚡', t:'PIX automático', d:'Comprador paga e a cota é reservada na hora. Zero trabalho manual.', c:'#f59e0b' },
          { e:'📲', t:'Seu link exclusivo', d:'Compartilhe nas redes e no zap. Cada criador tem seu endereço único.', c:'#38bdf8' },
        ]; %>
        <% features.forEach(f => { %>
        <div class="imp-card" style="padding:24px;border-top:3px solid <%= f.c %>;">
          <div style="font-size:2rem;margin-bottom:12px;"><%= f.e %></div>
          <h3 style="font-weight:800;color:#fff;font-size:15px;margin-bottom:8px;"><%= f.t %></h3>
          <p style="color:var(--imp-muted);font-size:13px;line-height:1.65;"><%= f.d %></p>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       SIMULADOR
  ══════════════════════════════════════════════ -->
  <section id="simulador" style="padding:80px 0;background:#111;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div style="text-align:center;margin-bottom:48px;">
        <div class="imp-badge mb-4">🧮 Simule seu lucro</div>
        <h2 style="font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;color:#fff;margin-top:12px;">
          Quanto você pode <span class="text-imp-green">arrecadar?</span>
        </h2>
        <p style="color:var(--imp-muted);margin-top:10px;">Ajuste os valores e veja em tempo real.</p>
      </div>

      <div class="imp-card" style="padding:32px;border-color:rgba(34,197,94,.2);">
        <!-- Inputs -->
        <div class="grid sm:grid-cols-2 gap-6 mb-8">
          <div>
            <label style="display:block;font-size:11px;font-weight:800;color:var(--imp-muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;">💵 Valor da cota (R$)</label>
            <input type="number" x-model.number="valorCota" min="0.01" step="0.01" class="imp-field" style="font-size:1.5rem;">
          </div>
          <div>
            <label style="display:block;font-size:11px;font-weight:800;color:var(--imp-muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;">
              🎫 Cotas vendidas: <span x-text="cotasVendidas.toLocaleString('pt-BR')" style="color:var(--imp-green);"></span>
            </label>
            <input type="range" x-model.number="cotasVendidas" min="1" max="10000" step="1" class="imp-range" style="margin-bottom:12px;">
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
              <% [100,500,1000,5000,10000].forEach(v => { %>
              <button type="button" @click="cotasVendidas = <%= v %>"
                style="font-size:11px;padding:5px 12px;border-radius:8px;font-weight:800;transition:.2s;cursor:pointer;border:1px solid transparent;"
                :style="cotasVendidas == <%= v %>
                  ? 'background:var(--imp-green);color:#000;border-color:var(--imp-green);'
                  : 'background:#1a1a1a;color:#9ca3af;border-color:#2a2a2a;'">
                <%= v.toLocaleString('pt-BR') %>
              </button>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- Resultado destaque -->
        <div style="background:linear-gradient(135deg,var(--imp-green-dark),var(--imp-green));border-radius:16px;padding:32px;text-align:center;margin-bottom:20px;box-shadow:0 0 40px var(--imp-green-glow);">
          <div style="font-size:12px;font-weight:800;color:rgba(0,0,0,.6);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;">💰 Você arrecada</div>
          <div style="font-size:clamp(2.5rem,6vw,3.5rem);font-weight:900;color:#000;line-height:1;">R$ <span x-text="fmt(totalOrganizador)"></span></div>
          <div style="font-size:13px;color:rgba(0,0,0,.55);margin-top:8px;">líquido de R$ <span x-text="fmt(totalCompradores)"></span> arrecadados</div>
        </div>

        <!-- Mini stats -->
        <div class="grid grid-cols-2 gap-4 mb-6">
          <div style="background:#1a1a1a;border:1px solid var(--imp-border);border-radius:12px;padding:16px;text-align:center;">
            <div style="font-size:10px;font-weight:800;color:var(--imp-muted);text-transform:uppercase;margin-bottom:6px;">Compradores pagam</div>
            <div style="font-size:1.5rem;font-weight:900;color:#fff;">R$ <span x-text="fmt(totalCompradores)"></span></div>
            <div style="font-size:11px;color:var(--imp-muted);margin-top:4px;">valor exato da cota</div>
          </div>
          <div style="background:#1a1a1a;border:1px solid rgba(245,158,11,.2);border-radius:12px;padding:16px;text-align:center;">
            <div style="font-size:10px;font-weight:800;color:var(--imp-gold);text-transform:uppercase;margin-bottom:6px;">Comissão plataforma</div>
            <div style="font-size:1.5rem;font-weight:900;color:var(--imp-gold);">R$ <span x-text="fmt(totalTaxa)"></span></div>
            <div style="font-size:11px;color:var(--imp-muted);margin-top:4px;">5% do total</div>
          </div>
        </div>

        <!-- Breakdown -->
        <div style="background:#0d0d0d;border:1px solid var(--imp-border);border-radius:12px;padding:16px;font-size:14px;">
          <div style="display:flex;justify-content:space-between;padding:8px 0;color:var(--imp-muted);">
            <span><span x-text="cotasVendidas.toLocaleString('pt-BR')"></span> cotas × R$ <span x-text="fmt(valorCota)"></span></span>
            <span style="font-weight:700;color:#e5e7eb;">R$ <span x-text="fmt(totalCompradores)"></span></span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:8px 0;color:var(--imp-gold);">
            <span>− Comissão VouRifar (5%)</span>
            <span>R$ <span x-text="fmt(totalTaxa)"></span></span>
          </div>
          <div style="display:flex;justify-content:space-between;padding:12px 0 0;margin-top:4px;border-top:1px solid var(--imp-border);font-weight:900;font-size:16px;">
            <span style="color:#fff;">💰 Você recebe</span>
            <span style="color:var(--imp-green);">R$ <span x-text="fmt(totalOrganizador)"></span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════
       CTA FINAL
  ══════════════════════════════════════════════ -->
  <section style="padding:80px 0 100px;">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div style="background:linear-gradient(135deg,#111 0%,#0d1a12 50%,#111 100%);border:1px solid rgba(34,197,94,.2);border-radius:24px;padding:60px 32px;position:relative;overflow:hidden;">
        <!-- Glow bg -->
        <div style="position:absolute;top:-60px;right:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(34,197,94,.2) 0%,transparent 70%);"></div>
        <div style="position:absolute;bottom:-60px;left:-60px;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(245,158,11,.1) 0%,transparent 70%);"></div>

        <div style="position:relative;">
          <div style="font-size:3rem;margin-bottom:16px;">🏆</div>
          <div class="imp-badge mb-4">100% Gratuito para começar</div>
          <h2 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:#fff;margin-top:16px;margin-bottom:12px;line-height:1.1;">
            Seu primeiro sorteio<br>pode ser <span class="text-imp-green">hoje</span>
          </h2>
          <p style="color:#9ca3af;font-size:16px;margin-bottom:8px;max-width:440px;margin-left:auto;margin-right:auto;">Sorteios ilimitados. Cotas ilimitadas. Receba na hora.</p>
          <p style="color:#6b7280;font-size:14px;margin-bottom:40px;">Sem mensalidade — só 5% quando arrecadar.</p>

          <div style="display:flex;flex-direction:column;gap:14px;align-items:center;">
            <a href="/cadastro"
               class="imp-glow-btn inline-flex items-center justify-center gap-3 px-10 py-4 rounded-2xl font-black text-black transition-all hover:-translate-y-1"
               style="background:var(--imp-green);font-size:1.1rem;min-width:280px;">
              🚀 Criar minha conta grátis
            </a>
            <a href="/demo"
               class="inline-flex items-center justify-center gap-2.5 px-10 py-4 rounded-2xl font-bold text-white transition-all hover:bg-white/5"
               style="border:1px solid rgba(255,255,255,.15);font-size:1rem;">
              <i data-lucide="play-circle" class="w-5 h-5" style="color:var(--imp-green);"></i>
              Ver demo
            </a>
          </div>

          <p style="color:#4b5563;font-size:13px;margin-top:28px;">
            <i data-lucide="shield-check" class="w-4 h-4 inline-block mr-1 mb-0.5" style="color:var(--imp-green);vertical-align:middle;"></i>
            Sem cartão de crédito • Cancele quando quiser
          </p>
        </div>
      </div>
    </div>
  </section>

</div>

<%- include('../partials/footer', { platformLanding: true }) %>
