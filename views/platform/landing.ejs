<%- include('../partials/header') %>

<style>
@keyframes floatA {
  0%,100% { transform: translateY(0px) rotate(-2deg); }
  50%      { transform: translateY(-14px) rotate(2deg); }
}
@keyframes floatB {
  0%,100% { transform: translateY(0px) rotate(3deg); }
  50%      { transform: translateY(-10px) rotate(-3deg); }
}
@keyframes floatC {
  0%,100% { transform: translateY(-5px) rotate(0deg); }
  50%      { transform: translateY(8px) rotate(-2deg); }
}
@keyframes slideRight {
  from { transform: translateX(-30px); opacity: 0; }
  to   { transform: translateX(0);     opacity: 1; }
}
@keyframes popIn {
  0%   { transform: scale(0.6) translateY(20px); opacity: 0; }
  70%  { transform: scale(1.05) translateY(-2px); opacity: 1; }
  100% { transform: scale(1)    translateY(0);    opacity: 1; }
}
@keyframes glow-pulse {
  0%,100% { box-shadow: 0 0 20px 0px rgba(16,185,129,0.5); }
  50%      { box-shadow: 0 0 35px 8px rgba(16,185,129,0.75); }
}
@keyframes ticker {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}
@keyframes shimmer {
  0%   { background-position: -200% center; }
  100% { background-position:  200% center; }
}
.float-a { animation: floatA 4s ease-in-out infinite; }
.float-b { animation: floatB 5s ease-in-out infinite; }
.float-c { animation: floatC 6s ease-in-out infinite; }
.pop-in   { animation: popIn  .6s cubic-bezier(.22,1,.36,1) forwards; opacity:0; }
.pop-in-1 { animation-delay:.15s; }
.pop-in-2 { animation-delay:.3s; }
.pop-in-3 { animation-delay:.45s; }
.pop-in-4 { animation-delay:.6s; }
.pop-in-5 { animation-delay:.75s; }
.glow-btn { animation: glow-pulse 2.5s ease-in-out infinite; }
.ticker-wrap { overflow: hidden; white-space: nowrap; }
.ticker-inner { display: inline-flex; animation: ticker 22s linear infinite; }
.text-shimmer {
  background: linear-gradient(90deg, #10b981, #6366f1, #06b6d4, #10b981);
  background-size: 200% auto;
  -webkit-background-clip: text; background-clip: text; color: transparent;
  animation: shimmer 4s linear infinite;
}
/* Badge flutuante: glassmorphism fixo — independe de dark/light */
.landing-notify {
  backdrop-filter: blur(16px) saturate(1.6);
  -webkit-backdrop-filter: blur(16px) saturate(1.6);
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.22);
  box-shadow: 0 8px 32px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.15);
}
.landing-notify p { color: #fff !important; }
.prize-emoji-card {
  transition: transform .2s, box-shadow .2s;
}
.prize-emoji-card:hover {
  transform: translateY(-5px) scale(1.04);
  box-shadow: 0 16px 40px rgba(0,0,0,0.12);
}
</style>

<div class="landing-page" x-data="{
  valorCota: 10,
  cotasVendidas: 500,
  get taxa() { return 0; },
  get comissao() { return Math.max(0, this.valorCota) * 0.05; },
  get compradorPaga() { return Math.max(0, this.valorCota); },
  get organizadorRecebe() { return Math.max(0, this.valorCota) * 0.95; },
  get totalOrganizador() { return Math.max(0, this.valorCota) * 0.95 * Math.max(0, this.cotasVendidas); },
  get totalTaxa() { return Math.max(0, this.valorCota) * 0.05 * Math.max(0, this.cotasVendidas); },
  get totalCompradores() { return Math.max(0, this.valorCota) * Math.max(0, this.cotasVendidas); },
  fmt(v) { return (Math.max(0,v)||0).toFixed(2).replace('.',','); }
}">

  <!-- ══ HERO ══════════════════════════════════════════════════ -->
  <section class="landing-dark-section relative overflow-hidden min-h-[90vh] flex items-center">
    <!-- Background gradiente vivo -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-slate-900 to-emerald-950 pointer-events-none"></div>
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full bg-emerald-500/15 blur-[80px] pointer-events-none"></div>
    <div class="absolute bottom-0 -left-20 w-[400px] h-[400px] rounded-full bg-violet-600/15 blur-[70px] pointer-events-none"></div>
    <div class="absolute top-1/3 left-1/2 w-[300px] h-[300px] rounded-full bg-sky-500/10 blur-[60px] pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 w-full">
      <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">

        <!-- Esquerda: copy -->
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-emerald-500/20 border border-emerald-500/30 text-emerald-300 text-xs font-bold uppercase tracking-widest mb-6 pop-in">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            Plataforma 100% Gratuita
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.08] tracking-tight mb-6 text-white">
            Crie seus<br>
            <span class="text-shimmer">sorteios online</span><br>
            <span class="text-white/80 text-3xl sm:text-4xl lg:text-5xl font-extrabold">e arrecade mais</span>
          </h1>

          <p class="text-lg leading-relaxed max-w-lg mb-4" style="color:#cbd5e1">
            Monte seu sistema de sorteios em <strong style="color:#fff">minutos</strong>. PIX automático, cotas ilimitadas, sorteios ilimitados.
            <strong style="color:#34d399">Grátis para criar</strong> — você só paga quando vende.
          </p>
          <p class="text-sm mb-10 flex items-center gap-2" style="color:#94a3b8">
            <i data-lucide="percent" class="w-4 h-4 text-amber-400 shrink-0"></i>
            5% de comissão sobre o arrecadado — nada antes disso.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a href="/cadastro"
               class="glow-btn inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-2xl bg-emerald-500 hover:bg-emerald-400 text-white font-black text-lg shadow-xl transition-all hover:-translate-y-1">
              <i data-lucide="rocket" class="w-5 h-5"></i>
              Criar grátis agora
            </a>
            <a href="/demo"
               class="inline-flex items-center justify-center gap-2.5 px-8 py-4 rounded-2xl border-2 border-white/20 text-white font-bold text-lg hover:bg-white/10 transition-all hover:-translate-y-1">
              <i data-lucide="play-circle" class="w-5 h-5 text-emerald-400"></i>
              Ver demo
            </a>
          </div>

          <div class="flex flex-wrap gap-5 text-slate-400 text-sm">
            <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Sem cartão</span>
            <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Sorteios ilimitados</span>
            <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Cotas ilimitadas</span>
            <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> PIX automático</span>
          </div>
        </div>

        <!-- Direita: elementos flutuantes + números -->
        <div class="relative flex items-center justify-center min-h-[420px]">

          <!-- Card central: PIX direto -->
          <div class="relative z-10 text-center pop-in pop-in-1">
            <div class="inline-flex flex-col items-center justify-center w-52 h-52 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 shadow-2xl shadow-emerald-500/40 float-a">
              <span class="text-4xl mb-1">💸</span>
              <span class="text-3xl font-black text-white leading-none">PIX</span>
              <span class="text-emerald-100 text-sm font-bold mt-1">automático</span>
              <span class="text-emerald-200 text-xs mt-1 px-3 text-center">direto na sua chave</span>
            </div>
          </div>

          <!-- Badge: PIX confirmado (topo esquerdo) -->
          <div class="absolute top-4 left-0 sm:-left-4 pop-in pop-in-2">
            <div class="landing-notify rounded-2xl px-4 py-3 float-b">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl">💰</span>
                <div>
                  <p class="text-xs font-bold">PIX confirmado!</p>
                  <p class="text-[11px] font-semibold" style="color:#6ee7b7">+ R$ 10,00 recebido</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Badge: nova venda (direita) -->
          <div class="absolute top-1/4 right-0 sm:-right-4 pop-in pop-in-3">
            <div class="landing-notify rounded-2xl px-4 py-3 float-c">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl">🎉</span>
                <div>
                  <p class="text-xs font-bold">Cota vendida!</p>
                  <p class="text-[11px] font-semibold" style="color:#c4b5fd">Nº 0437 reservado</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Badge: sorteio encerrado (baixo esquerdo) -->
          <div class="absolute bottom-8 left-0 sm:-left-8 pop-in pop-in-4">
            <div class="landing-notify rounded-2xl px-4 py-3 float-b" style="animation-delay:1s">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl">🏆</span>
                <div>
                  <p class="text-xs font-bold">Sorteio encerrado</p>
                  <p class="text-[11px] font-semibold" style="color:#fcd34d">R$ 4.750 arrecadado</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Badge: saque (baixo direito) -->
          <div class="absolute bottom-4 right-0 sm:-right-4 pop-in pop-in-5">
            <div class="landing-notify rounded-2xl px-4 py-3 float-a" style="animation-delay:2s">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl">🏦</span>
                <div>
                  <p class="text-xs font-bold">Saque realizado</p>
                  <p class="text-[11px] font-semibold" style="color:#7dd3fc">PIX na hora</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══ TICKER: prêmios populares ══════════════════════════════ -->
  <div class="py-3 bg-gradient-to-r from-emerald-600 via-teal-600 to-cyan-600 overflow-hidden">
    <div class="ticker-wrap">
      <div class="ticker-inner gap-8 items-center">
        <% const items = [
          ['📱','iPhone 15 Pro'],['🏍️','Moto 0km'],['🎮','PS5'],['💻','Notebook'],['📺','Smart TV'],['🚗','Carro'],
          ['💎','Jóias'],['👟','Tênis'],['🎸','Guitarra'],['🌴','Viagem'],['💰','Dinheiro'],['🏋️','Academia'],
          ['📱','iPhone 15 Pro'],['🏍️','Moto 0km'],['🎮','PS5'],['💻','Notebook'],['📺','Smart TV'],['🚗','Carro'],
          ['💎','Jóias'],['👟','Tênis'],['🎸','Guitarra'],['🌴','Viagem'],['💰','Dinheiro'],['🏋️','Academia']
        ]; %>
        <% items.forEach(([emoji, nome]) => { %>
          <span class="inline-flex items-center gap-2 text-sm font-bold text-white/90 px-4">
            <span class="text-lg"><%= emoji %></span> <%= nome %> <span class="text-white/40 ml-2">•</span>
          </span>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- ══ STATS ══════════════════════════════════════════════════ -->
  <section class="landing-light-section py-12 bg-white dark:bg-slate-900 border-b border-gray-100 dark:border-gray-800">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl sm:text-4xl font-black text-emerald-600 dark:text-emerald-400">∞</p>
          <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 mt-1">Sorteios</p>
          <p class="text-xs text-gray-400 dark:text-gray-500">Crie sem limite</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-black text-violet-600 dark:text-violet-400">∞</p>
          <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 mt-1">Cotas</p>
          <p class="text-xs text-gray-400 dark:text-gray-500">Por sorteio</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-black text-sky-600 dark:text-sky-400">R$0</p>
          <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 mt-1">Para criar</p>
          <p class="text-xs text-gray-400 dark:text-gray-500">Sem mensalidade</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-black text-teal-600 dark:text-teal-400">5%</p>
          <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 mt-1">Só quando vende</p>
          <p class="text-xs text-gray-400 dark:text-gray-500">Nada antes disso</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ O QUE PODE SORTEAR ════════════════════════════════════ -->
  <section class="py-16 lg:py-20 bg-gray-50 dark:bg-slate-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 text-xs font-bold uppercase mb-4">
          🎯 Possibilidades infinitas
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-3">Sorteie qualquer coisa</h2>
        <p class="text-gray-500 dark:text-gray-400">O que você quer rifar? A plataforma não tem limite de categoria.</p>
      </div>

      <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-4">
        <% const prizes = [
          {e:'📱', n:'iPhone'},    {e:'🏍️', n:'Moto 0km'},  {e:'🎮', n:'PS5 / Xbox'},
          {e:'💻', n:'Notebook'},  {e:'📺', n:'Smart TV'},   {e:'🚗', n:'Carro'},
          {e:'💰', n:'Dinheiro'},  {e:'🌴', n:'Viagem'},     {e:'💎', n:'Jóias'},
          {e:'👟', n:'Tênis'},     {e:'🎸', n:'Guitarra'},   {e:'🏠', n:'Eletrônicos'}
        ]; %>
        <% prizes.forEach(p => { %>
        <div class="prize-emoji-card landing-card p-4 text-center cursor-default select-none">
          <span class="text-3xl block mb-2"><%= p.e %></span>
          <span class="text-xs font-semibold text-gray-600 dark:text-gray-300"><%= p.n %></span>
        </div>
        <% }) %>
      </div>

      <p class="text-center text-sm text-gray-400 dark:text-gray-500 mt-8">e muito mais — o limite é a sua criatividade 🚀</p>
    </div>
  </section>

  <!-- ══ DIFERENCIAIS ══════════════════════════════════════════ -->
  <section class="py-16 lg:py-24 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">Por que escolher a <span class="text-shimmer">VouRifar</span>?</h2>
        <p class="text-gray-500 dark:text-gray-400">Tudo pronto, sem complicação — você foca em vender.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <div class="landing-card group relative overflow-hidden border-t-4 border-emerald-500">
          <div class="text-4xl mb-4">🆓</div>
          <h3 class="text-lg font-extrabold mb-2">100% Grátis para criar</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
            Nenhum plano, nenhuma assinatura. Pague <strong class="text-gray-700 dark:text-gray-300">apenas 5%</strong> quando arrecadar.
          </p>
        </div>

        <div class="landing-card group relative overflow-hidden border-t-4 border-violet-500">
          <div class="text-4xl mb-4">♾️</div>
          <h3 class="text-lg font-extrabold mb-2">Sorteios &amp; cotas ilimitados</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
            Crie <strong class="text-gray-700 dark:text-gray-300">quantos sorteios quiser</strong> com qualquer número de cotas — sem pagar mais.
          </p>
        </div>

        <div class="landing-card group relative overflow-hidden border-t-4 border-sky-500">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="text-lg font-extrabold mb-2">PIX automático na hora</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
            Comprador paga o <strong class="text-gray-700 dark:text-gray-300">valor exato</strong> via PIX. Confirmação instantânea, zero trabalho manual.
          </p>
        </div>

        <div class="landing-card group relative overflow-hidden border-t-4 border-amber-500">
          <div class="text-4xl mb-4">📲</div>
          <h3 class="text-lg font-extrabold mb-2">Seu site, seu link</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm leading-relaxed">
            Você tem <strong class="text-gray-700 dark:text-gray-300">seu próprio endereço</strong> na VouRifar. Compartilhe no zap e nas redes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ COMO COMEÇAR ══════════════════════════════════════════ -->
  <section class="py-16 lg:py-24 bg-gradient-to-b from-violet-50/80 to-white dark:from-violet-950/20 dark:to-slate-950 border-y border-violet-100 dark:border-violet-900/30">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-3">Pronto em <span class="text-violet-600 dark:text-violet-400">3 passos</span></h2>
        <p class="text-gray-500 dark:text-gray-400">Do cadastro à primeira venda em menos de 10 minutos.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <div class="hidden md:block absolute top-14 left-[22%] right-[22%] h-0.5 bg-gradient-to-r from-violet-300 via-teal-300 to-emerald-300 dark:from-violet-800 dark:via-teal-800 dark:to-emerald-800"></div>

        <div class="landing-card text-center relative">
          <div class="text-4xl mb-3">🚀</div>
          <div class="inline-block px-3 py-0.5 rounded-full bg-violet-100 dark:bg-violet-900/50 text-violet-700 dark:text-violet-300 text-[11px] font-black uppercase mb-3">Passo 1</div>
          <h3 class="font-extrabold text-lg mb-2">Crie sua conta grátis</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">Cadastro rápido. Seu painel fica pronto na hora — sem burocracia.</p>
        </div>

        <div class="landing-card text-center relative">
          <div class="text-4xl mb-3">🎯</div>
          <div class="inline-block px-3 py-0.5 rounded-full bg-teal-100 dark:bg-teal-900/50 text-teal-700 dark:text-teal-300 text-[11px] font-black uppercase mb-3">Passo 2</div>
          <h3 class="font-extrabold text-lg mb-2">Monte seu sorteio</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Defina o prêmio, valor da cota e quantidade. Adicione foto e pronto.</p>
          <div class="flex flex-wrap gap-2 justify-center text-xs font-bold">
            <span class="px-2.5 py-1 rounded-lg bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400">R$ 10 / cota</span>
            <span class="px-2.5 py-1 rounded-lg bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300">1.000 números</span>
          </div>
        </div>

        <div class="landing-card text-center relative">
          <div class="text-4xl mb-3">💸</div>
          <div class="inline-block px-3 py-0.5 rounded-full bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 text-[11px] font-black uppercase mb-3">Passo 3</div>
          <h3 class="font-extrabold text-lg mb-2">Compartilhe e arrecade</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">Manda o link no Whats, as cotas vendem e o PIX cai automático.</p>
          <div class="inline-block px-4 py-2 rounded-xl bg-emerald-500 text-white font-black text-xl shadow-lg shadow-emerald-500/30">R$ 9,50 <span class="text-sm font-medium text-emerald-100">/ cota</span></div>
          <p class="text-[11px] text-gray-400 mt-2">95% de R$ 10,00 — seu</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ SIMULADOR ════════════════════════════════════════════ -->
  <section id="simulador" class="py-16 lg:py-24 bg-white dark:bg-slate-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 text-xs font-bold uppercase mb-4">
          🧮 Calcule seu lucro
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-3">Quanto você pode arrecadar?</h2>
        <p class="text-gray-500 dark:text-gray-400">Arraste e veja em tempo real.</p>
      </div>

      <div class="landing-card overflow-visible">
        <div class="grid sm:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">💵 Valor da cota (R$)</label>
            <input type="number" x-model.number="valorCota" min="0.01" step="0.01"
              class="landing-field w-full px-4 py-4 rounded-2xl text-2xl font-black">
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2">
              🎫 Cotas vendidas: <span x-text="cotasVendidas.toLocaleString('pt-BR')" class="text-violet-600 dark:text-violet-400"></span>
            </label>
            <input type="range" x-model.number="cotasVendidas" min="1" max="10000" step="1" class="w-full accent-emerald-600 mb-3">
            <div class="flex flex-wrap gap-2">
              <% [100,500,1000,5000,10000].forEach(v => { %>
              <button type="button" @click="cotasVendidas = <%= v %>"
                class="text-[11px] px-3 py-1.5 rounded-xl font-bold transition"
                :class="cotasVendidas == <%= v %> ? 'bg-violet-600 text-white' : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-violet-100 dark:hover:bg-violet-900/40'">
                <%= v.toLocaleString('pt-BR') %>
              </button>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- Resultado em destaque -->
        <div class="relative rounded-3xl bg-gradient-to-br from-emerald-500 to-teal-600 p-8 text-center text-white shadow-2xl shadow-emerald-500/30 mb-6">
          <div class="absolute top-3 right-3 text-3xl opacity-50">💰</div>
          <p class="text-sm font-bold text-emerald-100 uppercase tracking-widest mb-2">Você arrecada</p>
          <p class="text-5xl sm:text-6xl font-black leading-none mb-2">R$ <span x-text="fmt(totalOrganizador)"></span></p>
          <p class="text-emerald-100 text-sm">95% de R$ <span x-text="fmt(totalCompradores)"></span> arrecadados</p>
        </div>

        <div class="grid grid-cols-2 gap-4 mb-6">
          <div class="rounded-2xl bg-slate-50 dark:bg-slate-800/80 p-4 text-center">
            <p class="text-xs font-bold text-gray-400 uppercase mb-1">Compradores pagam</p>
            <p class="text-2xl font-black text-gray-800 dark:text-white">R$ <span x-text="fmt(totalCompradores)"></span></p>
            <p class="text-[11px] text-gray-400 mt-1">valor exato da cota</p>
          </div>
          <div class="rounded-2xl bg-amber-50 dark:bg-amber-900/20 p-4 text-center">
            <p class="text-xs font-bold text-amber-600 dark:text-amber-400 uppercase mb-1">Comissão plataforma</p>
            <p class="text-2xl font-black text-amber-700 dark:text-amber-300">R$ <span x-text="fmt(totalTaxa)"></span></p>
            <p class="text-[11px] text-gray-400 mt-1">5% do total</p>
          </div>
        </div>

        <div class="rounded-2xl bg-gray-50 dark:bg-gray-900/60 p-4 text-sm border border-gray-100 dark:border-gray-800">
          <div class="flex justify-between py-1.5 text-gray-500 dark:text-gray-400">
            <span><span x-text="cotasVendidas.toLocaleString('pt-BR')"></span> cotas × R$ <span x-text="fmt(valorCota)"></span></span>
            <span class="font-semibold text-gray-700 dark:text-gray-200">R$ <span x-text="fmt(totalCompradores)"></span></span>
          </div>
          <div class="flex justify-between py-1.5 text-amber-600 dark:text-amber-400">
            <span>− Comissão VouRifar (5%)</span>
            <span>R$ <span x-text="fmt(totalTaxa)"></span></span>
          </div>
          <div class="flex justify-between pt-3 mt-1 border-t border-gray-200 dark:border-gray-700 font-extrabold text-lg">
            <span class="text-gray-900 dark:text-white">💰 Você recebe</span>
            <span class="text-emerald-600 dark:text-emerald-400">R$ <span x-text="fmt(totalOrganizador)"></span></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CTA FINAL ═════════════════════════════════════════════ -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="rounded-3xl bg-gradient-to-br from-slate-900 via-violet-950 to-emerald-950 p-12 sm:p-16 relative overflow-hidden shadow-2xl">
        <!-- grid de pontos decorativos -->
        <div class="absolute inset-0 opacity-10" style="background-image:radial-gradient(circle at 2px 2px, white 1px, transparent 0);background-size:28px 28px"></div>
        <!-- blobs -->
        <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full bg-emerald-500/20 blur-3xl"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 rounded-full bg-violet-500/20 blur-3xl"></div>

        <div class="relative">
          <div class="text-5xl mb-4">🏆</div>
          <span class="inline-block px-4 py-1.5 rounded-full bg-emerald-500/20 text-emerald-300 text-xs font-black uppercase tracking-widest mb-5">100% Gratuito para começar</span>
          <h2 class="text-3xl sm:text-4xl font-black text-white mb-4" style="color:#fff">
            Seu primeiro sorteio<br>pode ser hoje
          </h2>
          <p class="text-slate-300 text-lg mb-2 max-w-lg mx-auto">Sorteios ilimitados. Cotas ilimitadas. PIX automático. Sem mensalidade.</p>
          <p class="text-slate-500 text-sm mb-10">Só 5% de comissão quando você arrecadar — mais nada.</p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/cadastro"
               class="glow-btn inline-flex items-center justify-center gap-2.5 px-10 py-4 rounded-2xl bg-emerald-500 hover:bg-emerald-400 text-white font-black text-lg shadow-xl transition-all hover:-translate-y-1">
              🚀 Criar minha conta grátis
            </a>
            <a href="/demo"
               class="inline-flex items-center justify-center gap-2.5 px-10 py-4 rounded-2xl border-2 border-white/20 text-white font-bold text-lg hover:bg-white/10 transition-all">
              <i data-lucide="play-circle" class="w-5 h-5"></i>
              Ver demo
            </a>
          </div>

          <p class="text-slate-500 text-sm mt-8">
            <i data-lucide="shield-check" class="w-4 h-4 inline-block mr-1 mb-0.5 text-emerald-500"></i>
            Sem cartão de crédito • Cancele quando quiser
          </p>
        </div>
      </div>
    </div>
  </section>
</div>

<%- include('../partials/footer', { platformLanding: true }) %>
