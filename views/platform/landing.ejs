<%- include('../partials/header') %>

<div class="landing-page" x-data="{
  valorCota: 10,
  cotasVendidas: 100,
  get taxa() { return Math.max(0, this.valorCota) * 0.05; },
  get compradorPaga() { return Math.max(0, this.valorCota) + this.taxa; },
  get totalOrganizador() { return Math.max(0, this.valorCota) * Math.max(0, this.cotasVendidas); },
  get totalTaxa() { return this.taxa * Math.max(0, this.cotasVendidas); },
  get totalCompradores() { return this.compradorPaga * Math.max(0, this.cotasVendidas); },
  fmt(v) { return (Math.max(0, v) || 0).toFixed(2).replace('.', ','); }
}">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-emerald-400/20 blur-3xl"></div>
      <div class="absolute top-1/2 -left-32 w-80 h-80 rounded-full bg-slate-400/15 blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-16 lg:pt-20 lg:pb-24">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div class="text-center lg:text-left animate-fade-up">
          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-2 mb-6">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-800 dark:text-emerald-300 text-xs font-bold uppercase tracking-wide border border-emerald-200 dark:border-emerald-800">
              <i data-lucide="badge-check" class="w-3.5 h-3.5"></i>
              Comissão zero para você
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 text-xs font-bold uppercase tracking-wide border border-slate-200 dark:border-slate-700">
              5% para o comprador
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-violet-100 dark:bg-violet-900/40 text-violet-800 dark:text-violet-300 text-xs font-bold uppercase tracking-wide border border-violet-200 dark:border-violet-800">
              <i data-lucide="infinity" class="w-3.5 h-3.5"></i>
              Cotas ilimitadas
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-[1.12] tracking-tight mb-6 text-gray-900 dark:text-white">
            Seu sistema de rifas online em minutos
            <span class="block mt-2 text-2xl sm:text-3xl lg:text-4xl bg-gradient-to-r from-emerald-600 via-teal-600 to-sky-600 bg-clip-text text-transparent">
              Comissão zero para você
            </span>
          </h1>

          <p class="landing-subtitle text-lg leading-relaxed max-w-xl mx-auto lg:mx-0 mb-6">
            Organize rifas com site próprio, painel admin e PIX automático. Defina <strong class="text-violet-600 dark:text-violet-400">quantas cotas quiser</strong> — 100, 1.000 ou 10.000+. O comprador paga <strong class="text-emerald-600 dark:text-emerald-400">5% de taxa</strong>; você recebe <strong class="text-gray-800 dark:text-gray-200">100% do valor da cota</strong>.
          </p>

          <div class="inline-flex items-start gap-3 p-4 rounded-2xl bg-emerald-50 dark:bg-emerald-950/40 border border-emerald-200 dark:border-emerald-800/60 text-sm text-left max-w-md mx-auto lg:mx-0 mb-8">
            <i data-lucide="info" class="w-5 h-5 text-emerald-600 dark:text-emerald-400 shrink-0 mt-0.5"></i>
            <p class="text-emerald-950 dark:text-emerald-50/90">
              Exemplo: comprador paga <strong>R$ 10,50</strong> por uma cota de <strong>R$ 10,00</strong>
              <span class="text-emerald-600 dark:text-emerald-400"> (R$ 0,50 de taxa da plataforma)</span>.
              Você recebe os R$ 10,00 inteiros.
            </p>
          </div>

          <div class="flex flex-col sm:flex-row flex-wrap gap-3 justify-center lg:justify-start mb-8">
            <a href="/cadastro" class="landing-btn-primary inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl font-bold text-lg shadow-lg shadow-emerald-500/25 hover:-translate-y-0.5 transition-all">
              <i data-lucide="rocket" class="w-5 h-5"></i>
              Criar meu sistema grátis
            </a>
            <a href="/demo" class="landing-btn-secondary inline-flex items-center justify-center gap-2 px-8 py-4 rounded-2xl font-semibold text-lg transition-all hover:-translate-y-0.5">
              <i data-lucide="play-circle" class="w-5 h-5 text-emerald-600"></i>
              Ver demo
            </a>
          </div>

          <div class="flex flex-wrap justify-center lg:justify-start gap-4 text-sm text-gray-500 dark:text-gray-400">
            <span class="flex items-center gap-2"><i data-lucide="circle-dollar-sign" class="w-4 h-4 text-emerald-500"></i> Você não paga comissão</span>
            <span class="flex items-center gap-2"><i data-lucide="infinity" class="w-4 h-4 text-violet-500"></i> Cotas ilimitadas por rifa</span>
            <span class="flex items-center gap-2"><i data-lucide="eye" class="w-4 h-4 text-sky-500"></i> Taxa transparente</span>
            <span class="flex items-center gap-2"><i data-lucide="smartphone" class="w-4 h-4 text-teal-500"></i> 100% mobile</span>
          </div>
        </div>

        <!-- Simulador de taxa + checkout -->
        <div class="animate-fade-up space-y-4" style="animation-delay:.1s">
          <div class="landing-card">
            <h3 class="font-bold text-lg mb-1 flex items-center gap-2">
              <i data-lucide="calculator" class="w-5 h-5 text-emerald-600"></i>
              Simulador de taxa
            </h3>
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">Por cota — veja quanto o comprador paga e quanto você recebe</p>

            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase mb-2">Valor da cota (R$)</label>
            <input type="number" x-model.number="valorCota" min="0.01" step="0.01"
              class="landing-field w-full px-4 py-3 rounded-xl text-lg font-bold mb-4">

            <div class="space-y-2 text-sm">
              <div class="flex justify-between py-2 border-b border-gray-100 dark:border-gray-700">
                <span class="text-gray-500 dark:text-gray-400">Valor da cota</span>
                <span class="font-semibold text-gray-900 dark:text-white">R$ <span x-text="fmt(valorCota)"></span></span>
              </div>
              <div class="flex justify-between py-2 border-b border-gray-100 dark:border-gray-700">
                <span class="text-gray-500 dark:text-gray-400">Taxa plataforma (5%)</span>
                <span class="font-semibold text-amber-600 dark:text-amber-400">+ R$ <span x-text="fmt(taxa)"></span></span>
              </div>
              <div class="landing-bar-buyer flex justify-between py-3 rounded-xl px-4">
                <span class="font-medium">Comprador paga</span>
                <span class="font-bold text-lg">R$ <span x-text="fmt(compradorPaga)"></span></span>
              </div>
              <div class="landing-bar-organizer flex justify-between py-3 rounded-xl px-4">
                <span class="font-medium">Organizador recebe</span>
                <span class="font-bold text-lg">R$ <span x-text="fmt(valorCota)"></span></span>
              </div>
            </div>
          </div>

          <div class="landing-mockup landing-checkout rounded-2xl shadow-xl p-5">
            <p class="landing-checkout-muted text-xs font-semibold uppercase mb-3">Resumo no checkout</p>
            <div class="flex justify-between text-sm mb-1">
              <span>1 cota × R$ <span x-text="fmt(valorCota)"></span></span>
              <span>R$ <span x-text="fmt(valorCota)"></span></span>
            </div>
            <div class="flex justify-between text-sm text-amber-600 dark:text-amber-400 mb-3">
              <span>Taxa VouRifar (5%)</span>
              <span>+ R$ <span x-text="fmt(taxa)"></span></span>
            </div>
            <div class="flex justify-between font-bold pt-3 border-t border-gray-200 dark:border-slate-700">
              <span>Total PIX</span>
              <span class="text-emerald-600 dark:text-emerald-400">R$ <span x-text="fmt(compradorPaga)"></span></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Diferenciais -->
  <section id="diferenciais" class="py-16 lg:py-24 bg-white/70 dark:bg-slate-900/50 border-y border-gray-100 dark:border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">Modelo justo para organizadores</h2>
        <p class="text-gray-500 dark:text-gray-400">Você foca na rifa. A plataforma se mantém com uma taxa clara para quem compra.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-6">
        <article class="landing-card group relative overflow-hidden">
          <span class="absolute top-4 right-4 px-2 py-0.5 rounded-md bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 text-[10px] font-bold uppercase">0% organizador</span>
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center mb-5 shadow-lg shadow-emerald-500/20 group-hover:scale-105 transition-transform">
            <i data-lucide="badge-percent" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-2">Organizador não paga nada</h3>
          <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">
            Sua rifa, seu lucro. A comissão de <strong class="text-gray-700 dark:text-gray-300">5%</strong> fica por conta do comprador — você nunca paga taxa à plataforma.
          </p>
        </article>

        <article class="landing-card group relative overflow-hidden">
          <span class="absolute top-4 right-4 px-2 py-0.5 rounded-md bg-sky-100 dark:bg-sky-900/50 text-sky-700 dark:text-sky-300 text-[10px] font-bold uppercase">Automático</span>
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-sky-500 to-slate-700 flex items-center justify-center mb-5 shadow-lg shadow-sky-500/20 group-hover:scale-105 transition-transform">
            <i data-lucide="wallet" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-2">PIX automático com taxa embutida</h3>
          <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">
            Integração PIX calcula os <strong class="text-gray-700 dark:text-gray-300">5% automaticamente</strong>. O comprador vê o valor final antes de pagar.
          </p>
        </article>

        <article class="landing-card group relative overflow-hidden">
          <span class="absolute top-4 right-4 px-2 py-0.5 rounded-md bg-violet-100 dark:bg-violet-900/50 text-violet-700 dark:text-violet-300 text-[10px] font-bold uppercase">Sem teto</span>
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center mb-5 shadow-lg shadow-violet-500/20 group-hover:scale-105 transition-transform">
            <i data-lucide="infinity" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-2">Cotas ilimitadas</h3>
          <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">
            Rifa pequena ou grande campanha: você define o total de números. <strong class="text-gray-700 dark:text-gray-300">Sem limite de plano</strong> e sem pagar extra por quantidade.
          </p>
        </article>

        <article class="landing-card group">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-teal-500 to-cyan-600 flex items-center justify-center mb-5 shadow-lg shadow-teal-500/20 group-hover:scale-105 transition-transform">
            <i data-lucide="phone" class="w-7 h-7 text-white"></i>
          </div>
          <h3 class="text-xl font-bold mb-2">Sem login para comprar</h3>
          <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm">
            Comprador informa telefone e vê o acréscimo de <strong class="text-gray-700 dark:text-gray-300">5%</strong> no resumo antes de confirmar o PIX.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Cotas ilimitadas -->
  <section id="cotas" class="py-16 lg:py-20 bg-violet-50/60 dark:bg-violet-950/20 border-y border-violet-100 dark:border-violet-900/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300 text-xs font-bold uppercase mb-4">
            <i data-lucide="hash" class="w-3.5 h-3.5"></i> Escala livre
          </span>
          <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">Quantas cotas a sua rifa precisar</h2>
          <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">
            Outras plataformas limitam números por plano ou cobram a mais conforme cresce. Na VouRifar, <strong class="text-gray-800 dark:text-gray-200">você escolhe o tamanho da rifa</strong> — rifa de bairro, campanha solidária ou sorteio com milhares de participantes.
          </p>
          <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-400">
            <li class="flex items-start gap-3"><i data-lucide="check-circle-2" class="w-5 h-5 text-violet-600 shrink-0 mt-0.5"></i> Defina o total ao criar a rifa — de dezenas a <strong>10.000+ números</strong></li>
            <li class="flex items-start gap-3"><i data-lucide="check-circle-2" class="w-5 h-5 text-violet-600 shrink-0 mt-0.5"></i> Grade visual com busca e seleção rápida para o comprador</li>
            <li class="flex items-start gap-3"><i data-lucide="check-circle-2" class="w-5 h-5 text-violet-600 shrink-0 mt-0.5"></i> Mesma taxa de <strong>5% por cota vendida</strong> — não importa o tamanho da rifa</li>
          </ul>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="landing-card text-center p-5">
            <p class="text-3xl font-extrabold text-violet-600 dark:text-violet-400 mb-1">100</p>
            <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Cotas</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Rifa rápida entre amigos ou prêmio local</p>
          </div>
          <div class="landing-card text-center p-5 ring-2 ring-violet-400/50">
            <p class="text-3xl font-extrabold text-violet-600 dark:text-violet-400 mb-1">1.000</p>
            <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Cotas</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Campanhas médias com boa arrecadação</p>
          </div>
          <div class="landing-card text-center p-5">
            <p class="text-3xl font-extrabold text-violet-600 dark:text-violet-400 mb-1">5.000</p>
            <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Cotas</p>
            <p class="text-xs text-gray-500 dark:text-gray-400">Sorteios grandes e causas com alcance</p>
          </div>
          <div class="landing-card text-center p-5 bg-gradient-to-br from-violet-600 to-purple-700 text-white border-0">
            <p class="text-3xl font-extrabold mb-1">10.000+</p>
            <p class="text-xs font-semibold text-violet-200 uppercase mb-2">Cotas</p>
            <p class="text-xs text-violet-100/90">Sem trava de plano — cresça no seu ritmo</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Como funciona -->
  <section id="como-funciona" class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-4">Como funciona a taxa de 5%</h2>
        <p class="text-gray-500 dark:text-gray-400">Transparente para o comprador. Lucro integral para você.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <div class="hidden md:block absolute top-16 left-[20%] right-[20%] h-0.5 bg-gradient-to-r from-emerald-300 via-teal-300 to-sky-300 dark:from-emerald-800 dark:via-teal-800 dark:to-sky-800"></div>

        <div class="landing-card text-center relative">
          <div class="w-12 h-12 rounded-full landing-btn-primary flex items-center justify-center font-bold text-lg mx-auto mb-4 shadow-lg">1</div>
          <h3 class="font-bold text-lg mb-2">Organizador cria a rifa</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Valor da cota e total de números — você decide:</p>
          <div class="space-y-1">
            <div class="inline-block px-4 py-2 rounded-xl bg-gray-100 dark:bg-gray-800 font-bold text-emerald-700 dark:text-emerald-400">R$ 10,00 / cota</div>
            <div class="inline-block px-4 py-2 rounded-xl bg-violet-100 dark:bg-violet-900/40 font-bold text-violet-700 dark:text-violet-300 text-sm">1.000 números</div>
          </div>
          <p class="text-xs text-gray-400 mt-3">Sem taxa para você · cotas ilimitadas</p>
        </div>

        <div class="landing-card text-center relative">
          <div class="w-12 h-12 rounded-full landing-btn-primary flex items-center justify-center font-bold text-lg mx-auto mb-4 shadow-lg">2</div>
          <h3 class="font-bold text-lg mb-2">Comprador seleciona cotas</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Vê o valor final no resumo:</p>
          <div class="space-y-1 text-sm">
            <div class="text-gray-500">R$ 10,00 + R$ 0,50 taxa</div>
            <div class="font-bold text-lg text-slate-800 dark:text-white">= R$ 10,50 por cota</div>
          </div>
          <p class="text-xs text-amber-600 dark:text-amber-400 mt-3">Taxa visível antes do PIX</p>
        </div>

        <div class="landing-card text-center relative">
          <div class="w-12 h-12 rounded-full landing-btn-primary flex items-center justify-center font-bold text-lg mx-auto mb-4 shadow-lg">3</div>
          <h3 class="font-bold text-lg mb-2">Organizador recebe tudo</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Cada cota vendida rende:</p>
          <div class="inline-block px-4 py-2 rounded-xl bg-emerald-100 dark:bg-emerald-900/40 font-bold text-emerald-700 dark:text-emerald-400 text-xl">R$ 10,00</div>
          <p class="text-xs text-emerald-600 dark:text-emerald-400 mt-3">100% do valor da cota</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Simulador de arrecadação -->
  <section id="simulador" class="py-16 lg:py-24 bg-gradient-to-b from-emerald-50/80 to-white dark:from-emerald-950/30 dark:to-slate-950 border-y border-emerald-100 dark:border-emerald-900/30">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-300 text-xs font-bold uppercase mb-4">
          <i data-lucide="trending-up" class="w-3.5 h-3.5"></i> Projeção de vendas
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-3">Simulador de arrecadação</h2>
        <p class="text-gray-500 dark:text-gray-400 max-w-lg mx-auto">Estime quanto você arrecada e quanto os compradores pagam no total — a taxa de 5% nunca sai do seu bolso.</p>
      </div>

      <div class="landing-card">
        <div class="grid sm:grid-cols-2 gap-4 mb-6">
          <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase mb-2">Valor da cota (R$)</label>
            <input type="number" x-model.number="valorCota" min="0.01" step="0.01"
              class="landing-field w-full px-4 py-3 rounded-xl font-bold">
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase mb-2">Cotas vendidas</label>
            <input type="number" x-model.number="cotasVendidas" min="0" step="1"
              class="landing-field w-full px-4 py-3 rounded-xl font-bold">
            <input type="range" x-model.number="cotasVendidas" min="0" max="10000" step="1" class="w-full mt-3 accent-emerald-600">
            <div class="flex flex-wrap gap-2 mt-2">
              <button type="button" @click="cotasVendidas = 100" class="text-[10px] px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-violet-100 dark:hover:bg-violet-900/40 transition">100</button>
              <button type="button" @click="cotasVendidas = 500" class="text-[10px] px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-violet-100 dark:hover:bg-violet-900/40 transition">500</button>
              <button type="button" @click="cotasVendidas = 1000" class="text-[10px] px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-violet-100 dark:hover:bg-violet-900/40 transition">1.000</button>
              <button type="button" @click="cotasVendidas = 5000" class="text-[10px] px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 hover:bg-violet-100 dark:hover:bg-violet-900/40 transition">5.000</button>
              <button type="button" @click="cotasVendidas = 10000" class="text-[10px] px-2 py-1 rounded-lg bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-300 font-semibold hover:bg-violet-200 dark:hover:bg-violet-900/60 transition">10.000</button>
            </div>
            <p class="text-[11px] text-gray-400 mt-2"><span x-text="cotasVendidas.toLocaleString('pt-BR')"></span> cotas × R$ <span x-text="fmt(valorCota)"></span> · sem limite de plano</p>
          </div>
        </div>

        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          <div class="rounded-2xl bg-emerald-50 dark:bg-emerald-900/25 border border-emerald-200 dark:border-emerald-800 p-5 text-center">
