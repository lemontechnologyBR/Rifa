<script>
  const TENANT_SLUG = '<%= tenant.slug %>';
  const API_BASE = '/<%= tenant.slug %>/api';
  const RIFA_ID = <%= rifa.id %>;
  const VALOR_COTA = <%= rifa.valorCota %>;
  const COTAS_DISPONIVEIS = <%= stats.disponiveis %>;
  const QTD_MAX = Math.min(5000, <%= stats.disponiveis %>);
  const RIFA_ATIVA = <%= rifa.status === 'ativa' ? 'true' : 'false' %>;
  const FAIXAS = <%- JSON.stringify(rifa.faixasDesconto || []) %>;
  const TEMPO_RESERVA_MIN = <%= typeof tempoReservaMin !== 'undefined' ? tempoReservaMin : 10 %>;
  const CODIGO_INDICACAO = '<%= codigoIndicacao || '' %>';
  const DATA_SORTEIO = '<%= new Date(rifa.dataSorteio).toISOString() %>';

  /* Botão total label sync */
  (function() {
    function syncBtn() {
      var qtd = parseInt(document.getElementById('input-qtd-cotas')?.value || 1);
      var total = qtd * VALOR_COTA;
      var lbl = document.getElementById('btn-total-label');
      if (lbl) lbl.textContent = 'R$ ' + total.toFixed(2).replace('.', ',');
    }
    document.getElementById('input-qtd-cotas')?.addEventListener('input', syncBtn);
    document.getElementById('qtd-menos')?.addEventListener('click', function(){ setTimeout(syncBtn,10); });
    document.getElementById('qtd-mais')?.addEventListener('click', function(){ setTimeout(syncBtn,10); });
    document.querySelectorAll('[data-add-qtd]').forEach(function(b){
      b.addEventListener('click', function(){ setTimeout(syncBtn,50); });
    });
    syncBtn();
  })();

  /* Countdown sorteio */
  (function () {
    var alvo = new Date(DATA_SORTEIO).getTime();
    var els = {
      dias: document.getElementById('cd-dias'),
      horas: document.getElementById('cd-horas'),
      min: document.getElementById('cd-min'),
      status: document.getElementById('sorteio-status')
    };
    if (!els.dias) return;
    function pad(n) { return String(n).padStart(2, '0'); }
    function tick() {
      var diff = alvo - Date.now();
      if (diff <= 0) {
        if (els.status) { els.status.style.display='block'; els.status.textContent = '<%= rifa.status === "finalizada" ? "Sorteio realizado!" : "Sorteio em andamento!" %>'; }
        clearInterval(iv); return;
      }
      els.dias.textContent  = Math.floor(diff / 86400000);
      els.horas.textContent = pad(Math.floor((diff % 86400000) / 3600000));
      els.min.textContent   = pad(Math.floor((diff % 3600000) / 60000));
    }
    tick();
    var iv = setInterval(tick, 1000);
  })();

  window.__pendingScripts = window.__pendingScripts || [];
  window.__pendingScripts.push('/js/rifa-detalhe.js');
</script>

