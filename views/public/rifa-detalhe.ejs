<%- include('../partials/header') %>

<style>
/* ═══════════════════════════════════════════════
   DETALHE RIFA — ESTILO IMPÉRIO PRÊMIOS
═══════════════════════════════════════════════ */
.imp-detail { background: #12121f; min-height: 100vh; color: #fff; }
body .glass-nav { background: rgba(18,18,31,.97) !important; border-color: rgba(255,255,255,.07) !important; }

.imp-card-dark {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 14px;
  overflow: hidden;
}

.imp-progress-wrap { background: rgba(255,255,255,.1); border-radius: 9999px; height: 10px; overflow: hidden; }
.imp-progress-bar  { height: 100%; border-radius: 9999px; background: linear-gradient(90deg,#22c55e,#16a34a); transition: width .6s; }

.imp-pkg-btn {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 12px;
  padding: 14px 10px;
  text-align: center;
  cursor: pointer;
  transition: border-color .15s, background .15s;
  position: relative;
}
.imp-pkg-btn:hover, .imp-pkg-btn.active {
  border-color: #22c55e;
  background: rgba(34,197,94,.08);
}
.imp-pkg-popular {
  position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
  background: #22c55e; color: #000; font-size: 10px; font-weight: 900;
  padding: 2px 10px; border-radius: 9999px; white-space: nowrap;
}

.imp-stepper-btn {
  width: 44px; height: 44px; border-radius: 10px;
  background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
  color: #fff; font-size: 22px; font-weight: 700; cursor: pointer;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.imp-stepper-btn:hover { background: rgba(255,255,255,.15); }

.imp-stepper-input {
  width: 90px; text-align: center; font-size: 22px; font-weight: 900;
  background: #111827; border: 1px solid rgba(255,255,255,.15); border-radius: 10px;
  color: #fff; padding: 8px;
}

.imp-btn-green {
  background: #22c55e; color: #000; font-weight: 900; border-radius: 12px;
  padding: 15px 20px; font-size: 15px; border: none; cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 8px;
  width: 100%; transition: background .15s, transform .15s;
}
.imp-btn-green:hover { background: #16a34a; transform: translateY(-1px); }
.imp-btn-green:disabled { background: #374151; color: #6b7280; cursor: not-allowed; transform: none; }

.imp-accordion-trigger {
  width: 100%; background: #1e1e32; border: 1px solid rgba(255,255,255,.07);
  border-radius: 12px; padding: 14px 18px; display: flex; align-items: center;
  justify-content: space-between; cursor: pointer; color: #d1d5db; font-weight: 700;
  font-size: 14px;
}
.imp-accordion-trigger:hover { background: #232338; }

.imp-btn-outline-sm {
  background: transparent; border: 1px solid rgba(255,255,255,.15);
  border-radius: 9px; padding: 9px 16px; color: #9ca3af; font-size: 13px;
  font-weight: 700; cursor: pointer; transition: .15s; text-decoration: none;
  display: inline-flex; align-items: center; gap: 6px;
}
.imp-btn-outline-sm:hover { border-color: rgba(255,255,255,.35); color: #fff; }

@keyframes imp-slide-up { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
.imp-fade { animation: imp-slide-up .4s ease forwards; }
</style>

<%
  const pctVend = stats.total > 0 ? Math.round(((stats.total - stats.disponiveis) / stats.total) * 100) : 0;
  const vendidos = stats.total - stats.disponiveis;
  const dataFmt  = new Date(rifa.dataSorteio).toLocaleDateString('pt-BR', {weekday:'long',day:'2-digit',month:'long',year:'numeric'});
  const tenantBase = '/' + tenant.slug;
%>

<div class="imp-detail pb-32">
  <div class="max-w-2xl mx-auto px-3 sm:px-4 py-4">

    <!-- Voltar -->
    <a href="<%= tenantBase %>/" style="display:inline-flex;align-items:center;gap:6px;color:#6b7280;font-size:13px;font-weight:600;margin-bottom:14px;text-decoration:none;">
      <i data-lucide="arrow-left" class="w-4 h-4"></i> Campanhas
    </a>

    <!-- Imagem principal -->
    <div style="position:relative;border-radius:14px;overflow:hidden;margin-bottom:0;" class="imp-card-dark">
      <% if (rifa.imagemUrl) { %>
        <img src="<%= rifa.imagemUrl %>" alt="<%= rifa.titulo %>"
             style="width:100%;max-height:280px;object-fit:cover;display:block;">
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(18,18,31,.9) 0%,transparent 50%);"></div>
      <% } else { %>
        <div style="width:100%;height:200px;background:linear-gradient(135deg,#1a1a2e,#0d0d1a);display:flex;align-items:center;justify-content:center;font-size:5rem;">🏆</div>
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(18,18,31,.9) 0%,transparent 60%);"></div>
      <% } %>

      <!-- Badge status -->
      <div style="position:absolute;top:12px;left:12px;display:flex;gap:6px;">
        <span style="background:rgba(34,197,94,.2);border:1px solid rgba(34,197,94,.4);color:#22c55e;padding:4px 10px;border-radius:9999px;font-size:10px;font-weight:900;text-transform:uppercase;">● <%= rifa.status === 'ativa' ? 'ATIVA' : rifa.status.toUpperCase() %></span>
        <% if (pctVend >= 75) { %><span style="background:rgba(249,115,22,.2);border:1px solid rgba(249,115,22,.4);color:#fb923c;padding:4px 10px;border-radius:9999px;font-size:10px;font-weight:900;">🔥 Quase esgotando!</span><% } %>
      </div>

      <!-- Título overlay -->
      <div style="position:absolute;bottom:0;left:0;right:0;padding:16px;">
        <h1 style="font-size:18px;font-weight:900;color:#fff;margin:0 0 4px;text-shadow:0 2px 8px rgba(0,0,0,.6);"><%= rifa.titulo %></h1>
        <p style="font-size:12px;color:rgba(255,255,255,.55);margin:0;text-transform:capitalize;">
          Resultado: <%= dataFmt.charAt(0).toUpperCase() + dataFmt.slice(1) %>
        </p>
      </div>
    </div>

    <!-- Barra de progresso -->
    <div style="background:#1a1a2e;border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:14px 16px;margin-top:10px;margin-bottom:10px;" class="imp-fade">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <a href="<%= tenantBase %>/minhas-reservas" style="font-size:12px;color:#9ca3af;font-weight:700;text-decoration:none;display:flex;align-items:center;gap:4px;">
          <i data-lucide="ticket" class="w-3.5 h-3.5"></i> Meus títulos
        </a>
        <span style="font-size:14px;font-weight:900;color:#22c55e;"><%= pctVend %>%</span>
      </div>
      <div class="imp-progress-wrap">
        <div class="imp-progress-bar" style="width:<%= Math.max(pctVend,2) %>%;"></div>
      </div>
      <div style="display:flex;justify-content:space-between;font-size:11px;color:#6b7280;margin-top:6px;">
        <span><%= vendidos.toLocaleString('pt-BR') %> vendidos</span>
        <span><%= stats.disponiveis.toLocaleString('pt-BR') %> disponíveis</span>
      </div>
    </div>

    <!-- Preço -->
    <div style="background:#1a1a2e;border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:14px 16px;margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;" class="imp-fade">
      <div>
        <div style="font-size:11px;color:#6b7280;font-weight:700;text-transform:uppercase;margin-bottom:2px;">Por apenas</div>
        <div style="font-size:26px;font-weight:900;color:#fff;">R$&nbsp;<%= rifa.valorCota.toFixed(2).replace('.',',') %></div>
      </div>
      <div style="text-align:right;">
        <div style="font-size:11px;color:#6b7280;margin-bottom:4px;">Sorteio em</div>
        <div style="display:flex;gap:6px;">
          <div style="background:#111827;border-radius:8px;padding:6px 10px;text-align:center;">
            <span id="cd-dias" style="display:block;font-size:16px;font-weight:900;color:#22c55e;line-height:1;">--</span>
            <span style="font-size:9px;color:#6b7280;text-transform:uppercase;">dias</span>
          </div>
          <div style="background:#111827;border-radius:8px;padding:6px 10px;text-align:center;">
            <span id="cd-horas" style="display:block;font-size:16px;font-weight:900;color:#22c55e;line-height:1;">--</span>
            <span style="font-size:9px;color:#6b7280;text-transform:uppercase;">hrs</span>
          </div>
          <div style="background:#111827;border-radius:8px;padding:6px 10px;text-align:center;">
            <span id="cd-min" style="display:block;font-size:16px;font-weight:900;color:#22c55e;line-height:1;">--</span>
            <span style="font-size:9px;color:#6b7280;text-transform:uppercase;">min</span>
          </div>
        </div>
        <p id="sorteio-status" class="hidden" style="font-size:12px;font-weight:800;color:#22c55e;margin-top:4px;"></p>
      </div>
    </div>

    <% if (rifa.status === 'ativa') { %>

    <!-- Pacotes de desconto (faixas) -->
    <% if (rifa.faixasDesconto && rifa.faixasDesconto.length) { %>
    <div style="background:#1a1a2e;border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:14px 16px;margin-bottom:10px;" class="imp-fade">
      <div style="display:flex;align-items:center;gap:6px;margin-bottom:12px;">
        <span style="font-size:16px;">🔥</span>
        <span style="font-weight:800;color:#fff;font-size:14px;">Promoção</span>
        <span style="font-size:12px;color:#6b7280;">Compre mais barato!</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(<%= Math.min(rifa.faixasDesconto.length,3) %>,1fr);gap:8px;">
        <% rifa.faixasDesconto.forEach(function(f, fi) { %>
        <button type="button" class="imp-pkg-btn" data-add-qtd="<%= f.quantidadeMin %>"
          style="padding-top:<%= fi===0?'20px':'14px' %>;">
          <% if (fi === 0) { %><span class="imp-pkg-popular">Mais popular</span><% } %>
          <div style="font-size:16px;font-weight:900;color:#22c55e;">+<%= f.quantidadeMin.toLocaleString('pt-BR') %></div>
          <div style="font-size:13px;font-weight:700;color:#fff;margin-top:2px;">R$&nbsp;<%= f.valorTotal.toFixed(2).replace('.',',') %></div>
          <div style="font-size:10px;color:#6b7280;margin-top:2px;">SELECIONAR</div>
        </button>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- Seção de compra -->
    <div style="background:#1a1a2e;border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:16px;margin-bottom:10px;" class="imp-fade" id="comprar-cotas">
      <p style="font-size:13px;color:#9ca3af;text-align:center;margin:0 0 14px;">Quanto mais títulos, mais chances de ganhar!</p>

      <!-- Pacotes rápidos sem faixas -->
      <% if (!rifa.faixasDesconto || !rifa.faixasDesconto.length) { %>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px;">
        <button type="button" class="imp-pkg-btn" data-add-qtd="10">
          <div style="font-size:15px;font-weight:900;color:#22c55e;">+10</div>
          <div style="font-size:10px;color:#6b7280;margin-top:2px;">SELECIONAR</div>
        </button>
        <button type="button" class="imp-pkg-btn" style="padding-top:20px;">
          <span class="imp-pkg-popular">Mais popular</span>
          <div style="font-size:15px;font-weight:900;color:#22c55e;">+50</div>
          <div style="font-size:10px;color:#6b7280;margin-top:2px;">SELECIONAR</div>
        </button>
        <button type="button" class="imp-pkg-btn" data-add-qtd="100">
          <div style="font-size:15px;font-weight:900;color:#22c55e;">+100</div>
          <div style="font-size:10px;color:#6b7280;margin-top:2px;">SELECIONAR</div>
        </button>
      </div>
      <% } %>

      <!-- Stepper -->
      <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:10px;">
        <button type="button" class="imp-stepper-btn" id="qtd-menos" aria-label="Diminuir">−</button>
        <input type="number" id="input-qtd-cotas" class="imp-stepper-input" value="1" min="1" inputmode="numeric">
        <button type="button" class="imp-stepper-btn" id="qtd-mais" aria-label="Aumentar">+</button>
      </div>

      <p style="text-align:center;font-size:12px;color:#6b7280;margin:0 0 14px;">
        <span id="label-qtd-cotas">1</span> cota(s) ·
        <span id="label-disponiveis"><%= stats.disponiveis %></span> disponíveis
      </p>
      <p id="aviso-limite-qtd" style="text-align:center;font-size:12px;color:#fbbf24;margin:0 0 6px;" class="hidden"></p>
      <p id="aviso-compra-minima" style="text-align:center;font-size:12px;color:#fbbf24;margin:0 0 6px;" class="hidden">Compra mínima: R$ 10,50</p>

      <!-- Resumo -->
      <div style="border-top:1px solid rgba(255,255,255,.08);padding-top:12px;margin-bottom:14px;display:flex;flex-direction:column;gap:6px;font-size:13px;">
        <div style="display:flex;justify-content:space-between;color:#9ca3af;"><span>Cotas</span><span id="page-res-qtd" style="color:#fff;font-weight:600;">1</span></div>
        <div style="display:flex;justify-content:space-between;color:#9ca3af;"><span>Subtotal</span><span id="page-res-subtotal">R$ 0,00</span></div>
        <div style="display:flex;justify-content:space-between;font-size:16px;font-weight:900;padding-top:10px;border-top:1px solid rgba(255,255,255,.08);">
          <span style="color:#fff;">Total PIX</span>
          <span id="page-res-total" style="color:#22c55e;">R$ 0,00</span>
        </div>
      </div>

      <button type="button" id="btn-iniciar-compra" class="imp-btn-green">
        <i data-lucide="qr-code" class="w-5 h-5"></i>
        Quero participar · <span id="btn-total-label">R$ 0,00</span>
      </button>
    </div>

    <!-- Compartilhar -->
    <div style="margin-bottom:10px;">
      <a href="https://wa.me/?text=<%= whatsappMsg %>" target="_blank" class="imp-btn-outline-sm" style="width:100%;justify-content:center;">
        <i data-lucide="share-2" class="w-4 h-4"></i> Compartilhar no WhatsApp
      </a>
    </div>

    <% } else if (rifa.status === 'finalizada') { %>
    <div style="margin-bottom:10px;">
      <a href="<%= tenantBase %>/rifas/<%= rifa.id %>/resultado" class="imp-btn-green" style="display:flex;">🏆 Ver Resultado do Sorteio</a>
    </div>
    <% } %>

    <!-- Descrição/Regulamento accordion -->
    <div style="margin-bottom:10px;" class="imp-fade">
      <button class="imp-accordion-trigger" onclick="var c=document.getElementById('acc-desc');c.style.display=c.style.display==='none'?'block':'none';">
        <span>📋 Descrição / Regulamento</span>
        <i data-lucide="chevron-down" class="w-4 h-4"></i>
      </button>
      <div id="acc-desc" style="display:none;background:#1a1a2e;border:1px solid rgba(255,255,255,.07);border-top:none;border-radius:0 0 12px 12px;padding:16px;">
        <p style="font-size:14px;color:#d1d5db;line-height:1.7;white-space:pre-line;margin:0;"><%= rifa.descricao || 'Nenhuma descrição fornecida.' %></p>
      </div>
    </div>

    <!-- Depoimentos -->
    <div style="background:#1a1a2e;border:1px solid rgba(255,255,255,.07);border-radius:14px;padding:16px;" class="imp-fade" id="comentarios">
      <h2 style="font-size:15px;font-weight:800;color:#fff;margin:0 0 14px;display:flex;align-items:center;gap:6px;">
        <i data-lucide="message-circle" class="w-4 h-4" style="color:#22c55e;"></i> Depoimentos
      </h2>
      <div id="lista-comentarios" style="display:flex;flex-direction:column;gap:10px;">
        <% if (!(comentarios || []).length) { %>
          <p id="depoimentos-vazio" style="font-size:13px;color:#6b7280;text-align:center;padding:16px 0;margin:0;">Seja o primeiro a comentar!</p>
        <% } %>
        <% (comentarios || []).forEach(function(c) { %>
          <div class="depoimento-item" style="display:flex;gap:10px;padding:12px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:10px;">
            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#22c55e,#16a34a);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;color:#000;flex-shrink:0;"><%= c.usuario.nome.charAt(0).toUpperCase() %></div>
            <div>
              <p style="font-size:13px;color:#d1d5db;margin:0 0 4px;" class="depoimento-texto"><%= c.texto %></p>
              <p style="font-size:11px;color:#6b7280;margin:0;"><%= c.usuario.nome %> · <%= new Date(c.createdAt).toLocaleDateString('pt-BR') %></p>
            </div>
          </div>
        <% }); %>
      </div>

      <form id="form-depoimento" style="margin-top:14px;padding-top:14px;border-top:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;gap:10px;">
        <p style="font-size:11px;color:#6b7280;margin:0;display:flex;align-items:flex-start;gap:6px;">
          <i data-lucide="shield-check" class="w-3.5 h-3.5" style="color:#22c55e;flex-shrink:0;margin-top:1px;"></i>
          Somente quem comprou com pagamento confirmado pode comentar.
        </p>
        <input type="text" name="cpf" id="depoimento-cpf" required placeholder="Seu CPF (000.000.000-00)" inputmode="numeric" maxlength="14"
          style="background:#111827;border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:11px 14px;color:#fff;font-size:13px;width:100%;">
        <textarea name="texto" rows="3" maxlength="500" required placeholder="Conte como foi sua experiência..."
          style="background:#111827;border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:11px 14px;color:#fff;font-size:13px;width:100%;resize:none;"></textarea>
        <button type="submit" class="imp-btn-green" style="font-size:13px;padding:12px;">
          <i data-lucide="send" class="w-4 h-4"></i> Enviar depoimento
        </button>
      </form>
    </div>

  </div>
</div>

<!-- ══ STICKY BAR MOBILE ══════════════════════════════════════════ -->
<% if (rifa.status === 'ativa') { %>
<div id="sticky-buy" class="lg:hidden fixed bottom-0 inset-x-0 z-40"
     style="background:rgba(18,18,31,.97);border-top:1px solid rgba(255,255,255,.08);padding:12px 16px;">
  <div style="display:flex;align-items:center;gap:12px;max-width:480px;margin:0 auto;">
    <div style="flex:1;">
      <div style="font-size:11px;color:#6b7280;"><span id="sticky-qtd">1</span> cota(s)</div>
      <div style="font-size:18px;font-weight:900;color:#22c55e;" id="sticky-total">R$ 0,00</div>
    </div>
    <button id="btn-comprar-mobile" class="imp-btn-green" style="flex:1;max-width:180px;padding:12px 16px;font-size:14px;">
      <i data-lucide="qr-code" class="w-4 h-4"></i> Participar
    </button>
  </div>
</div>
<% } %>

<!-- ══ MODAL COMPRA ══════════════════════════════════════════════ -->
<div id="modal-compra" class="fixed inset-0 z-50 hidden flex items-end sm:items-center justify-center p-0 sm:p-4" style="background:rgba(0,0,0,.8);">
  <div style="background:#1a1a2e;border:1px solid rgba(255,255,255,.1);color:#fff;width:100%;max-width:480px;border-radius:20px 20px 0 0;overflow-y:auto;max-height:92vh;" class="sm:rounded-2xl pb-safe">
    <div style="width:48px;height:4px;background:rgba(255,255,255,.15);border-radius:9999px;margin:12px auto 0;" class="sm:hidden"></div>
    <div style="padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:space-between;">
      <h3 style="font-weight:800;font-size:16px;color:#fff;margin:0;">Finalizar compra</h3>
      <button id="btn-fechar-modal" style="background:rgba(255,255,255,.08);border:none;border-radius:8px;padding:8px;cursor:pointer;color:#9ca3af;">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>
    <div style="padding:20px;">
      <div id="timer-reserva" style="display:none;background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:10px 14px;margin-bottom:14px;font-size:13px;color:#fbbf24;display:flex;align-items:center;gap:8px;">
        <i data-lucide="clock" class="w-4 h-4"></i>
        Reserva expira em <strong id="timer-texto" style="margin-left:4px;"><%= typeof tempoReservaMin !== 'undefined' ? tempoReservaMin : 10 %>:00</strong>
      </div>
      <div style="margin-bottom:14px;">
        <div style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;margin-bottom:8px;">Suas cotas</div>
        <div id="numeros-selecionados" style="font-size:13px;color:#d1d5db;"></div>
      </div>
      <div id="checkout-resumo" style="display:none;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:14px;margin-bottom:14px;font-size:13px;">
        <div style="display:flex;justify-content:space-between;color:#9ca3af;margin-bottom:6px;"><span>Subtotal</span><span id="checkout-subtotal">R$ 0,00</span></div>
        <div style="display:flex;justify-content:space-between;font-weight:900;font-size:15px;padding-top:10px;border-top:1px solid rgba(255,255,255,.08);">
          <span style="color:#fff;">Total PIX</span><span id="valor-total" style="color:#22c55e;">R$ 0,00</span>
        </div>
      </div>
      <form id="form-compra" style="display:flex;flex-direction:column;gap:10px;">
        <input type="text" name="nome" required placeholder="Nome completo *"
          style="background:#111827;border:1px solid rgba(255,255,255,.12);border-radius:10px;padding:12px 14px;color:#fff;font-size:14px;width:100%;">
