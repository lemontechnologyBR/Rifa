<%- include('../partials/header') %>



<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 pb-safe">

  <div class="text-center mb-8 animate-fade-up">

    <div class="w-14 h-14 rounded-2xl btn-brand flex items-center justify-center mx-auto mb-4 shadow-lg shadow-indigo-500/30">

      <i data-lucide="clipboard-list" class="w-7 h-7 text-white"></i>

    </div>

    <h1 class="text-2xl sm:text-3xl font-extrabold dark:text-white mb-2">Minhas Reservas</h1>

    <p class="text-gray-500 dark:text-gray-400">Informe o CPF usado na compra para consultar reservas e comprovantes.</p>

  </div>



  <% if (typeof erro !== 'undefined' && erro) { %>

    <div class="bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-6 text-sm"><%= erro %></div>

  <% } %>



  <form method="POST" action="<%= tenantBase %>/minhas-reservas" class="bg-white dark:bg-gray-800/80 rounded-2xl shadow-lg border border-gray-100 dark:border-gray-700/60 p-6 mb-8 animate-fade-up">

    <input type="hidden" name="_csrf" value="<%= csrfToken %>">

    <div class="flex flex-col sm:flex-row gap-3">

      <input type="text" name="cpf" id="input-busca-cpf" value="<%= typeof cpf !== 'undefined' ? cpf : '' %>"

             class="input-field flex-1"

             placeholder="000.000.000-00" inputmode="numeric" maxlength="14" required>

      <button type="submit" class="btn-brand font-semibold px-6 py-3 rounded-xl flex items-center justify-center gap-2 shadow-md">

        <i data-lucide="search" class="w-5 h-5"></i> Buscar

      </button>

    </div>

  </form>



  <% if (resultado !== null) { %>

    <% if (!resultado.usuario) { %>

      <div class="text-center py-16 bg-white dark:bg-gray-800/80 rounded-2xl border border-dashed border-gray-300 dark:border-gray-700">

        <i data-lucide="user-x" class="w-14 h-14 text-gray-300 mx-auto mb-3"></i>

        <p class="text-gray-500 dark:text-gray-400">Nenhuma reserva encontrada para este CPF.</p>

      </div>

    <% } else { %>

      <div class="flex items-center gap-3 mb-6 p-4 bg-indigo-50 dark:bg-indigo-900/30 rounded-xl border border-indigo-100 dark:border-indigo-800">

        <div class="w-10 h-10 rounded-full btn-brand flex items-center justify-center text-white font-bold"><%= resultado.usuario.nome.charAt(0).toUpperCase() %></div>

        <div>

          <p class="font-semibold dark:text-white">Olá, <%= resultado.usuario.nome %>!</p>

          <p class="text-sm text-gray-500 dark:text-gray-400"><%= resultado.reservas.length %> reserva(s) encontrada(s)</p>

        </div>

      </div>



      <div class="space-y-4">

        <% resultado.reservas.forEach(function(r) { %>

          <div class="bg-white dark:bg-gray-800/80 rounded-2xl shadow-md border border-gray-100 dark:border-gray-700/60 p-6 card-hover <%= r.ganhou ? 'ring-2 ring-yellow-400' : '' %>">

            <% if (r.ganhou) { %>

              <div class="bg-gradient-to-r from-yellow-50 to-amber-50 dark:from-yellow-900/30 dark:to-amber-900/20 border border-yellow-200 dark:border-yellow-800 rounded-xl p-3 mb-4 flex items-center gap-2">

                <i data-lucide="trophy" class="w-5 h-5 text-yellow-600"></i>

                <span class="text-yellow-800 dark:text-yellow-300 font-bold">🎉 PARABÉNS! Você ganhou esta rifa!</span>

              </div>

            <% } %>



            <div class="flex flex-wrap justify-between items-start gap-4 mb-4">

              <div>

                <h3 class="font-bold dark:text-white text-base sm:text-lg break-words"><%= r.rifa_titulo %></h3>

                <p class="text-sm text-gray-500">Reserva #<%= r.id %> · <%= new Date(r.createdAt).toLocaleString('pt-BR') %></p>

              </div>

              <% 

                let statusClass = 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300';

                let statusText = 'Pendente';

                if (r.statusPagamento === 'confirmado') { statusClass = 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300'; statusText = 'Confirmado'; }

                if (r.statusPagamento === 'cancelado') { statusClass = 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300'; statusText = 'Cancelado'; }

                if (r.statusPagamento === 'expirado') { statusClass = 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300'; statusText = 'Expirado'; }

              %>

              <span class="text-xs font-semibold px-3 py-1 rounded-full <%= statusClass %>"><%= statusText %></span>

            </div>



            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm mb-4">

              <div class="bg-gray-50 dark:bg-gray-900/40 rounded-lg p-2 col-span-2 sm:col-span-1">

                <span class="text-gray-500 block text-xs">Números</span>

                <span class="font-semibold dark:text-white mobile-text-wrap text-sm"><%= r.numeros.join(', ') %></span>

              </div>

              <div class="bg-gray-50 dark:bg-gray-900/40 rounded-lg p-2">

                <span class="text-gray-500 block text-xs">Valor Total</span>

                <span class="font-semibold text-indigo-600 dark:text-indigo-400">R$ <%= r.valorTotal.toFixed(2).replace('.', ',') %></span>

              </div>

              <div class="bg-gray-50 dark:bg-gray-900/40 rounded-lg p-2">

                <span class="text-gray-500 block text-xs">Sorteio</span>

                <span class="font-semibold dark:text-white"><%= new Date(r.data_sorteio || r.rifa?.dataSorteio).toLocaleDateString('pt-BR') %></span>

              </div>

              <div class="bg-gray-50 dark:bg-gray-900/40 rounded-lg p-2">

                <span class="text-gray-500 block text-xs">Status Rifa</span>

                <span class="font-semibold dark:text-white capitalize"><%= r.rifa_status %></span>

              </div>

            </div>



            <a href="<%= tenantBase %>/comprovante/<%= r.id %>"

               class="inline-flex items-center gap-1.5 btn-brand text-sm font-semibold px-4 py-2 rounded-xl">

              <i data-lucide="file-text" class="w-4 h-4"></i> Ver comprovante

            </a>

          </div>

        <% }); %>

      </div>

    <% } %>

  <% } %>

</div>



<%- include('../partials/footer', { tenantPublic: true }) %>

