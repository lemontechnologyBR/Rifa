<%- include('../partials/header') %>

<style>
@keyframes pulse-ring {
  0%   { transform: scale(1);    opacity:.7; }
  100% { transform: scale(1.5);  opacity:0;  }
}
@keyframes slideUp {
  from { opacity:0; transform:translateY(20px); }
  to   { opacity:1; transform:translateY(0); }
}
.rifa-card-anim { animation: slideUp .45s ease forwards; opacity:0; }
.rifa-card-anim:nth-child(1){animation-delay:.05s}
.rifa-card-anim:nth-child(2){animation-delay:.12s}
.rifa-card-anim:nth-child(3){animation-delay:.19s}
.rifa-card-anim:nth-child(4){animation-delay:.26s}
.rifa-card-anim:nth-child(5){animation-delay:.33s}
.rifa-card-anim:nth-child(6){animation-delay:.40s}
.live-dot::before {
  content:'';
  position:absolute; inset:-3px;
  border-radius:50%;
  background:currentColor;
  animation: pulse-ring 1.4s ease-out infinite;
}
.progress-hot { background: linear-gradient(90deg, #f59e0b, #ef4444); }
.progress-mid { background: linear-gradient(90deg, #10b981, #06b6d4); }
.progress-low { background: linear-gradient(90deg, #6366f1, #8b5cf6); }
.store-hero-bg {
  background: linear-gradient(135deg, var(--hero-from,#0f172a) 0%, var(--hero-to,#134e4a) 100%);
}
</style>

<%
  const corPrimaria = tenant.corPrimaria || '#10b981';
  const totalAtivos = rifas.length;
  const totalCotas = rifas.reduce((s,r) => s + (r.stats.disponiveis || 0), 0);
  const totalVendidos = rifas.reduce((s,r) => s + (r.stats.vendidos || (r.stats.total - r.stats.disponiveis) || 0), 0);
  const nomeExibido = typeof organizadorNome !== 'undefined' ? organizadorNome : tenant.nome;
  const iniciais = nomeExibido.split(' ').slice(0,2).map(p=>p[0]).join('').toUpperCase();
%>

<!-- ══ SORTEIOS ══════════════════════════════════════════════════ -->
<div class="public-site max-w-5xl mx-auto px-4 sm:px-6 py-8 pb-20 pb-safe">

  <% if (rifas.length === 0) { %>

    <div class="text-center py-24">
      <div class="text-6xl mb-5">🎯</div>
      <p class="text-gray-700 dark:text-white text-xl font-bold mb-2">Nenhum sorteio ativo agora</p>
      <p class="text-gray-400 dark:text-gray-500 text-sm">Volte em breve — novidades chegando!</p>
    </div>

  <% } else { %>

    <div id="rifas-container" class="grid grid-cols-1 sm:grid-cols-2 gap-5"
         data-page="<%= page %>" data-paginas="<%= paginas %>"
         data-slug="<%= tenant.slug %>"
         data-organizador-nome="<%= nomeExibido.replace(/"/g, '&quot;') %>">

      <% rifas.forEach(function(rifa, idx) {
        const vendidos  = rifa.stats.vendidos || (rifa.stats.total - rifa.stats.disponiveis);
        const pct       = rifa.stats.total > 0 ? Math.round((vendidos / rifa.stats.total) * 100) : 0;
        const isQuente  = pct >= 75;
        const isMeio    = pct >= 40 && pct < 75;
        const diasRestantes = Math.max(0, Math.ceil((new Date(rifa.dataSorteio) - new Date()) / (1000*60*60*24)));
        const urgente   = diasRestantes <= 3 && diasRestantes >= 0;
      %>

        <article class="public-rifa-card rifa-card-anim flex flex-col overflow-hidden group">

          <!-- Imagem ou placeholder colorido -->
          <div class="relative <% if (rifa.imagemUrl) { %>h-52<% } else { %>h-28<% } %> overflow-hidden shrink-0">

            <% if (rifa.imagemUrl) { %>
              <img src="<%= rifa.imagemUrl %>" alt="<%= rifa.titulo %>"
                   class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy">
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
            <% } else { %>
              <div class="w-full h-full flex items-center justify-center text-4xl"
                   style="background:linear-gradient(135deg,<%= corPrimaria %>33,<%= corPrimaria %>11)">
                🏆
              </div>
            <% } %>

            <!-- Badges sobrepostos -->
            <div class="absolute top-3 left-3 flex flex-wrap gap-1.5">
              <% if (urgente) { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-red-600 text-white text-[10px] font-black uppercase shadow">
                  ⏰ <%= diasRestantes === 0 ? 'Hoje!' : diasRestantes + 'd' %>
                </span>
              <% } %>
              <% if (isQuente) { %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-orange-500 text-white text-[10px] font-black uppercase shadow">
                  🔥 Quente
                </span>
              <% } %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-emerald-500 text-white text-[10px] font-bold uppercase shadow">
                ATIVA
              </span>
            </div>

            <% if (rifa.imagemUrl) { %>
              <div class="absolute bottom-3 left-3 right-3">
                <h3 class="font-black text-white text-lg leading-tight drop-shadow-lg"><%= rifa.titulo %></h3>
              </div>
            <% } %>
          </div>

          <!-- Corpo do card -->
          <div class="p-5 flex flex-col flex-1">

            <% if (!rifa.imagemUrl) { %>
              <h3 class="font-black text-lg text-gray-900 dark:text-white mb-3 leading-snug"><%= rifa.titulo %></h3>
            <% } %>

            <!-- Valor + stats -->
            <div class="flex items-end justify-between mb-4">
              <div>
                <p class="text-[10px] text-gray-500 dark:text-gray-400 uppercase font-bold mb-0.5">Valor da cota</p>
                <p class="text-3xl font-black rifa-brand-text leading-none">R$&nbsp;<%= rifa.valorCota.toFixed(2).replace('.', ',') %></p>
              </div>
              <div class="text-right">
                <p class="text-sm font-bold text-gray-700 dark:text-white"><%= vendidos.toLocaleString('pt-BR') %> <span class="text-gray-400 font-normal">/ <%= rifa.stats.total.toLocaleString('pt-BR') %></span></p>
                <p class="text-[11px] text-gray-400 flex items-center justify-end gap-1 mt-0.5">
                  <i data-lucide="calendar" class="w-3 h-3"></i>
                  <%= new Date(rifa.dataSorteio).toLocaleDateString('pt-BR') %>
                </p>
              </div>
            </div>

            <!-- Barra de progresso -->
            <div class="mb-5 rounded-2xl p-4 <%= isQuente ? 'bg-orange-50 dark:bg-orange-950/30 border border-orange-200 dark:border-orange-800/40' : isMeio ? 'bg-emerald-50 dark:bg-emerald-950/30 border border-emerald-200 dark:border-emerald-800/40' : 'bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700' %>">
              <div class="flex justify-between items-center mb-3">
                <span class="text-xs font-bold uppercase tracking-wide <%= isQuente ? 'text-orange-600 dark:text-orange-400' : isMeio ? 'text-emerald-700 dark:text-emerald-400' : 'text-gray-500 dark:text-gray-400' %>">
                  <%= isQuente ? '🔥 Quase esgotando!' : isMeio ? '📈 Vendendo bem' : '🎟️ Cotas vendidas' %>
                </span>
                <span class="text-2xl font-black <%= isQuente ? 'text-orange-500' : isMeio ? 'text-emerald-600 dark:text-emerald-400' : 'rifa-brand-text' %>"><%= pct %>%</span>
              </div>
              <div class="h-5 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden shadow-inner">
                <div class="h-full rounded-full transition-all duration-700 flex items-center justify-end pr-2 <%= isQuente ? 'progress-hot' : isMeio ? 'progress-mid' : 'progress-low' %>"
                     style="width:<%= Math.max(pct, 4) %>%; min-width:<%= pct > 0 ? '1.5rem' : '0' %>">
                  <% if (pct >= 15) { %>
                    <span class="text-[10px] font-black text-white/90"><%= pct %>%</span>
                  <% } %>
                </div>
              </div>
              <div class="flex justify-between text-xs mt-2 <%= isQuente ? 'text-orange-500 dark:text-orange-400' : 'text-gray-400 dark:text-gray-500' %>">
                <span><%= vendidos.toLocaleString('pt-BR') %> vendidas</span>
                <% if (isQuente) { %>
                  <span class="font-bold">⚡ só <%= rifa.stats.disponiveis.toLocaleString('pt-BR') %> restam!</span>
                <% } else { %>
                  <span><%= rifa.stats.disponiveis.toLocaleString('pt-BR') %> disponíveis</span>
                <% } %>
              </div>
            </div>

            <!-- Botões -->
            <div class="mt-auto flex flex-col sm:flex-row gap-2.5">
              <button type="button"
                class="public-btn-primary flex-1 py-3.5 px-4 text-center rounded-xl font-bold text-sm sm:text-base"
                data-abrir-modal
                data-rifa-id="<%= rifa.id %>"
                data-rifa-titulo="<%= rifa.titulo.replace(/"/g, '&quot;') %>"
                data-valor-cota="<%= rifa.valorCota %>"
                data-disponiveis="<%= rifa.stats.disponiveis %>"
                data-faixas="<%= encodeURIComponent(JSON.stringify(rifa.faixasDesconto || [])) %>">
                🎟️ Participar agora
              </button>

              <a href="<%= tenantBase %>/rifas/<%= rifa.id %>"
                class="py-3.5 px-4 text-center text-sm font-semibold rounded-xl border-2 border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-200 hover:border-gray-400 dark:hover:border-gray-500 transition flex items-center justify-center gap-1.5 bg-transparent">
                Ver detalhes
              </a>
            </div>
          </div>

        </article>

      <% }); %>

    </div>

    <% if (page < paginas) { %>
      <div id="load-more" class="text-center py-10">
        <div class="inline-flex items-center gap-2 text-gray-400 text-sm">
          <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
          Carregando mais sorteios...
        </div>
      </div>
    <% } %>

  <% } %>

</div>

<!-- ══ MODAL COMPRA RÁPIDA ════════════════════════════════════════ -->
<div id="modal-participar" class="fixed inset-0 z-50 hidden public-modal-backdrop flex items-end sm:items-center justify-center p-0 sm:p-4" role="dialog" aria-modal="true">
  <div class="bg-white dark:bg-slate-900 w-full sm:max-w-lg modal-sheet overflow-y-auto rounded-t-2xl sm:rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 pb-safe">
    <div class="w-12 h-1 bg-gray-300 dark:bg-gray-600 rounded-full mx-auto mt-3 sm:hidden shrink-0"></div>
    <div class="sticky top-0 bg-white dark:bg-slate-900 border-b border-gray-100 dark:border-gray-800 px-4 sm:px-6 py-4 flex items-center justify-between z-10">
      <h3 id="modal-rifa-titulo" class="font-bold text-lg text-gray-900 dark:text-white pr-4">Sorteio</h3>
      <button type="button" id="modal-fechar" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500" aria-label="Fechar">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>

    <div class="p-4 sm:p-6 space-y-5">
      <div class="compra-qtd-panel rounded-xl p-4 sm:p-5">
        <p class="text-sm font-semibold mb-1 flex items-center gap-2">
          <i data-lucide="layers" class="w-4 h-4 text-emerald-400"></i> Quantas cotas você quer?
        </p>
        <p class="text-xs text-gray-400 mb-4">Números atribuídos automaticamente.</p>

        <div class="grid grid-cols-3 gap-2 mb-4">
          <button type="button" class="btn-quick text-xs py-2.5" data-modal-add="100">+100</button>
          <button type="button" class="btn-quick text-xs py-2.5" data-modal-add="500">+500</button>
          <button type="button" class="btn-quick text-xs py-2.5" data-modal-add="1000">+1000</button>
        </div>

        <div class="flex items-center justify-center gap-3 mb-3">
          <button type="button" class="stepper-btn !w-10 !h-10 !text-xl" id="modal-qtd-menos" aria-label="Diminuir">−</button>
          <input type="number" id="modal-input-qtd" class="stepper-input !text-xl !max-w-[100px]" value="1" min="1" inputmode="numeric">
          <button type="button" class="stepper-btn !w-10 !h-10 !text-xl" id="modal-qtd-mais" aria-label="Aumentar">+</button>
        </div>

        <p class="text-center text-xs text-gray-400 mb-4">
          <span id="modal-label-disponiveis">0</span> cotas disponíveis
        </p>

        <div class="resumo-checkout space-y-2 text-sm">
          <div class="flex justify-between text-gray-400"><span>Cotas</span><span id="modal-qtd" class="text-white font-medium">1</span></div>
          <div class="flex justify-between text-gray-400"><span>Subtotal</span><span id="modal-subtotal">R$ 0,00</span></div>
          <div class="flex justify-between pt-2 border-t border-white/10 font-bold">
            <span class="text-white">Total PIX</span>
            <span id="modal-valor-total" class="text-emerald-400 text-lg">R$ 0,00</span>
          </div>
        </div>
      </div>

      <div class="space-y-3">
        <div>
          <label for="modal-nome" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Nome completo *</label>
          <input type="text" id="modal-nome" placeholder="Seu nome" class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-4 py-3 bg-white dark:bg-slate-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/30">
        </div>
        <div>
          <label for="modal-cpf" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">CPF *</label>
          <input type="text" id="modal-cpf" placeholder="000.000.000-00" inputmode="numeric" maxlength="14" class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-4 py-3 bg-white dark:bg-slate-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/30">
        </div>
        <div>
          <label for="modal-telefone" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">WhatsApp *</label>
          <input type="tel" id="modal-telefone" placeholder="(11) 99999-9999" inputmode="numeric" maxlength="15" class="w-full border border-gray-300 dark:border-gray-600 rounded-xl px-4 py-3 bg-white dark:bg-slate-800 text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500/30">
        </div>
      </div>

      <p id="modal-aviso-compra-minima" class="hidden text-center text-xs text-amber-400 mb-2"></p>
      <button type="button" id="modal-pagar-pix" class="public-btn-primary w-full py-4 text-base flex items-center justify-center gap-2">
        <i data-lucide="qr-code" class="w-5 h-5"></i> Pagar via PIX
      </button>

      <a id="modal-ver-detalhe" href="#" class="block w-full py-3 text-sm text-center text-blue-800 dark:text-blue-300 font-medium hover:underline">
        Ver detalhes do sorteio →
      </a>
    </div>
  </div>
</div>

<script>
  const PUBLIC_API_BASE    = '<%= tenantBase %>/api';
  const PUBLIC_TENANT_BASE = '<%= tenantBase %>';
  window.__pendingScripts = window.__pendingScripts || [];
  window.__pendingScripts.push('/js/public-index.js');
</script>

<%- include('../partials/footer', { tenantPublic: true }) %>
