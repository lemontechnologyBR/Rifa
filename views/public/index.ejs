<%- include('../partials/header') %>

<style>
/* ═══════════════════════════════════════════════
   STORE PÚBLICA — ESTILO IMPÉRIO PRÊMIOS
═══════════════════════════════════════════════ */
.imp-store {
  background: #12121f;
  min-height: 100vh;
  color: #fff;
}
.imp-store .glass-nav,
body .glass-nav {
  background: rgba(18,18,31,.97) !important;
  border-color: rgba(255,255,255,.07) !important;
}

/* Card destaque (primeiro sorteio) */
.imp-featured-card {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 16px;
  overflow: hidden;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
}
.imp-featured-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(0,0,0,.5);
}

/* Cards menores (lista) */
.imp-list-card {
  background: #1a1a2e;
  border: 1px solid rgba(255,255,255,.07);
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  align-items: stretch;
  transition: border-color .2s, transform .2s;
  cursor: pointer;
}
.imp-list-card:hover {
  border-color: rgba(34,197,94,.4);
  transform: translateY(-2px);
}

/* Progress bar */
.imp-progress-wrap {
  background: rgba(255,255,255,.08);
  border-radius: 9999px;
  height: 8px;
  overflow: hidden;
}
.imp-progress-bar {
  height: 100%;
  border-radius: 9999px;
  background: linear-gradient(90deg, #22c55e, #16a34a);
  transition: width .6s ease;
}

/* Badge */
.imp-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 10px;
  border-radius: 9999px;
  font-size: 10px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.imp-badge-green  { background: rgba(34,197,94,.2);  color: #22c55e; border:1px solid rgba(34,197,94,.3); }
.imp-badge-red    { background: rgba(239,68,68,.2);   color: #f87171; border:1px solid rgba(239,68,68,.3); }
.imp-badge-orange { background: rgba(249,115,22,.2);  color: #fb923c; border:1px solid rgba(249,115,22,.3); }

/* Botão participar */
.imp-btn-primary {
  background: #22c55e;
  color: #000;
  font-weight: 900;
  border-radius: 10px;
  padding: 12px 20px;
  font-size: 14px;
  border: none;
  cursor: pointer;
  transition: background .15s, transform .15s;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.imp-btn-primary:hover { background: #16a34a; transform: translateY(-1px); }

.imp-btn-outline {
  background: transparent;
  color: #9ca3af;
  font-weight: 700;
  border-radius: 10px;
  padding: 11px 20px;
  font-size: 13px;
  border: 1px solid rgba(255,255,255,.15);
  cursor: pointer;
  transition: border-color .15s, color .15s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  text-decoration: none;
}
.imp-btn-outline:hover { border-color: rgba(255,255,255,.4); color: #fff; }

@keyframes imp-slide-up {
  from { opacity:0; transform:translateY(18px); }
  to   { opacity:1; transform:translateY(0); }
}
.imp-anim { animation: imp-slide-up .4s ease forwards; opacity:0; }
.imp-anim:nth-child(1){animation-delay:.05s}
.imp-anim:nth-child(2){animation-delay:.12s}
.imp-anim:nth-child(3){animation-delay:.19s}
.imp-anim:nth-child(4){animation-delay:.26s}
.imp-anim:nth-child(5){animation-delay:.33s}
.imp-anim:nth-child(6){animation-delay:.40s}
</style>

<%
  const corPrimaria = tenant.corPrimaria || '#22c55e';
  const nomeExibido = typeof organizadorNome !== 'undefined' ? organizadorNome : tenant.nome;
%>

<div class="imp-store">
  <div class="max-w-2xl mx-auto px-3 sm:px-4 py-6 pb-24">

    <!-- Descrição da loja -->
    <% if (tenant.descricao) { %>
    <p style="color:#6b7280;font-size:13px;text-align:center;margin-bottom:20px;"><%= tenant.descricao %></p>
    <% } %>

    <!-- Cabeçalho da seção -->
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:20px;">
      <span style="color:#22c55e;font-size:18px;">⚡</span>
      <h2 style="font-size:18px;font-weight:900;color:#fff;margin:0;">Campanhas</h2>
      <span style="color:#6b7280;font-size:13px;font-weight:500;">Escolha sua sorte</span>
    </div>

    <% if (rifas.length === 0) { %>
      <div style="text-align:center;padding:80px 20px;">
        <div style="font-size:4rem;margin-bottom:16px;">🎯</div>
        <p style="font-size:18px;font-weight:800;color:#fff;margin-bottom:8px;">Nenhum sorteio ativo agora</p>
        <p style="color:#6b7280;font-size:14px;">Volte em breve — novidades chegando!</p>
      </div>
    <% } else { %>

    <div id="rifas-container"
         data-page="<%= page %>" data-paginas="<%= paginas %>"
         data-slug="<%= tenant.slug %>"
         data-organizador-nome="<%= nomeExibido.replace(/"/g, '&quot;') %>">

      <% rifas.forEach(function(rifa, idx) {
        const vendidos  = rifa.stats.vendidos || (rifa.stats.total - rifa.stats.disponiveis);
        const pct       = rifa.stats.total > 0 ? Math.round((vendidos / rifa.stats.total) * 100) : 0;
        const isQuente  = pct >= 75;
        const diasRestantes = Math.max(0, Math.ceil((new Date(rifa.dataSorteio) - new Date()) / (1000*60*60*24)));
        const urgente   = diasRestantes <= 3;
        const dataFmt   = new Date(rifa.dataSorteio).toLocaleDateString('pt-BR', {weekday:'long',day:'2-digit',month:'2-digit',year:'numeric'});
      %>

      <%
        const premioLabel = rifa.premios && rifa.premios.length ? rifa.premios[0].titulo.toUpperCase() : rifa.titulo.toUpperCase();
        const precoFmt = 'R$ ' + rifa.valorCota.toFixed(2).replace('.', ',');
      %>

      <% if (idx === 0) { %>
        <!-- ══ CARD DESTAQUE (primeiro) ══ -->
        <a href="<%= tenantBase %>/rifas/<%= rifa.id %>" class="imp-featured-card imp-anim" style="margin-bottom:12px;display:block;text-decoration:none;">

          <!-- Imagem grande com badge prêmio sobreposto -->
          <div style="position:relative;overflow:hidden;">
            <% if (rifa.imagemUrl) { %>
              <img src="<%= rifa.imagemUrl %>" alt="<%= rifa.titulo %>"
                   style="width:100%;height:280px;object-fit:cover;display:block;">
            <% } else { %>
              <div style="width:100%;height:280px;background:linear-gradient(135deg,#1a1a2e,#0d0d1a);display:flex;align-items:center;justify-content:center;font-size:5rem;">🏆</div>
            <% } %>
            <!-- Badge prêmio no canto superior esquerdo -->
            <div style="position:absolute;top:10px;left:10px;background:rgba(34,197,94,.9);backdrop-filter:blur(4px);color:#000;font-size:10px;font-weight:900;padding:4px 10px;border-radius:6px;letter-spacing:.5px;max-width:70%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
              <%= premioLabel %>
            </div>
          </div>

          <!-- Info abaixo da imagem -->
          <div style="padding:12px 14px 14px;">
            <h3 style="font-size:16px;font-weight:900;color:#fff;margin:0 0 2px;line-height:1.3;"><%= rifa.titulo %></h3>
            <p style="font-size:11px;color:#6b7280;margin:0 0 10px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;">PARTICIPE E CONCORRA!</p>

            <!-- Barra de progresso -->
            <div style="background:rgba(255,255,255,.08);border-radius:9999px;height:6px;overflow:hidden;margin-bottom:4px;">
              <div style="height:100%;border-radius:9999px;background:linear-gradient(90deg,#22c55e,#16a34a);width:<%= pct %>%;transition:width .6s;"></div>
            </div>
            <div style="display:flex;justify-content:space-between;margin-bottom:10px;">
              <span style="font-size:11px;color:#22c55e;font-weight:700;"><%= pct %>% vendido</span>
              <span style="font-size:11px;color:#6b7280;"><%= rifa.stats.disponiveis %> disponíveis</span>
            </div>

            <!-- Preço + badges -->
            <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
              <div>
                <span style="font-size:10px;color:#6b7280;font-weight:700;text-transform:uppercase;">Por apenas</span>
                <div style="font-size:18px;font-weight:900;color:#22c55e;line-height:1.1;"><%= precoFmt %></div>
              </div>
              <div style="display:flex;gap:5px;flex-wrap:wrap;justify-content:flex-end;">
                <span class="imp-status-badge imp-badge-green">● ATIVA</span>
                <% if (isQuente) { %><span class="imp-status-badge imp-badge-orange">🔥 Esgotando</span><% } %>
                <% if (urgente) { %><span class="imp-status-badge imp-badge-red">⏰ <%= diasRestantes === 0 ? 'Hoje!' : diasRestantes + 'd' %></span><% } %>
              </div>
            </div>
          </div>
        </a>

      <% } else { %>
        <!-- ══ CARD LISTA (demais) ══ -->
        <a href="<%= tenantBase %>/rifas/<%= rifa.id %>" class="imp-list-card imp-anim" style="margin-bottom:10px;text-decoration:none;">

          <!-- Thumbnail -->
          <div style="width:100px;height:100px;flex-shrink:0;overflow:hidden;position:relative;">
            <% if (rifa.imagemUrl) { %>
              <img src="<%= rifa.imagemUrl %>" alt="<%= rifa.titulo %>"
                   style="width:100%;height:100%;object-fit:cover;display:block;">
            <% } else { %>
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#1f2a1f,#0d1a0d);display:flex;align-items:center;justify-content:center;font-size:2rem;">🏆</div>
            <% } %>
          </div>

          <!-- Info -->
          <div style="flex:1;padding:10px 12px;display:flex;flex-direction:column;justify-content:space-between;min-width:0;gap:4px;">
            <!-- Título + badges -->
            <div>
              <div style="display:flex;align-items:center;gap:5px;margin-bottom:3px;">
                <span class="imp-status-badge imp-badge-green" style="font-size:9px;padding:2px 6px;">● ATIVA</span>
                <% if (urgente) { %><span class="imp-status-badge imp-badge-red" style="font-size:9px;padding:2px 6px;">⏰ <%= diasRestantes === 0 ? 'Hoje!' : diasRestantes + 'd' %></span><% } %>
              </div>
              <h3 style="font-size:13px;font-weight:800;color:#fff;margin:0;overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.3;"><%= rifa.titulo %></h3>
            </div>

            <!-- Barra de progresso compacta -->
            <div>
              <div style="background:rgba(255,255,255,.08);border-radius:9999px;height:4px;overflow:hidden;margin-bottom:3px;">
                <div style="height:100%;border-radius:9999px;background:linear-gradient(90deg,#22c55e,#16a34a);width:<%= pct %>%;"></div>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <span style="font-size:10px;color:#6b7280;"><%= pct %>% vendido</span>
                <span style="font-size:12px;font-weight:900;color:#22c55e;">Por apenas <%= precoFmt %></span>
              </div>
            </div>
          </div>
        </a>

      <% } %>
      <% }); %>

    </div>

    <% if (page < paginas) { %>
      <div id="load-more" style="text-align:center;padding:32px 0;">
        <div style="display:inline-flex;align-items:center;gap:8px;color:#6b7280;font-size:13px;">
          <svg style="animation:spin 1s linear infinite;width:16px;height:16px;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none" opacity=".25"/><path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" opacity=".75"/></svg>
          Carregando mais...
        </div>
      </div>
    <% } %>

    <% } %>

    <!-- ══ ENCERRADAS ══════════════════════════════════════════ -->
    <% if (typeof rifasEncerradas !== 'undefined' && rifasEncerradas.length > 0) { %>
    <div style="margin-top:32px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <span style="font-size:16px;">🏁</span>
          <h2 style="font-size:16px;font-weight:900;color:#fff;margin:0;">Encerradas</h2>
          <span style="font-size:12px;color:#6b7280;">concluídas</span>
        </div>
        <a href="<%= tenantBase %>/encerradas" style="font-size:12px;color:#22c55e;font-weight:700;text-decoration:none;">Ver todas →</a>
      </div>

      <% rifasEncerradas.forEach(function(rifa) { %>
      <a href="<%= tenantBase %>/rifas/<%= rifa.id %>" style="display:flex;align-items:stretch;background:#1a1a2e;border:1px solid rgba(255,255,255,.07);border-radius:12px;overflow:hidden;margin-bottom:8px;text-decoration:none;transition:border-color .15s;" onmouseover="this.style.borderColor='rgba(255,255,255,.2)'" onmouseout="this.style.borderColor='rgba(255,255,255,.07)'">
        <!-- Thumb -->
        <div style="width:90px;height:76px;flex-shrink:0;overflow:hidden;">
          <% if (rifa.imagemUrl) { %>
            <img src="<%= rifa.imagemUrl %>" alt="<%= rifa.titulo %>" style="width:100%;height:100%;object-fit:cover;display:block;filter:grayscale(30%);">
          <% } else { %>
            <div style="width:100%;height:100%;background:#111827;display:flex;align-items:center;justify-content:center;font-size:1.8rem;">🏆</div>
          <% } %>
        </div>
        <!-- Info -->
        <div style="flex:1;padding:10px 14px;display:flex;flex-direction:column;justify-content:center;min-width:0;">
          <h3 style="font-size:13px;font-weight:800;color:#9ca3af;margin:0 0 3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= rifa.titulo %></h3>
          <p style="font-size:11px;color:#6b7280;margin:0 0 6px;"><%= new Date(rifa.dataSorteio).toLocaleDateString('pt-BR') %></p>
          <% if (rifa.ganhadorNome) { %>
            <span style="font-size:11px;color:#22c55e;font-weight:700;">🏆 Ganhador: <%= rifa.ganhadorNome %></span>
          <% } %>
          <span style="display:inline-block;background:rgba(107,114,128,.15);border:1px solid rgba(107,114,128,.2);color:#6b7280;padding:2px 8px;border-radius:9999px;font-size:10px;font-weight:800;margin-top:4px;width:fit-content;">Concluído</span>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>

    <!-- ══ GANHADORES ══════════════════════════════════════════ -->
    <%
      const ganhadores = (typeof rifasEncerradas !== 'undefined' ? rifasEncerradas : [])
        .filter(function(r){ return r.ganhadorNome; })
        .map(function(r){ return { nome: r.ganhadorNome, titulo: r.titulo, numero: r.numeroSorteado, data: r.updatedAt || r.dataSorteio }; })
        .slice(0, 1);
    %>
    <% if (ganhadores.length > 0) { %>
    <div style="margin-top:32px;">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
        <span style="font-size:16px;">🎉</span>
        <h2 style="font-size:16px;font-weight:900;color:#fff;margin:0;">Ganhadores</h2>
        <span style="font-size:12px;color:#6b7280;">sortudos</span>
      </div>

      <% ganhadores.forEach(function(g) { %>
      <div style="display:flex;align-items:center;gap:12px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.05);">
        <!-- Avatar -->
        <div style="width:46px;height:46px;border-radius:50%;background:#1e2535;border:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <i data-lucide="user" style="width:22px;height:22px;color:#6b7280;"></i>
        </div>
        <!-- Info -->
        <div style="flex:1;min-width:0;">
          <div style="font-weight:800;color:#fff;font-size:14px;margin-bottom:2px;"><%= g.nome %> ***</div>
          <div style="font-size:12px;color:#9ca3af;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:4px;"><%= g.titulo %></div>
          <% if (g.numero) { %>
            <div style="font-size:11px;color:#22c55e;font-weight:700;">Número da sorte: <strong><%= g.numero %></strong></div>
          <% } %>
          <div style="font-size:11px;color:#6b7280;margin-top:2px;">Data: <strong style="color:#9ca3af;"><%= new Date(g.data).toLocaleDateString('pt-BR') %></strong></div>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>

  </div>
</div>

<!-- ══ MODAL COMPRA RÁPIDA ══════════════════════════════════════════ -->
<div id="modal-participar" class="fixed inset-0 z-50 hidden flex items-end sm:items-center justify-center p-0 sm:p-4" style="background:rgba(0,0,0,.75);" role="dialog" aria-modal="true">
  <div style="background:#1a1a2e;border:1px solid rgba(255,255,255,.1);color:#fff;width:100%;max-width:480px;border-radius:20px 20px 0 0;overflow-y:auto;max-height:92vh;" class="sm:rounded-2xl pb-safe">
    <div style="width:48px;height:4px;background:rgba(255,255,255,.2);border-radius:9999px;margin:12px auto 0;" class="sm:hidden"></div>
    <!-- Header -->
    <div style="padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:#1a1a2e;z-index:10;">
      <h3 id="modal-rifa-titulo" style="font-weight:800;font-size:16px;color:#fff;margin:0;padding-right:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">Sorteio</h3>
      <button type="button" id="modal-fechar" style="background:rgba(255,255,255,.08);border:none;border-radius:8px;padding:8px;cursor:pointer;color:#9ca3af;" aria-label="Fechar">
        <i data-lucide="x" class="w-5 h-5"></i>
      </button>
    </div>

    <div style="padding:20px;">
      <!-- Qtd -->
      <div style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:18px;margin-bottom:16px;">
        <p style="font-size:13px;font-weight:700;color:#d1d5db;margin:0 0 4px;">Quantas cotas você quer?</p>
        <p style="font-size:11px;color:#6b7280;margin:0 0 14px;">Números atribuídos automaticamente.</p>

        <!-- Atalhos -->
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px;">
          <button type="button" class="btn-quick text-xs py-2.5" data-modal-add="100" style="background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:#22c55e;border-radius:8px;font-weight:800;cursor:pointer;">+100</button>
          <button type="button" class="btn-quick text-xs py-2.5" data-modal-add="500" style="background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:#22c55e;border-radius:8px;font-weight:800;cursor:pointer;">+500</button>
          <button type="button" class="btn-quick text-xs py-2.5" data-modal-add="1000" style="background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:#22c55e;border-radius:8px;font-weight:800;cursor:pointer;">+1000</button>
        </div>

        <!-- Stepper -->
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-bottom:10px;">
          <button type="button" id="modal-qtd-menos" style="width:44px;height:44px;border-radius:10px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#fff;font-size:22px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;" aria-label="Diminuir">−</button>
          <input type="number" id="modal-input-qtd" value="1" min="1" inputmode="numeric"
            style="width:90px;text-align:center;font-size:22px;font-weight:900;background:#111827;border:1px solid rgba(255,255,255,.15);border-radius:10px;color:#fff;padding:8px;">
          <button type="button" id="modal-qtd-mais" style="width:44px;height:44px;border-radius:10px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#fff;font-size:22px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;" aria-label="Aumentar">+</button>
        </div>

        <p style="text-align:center;font-size:11px;color:#6b7280;margin:0 0 14px;">
          <span id="modal-label-disponiveis">0</span> cotas disponíveis
        </p>

        <!-- Resumo -->
        <div style="border-top:1px solid rgba(255,255,255,.08);padding-top:12px;display:flex;flex-direction:column;gap:6px;">
          <div style="display:flex;justify-content:space-between;font-size:13px;color:#9ca3af;">
            <span>Cotas</span><span id="modal-qtd" style="color:#fff;font-weight:600;">1</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:13px;color:#9ca3af;">
            <span>Subtotal</span><span id="modal-subtotal">R$ 0,00</span>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:15px;font-weight:900;padding-top:8px;border-top:1px solid rgba(255,255,255,.08);">
            <span style="color:#fff;">Total PIX</span>
            <span id="modal-valor-total" style="color:#22c55e;">R$ 0,00</span>
          </div>
        </div>
      </div>

      <!-- Dados -->
      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:16px;">
        <div>
          <label for="modal-nome" style="display:block;font-size:12px;font-weight:700;color:#9ca3af;margin-bottom:6px;">Nome completo *</label>
          <input type="text" id="modal-nome" placeholder="Seu nome"
            style="width:100%;background:#111827;border:1px solid rgba(255,255,255,.15);border-radius:10px;padding:12px 14px;color:#fff;font-size:14px;">
        </div>
        <div>
          <label for="modal-cpf" style="display:block;font-size:12px;font-weight:700;color:#9ca3af;margin-bottom:6px;">CPF *</label>
          <input type="text" id="modal-cpf" placeholder="000.000.000-00" inputmode="numeric" maxlength="14"
            style="width:100%;background:#111827;border:1px solid rgba(255,255,255,.15);border-radius:10px;padding:12px 14px;color:#fff;font-size:14px;">
        </div>
        <div>
          <label for="modal-telefone" style="display:block;font-size:12px;font-weight:700;color:#9ca3af;margin-bottom:6px;">WhatsApp *</label>
          <input type="tel" id="modal-telefone" placeholder="(11) 99999-9999" inputmode="numeric" maxlength="15"
            style="width:100%;background:#111827;border:1px solid rgba(255,255,255,.15);border-radius:10px;padding:12px 14px;color:#fff;font-size:14px;">
        </div>
      </div>

      <p id="modal-aviso-compra-minima" class="hidden" style="text-align:center;font-size:12px;color:#fbbf24;margin-bottom:10px;"></p>

      <button type="button" id="modal-pagar-pix" class="imp-btn-primary" style="font-size:15px;padding:15px;">
        <i data-lucide="qr-code" class="w-5 h-5"></i> Pagar via PIX
      </button>

      <a id="modal-ver-detalhe" href="#"
         style="display:block;width:100%;padding:11px;text-align:center;font-size:13px;color:#6b7280;font-weight:600;margin-top:8px;text-decoration:none;">
        Ver detalhes do sorteio →
      </a>
    </div>
  </div>
</div>

<!-- ══ MODAL SUCESSO / PIX ══════════════════════════════════════════ -->
<div id="modal-sucesso-index" class="fixed inset-0 z-50 hidden flex items-end sm:items-center justify-center p-0 sm:p-4" style="background:rgba(0,0,0,.8);">
  <div style="background:#1a1a2e;border:1px solid rgba(34,197,94,.25);color:#fff;width:100%;max-width:440px;border-radius:20px 20px 0 0;overflow-y:auto;max-height:92vh;" class="sm:rounded-2xl pb-safe">
    <div style="width:48px;height:4px;background:rgba(255,255,255,.15);border-radius:9999px;margin:12px auto 0;" class="sm:hidden"></div>

    <div style="padding:24px 20px;">
      <!-- Header -->
      <div style="text-align:center;margin-bottom:20px;">
        <div style="width:56px;height:56px;border-radius:50%;background:rgba(34,197,94,.15);border:2px solid rgba(34,197,94,.3);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
          <i data-lucide="check-circle" class="w-9 h-9" style="color:#22c55e;"></i>
        </div>
        <h3 style="font-size:18px;font-weight:900;color:#fff;margin:0 0 4px;">Reserva Confirmada!</h3>
        <p style="font-size:13px;color:#6b7280;margin:0;">Realize o pagamento PIX para garantir seus números</p>
      </div>

      <!-- Detalhes -->
      <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:14px;margin-bottom:16px;font-size:13px;color:#d1d5db;">
        <div style="display:inline-flex;align-items:center;gap:4px;background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:#22c55e;border-radius:9999px;padding:3px 10px;font-size:11px;font-weight:800;margin-bottom:10px;">💳 PIX</div>
        <div style="margin-bottom:4px;">Reserva <strong id="ms-id" style="color:#fff;">#</strong></div>
        <div style="margin-bottom:4px;"><strong id="ms-qtd" style="color:#fff;">0</strong> cota(s) — <span id="ms-nums" style="color:#22c55e;font-weight:700;"></span></div>
        <div style="margin-bottom:10px;">Total: <strong id="ms-total" style="color:#fff;">R$ 0,00</strong></div>
        <div style="background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.2);border-radius:10px;padding:10px;text-align:center;font-size:12px;color:#fbbf24;">
          ⏱️ Pague em até <strong>10 min</strong> — expira em <strong id="ms-timer">--:--</strong>
        </div>
      </div>

      <!-- QR -->
      <div style="text-align:center;margin-bottom:16px;">
        <p style="font-size:11px;color:#6b7280;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px;">Escaneie o QR Code</p>
        <img id="ms-qrcode" src="" alt="QR Code PIX" style="display:none;max-width:180px;width:100%;border-radius:12px;border:3px solid rgba(255,255,255,.1);margin:0 auto 12px;">
        <div style="display:flex;align-items:center;gap:10px;margin:12px 0;">
          <div style="flex:1;height:1px;background:rgba(255,255,255,.08);"></div>
          <span style="font-size:11px;color:#6b7280;">ou</span>
          <div style="flex:1;height:1px;background:rgba(255,255,255,.08);"></div>
        </div>
        <button id="ms-copiar" type="button" class="imp-btn-primary" style="font-size:14px;">📋 Copiar código PIX</button>
        <p id="ms-status-pix" style="font-size:12px;color:#fbbf24;font-weight:700;margin-top:10px;">⏳ Aguardando pagamento PIX…</p>
      </div>

      <a id="ms-ver-comprovante" href="#" class="imp-btn-primary" style="display:flex;margin-bottom:8px;font-size:14px;">Ver Comprovante</a>
      <button id="ms-fechar" type="button" style="width:100%;background:transparent;border:none;color:#6b7280;font-size:13px;padding:8px;cursor:pointer;">Fechar</button>
    </div>
  </div>
</div>

