<% const simFull = typeof full !== 'undefined' && full; %>
<div class="admin-sim-panel<%= simFull ? ' admin-sim-panel-full' : '' %>">
  <div class="admin-sim-head">
    <i data-lucide="trending-up" class="w-4 h-4 text-emerald-600"></i>
    <span><%= simFull ? 'Projeção se vender tudo' : 'Simulação por cota' %></span>
  </div>

  <div class="grid grid-cols-2 gap-3 mb-3">
    <div class="admin-sim-card admin-sim-card-you">
      <p class="admin-sim-card-label">Você recebe / cota</p>
      <p class="admin-sim-card-value">R$ <span x-text="fmt(valorCota * 0.95)"></span></p>
      <p class="admin-sim-card-sub">95% do valor da cota</p>
    </div>
    <div class="admin-sim-card">
      <p class="admin-sim-card-label">Comprador paga / cota</p>
      <p class="admin-sim-card-value">R$ <span x-text="fmt(compradorPaga)"></span></p>
      <p class="admin-sim-card-sub">Valor exato, sem acréscimo</p>
    </div>
  </div>

  <% if (simFull) { %>
  <div class="admin-sim-total space-y-2">
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Cotas</span>
      <span class="font-semibold" x-text="fmtInt(totalCotas)"></span>
    </div>
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Seu faturamento (95%)</span>
      <span class="font-bold text-emerald-600">R$ <span x-text="fmt(faturamentoTotal)"></span></span>
    </div>
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Volume pago pelos compradores</span>
      <span class="font-semibold">R$ <span x-text="fmt(volumeCompradores)"></span></span>
    </div>
    <div class="flex justify-between text-xs text-gray-400 pt-1 border-t border-emerald-100 dark:border-emerald-900">
      <span>Comissão plataforma (5% do arrecadado)</span>
      <span>R$ <span x-text="fmt(taxaPlataformaTotal)"></span></span>
    </div>
  </div>
  <% } else { %>
  <div class="admin-sim-preview">
    <p class="text-xs text-gray-500 mb-2">Se vender <strong x-text="fmtInt(totalCotas)"></strong> cotas:</p>
    <div class="flex justify-between items-end gap-2">
      <div>
        <p class="text-[10px] uppercase tracking-wide text-emerald-600 font-bold">Seu lucro</p>
        <p class="text-xl font-extrabold text-emerald-700 dark:text-emerald-400">R$ <span x-text="fmt(faturamentoTotal)"></span></p>
      </div>
      <div class="text-right text-xs text-gray-400">
        <p>Compradores pagam</p>
        <p class="font-semibold text-gray-600 dark:text-gray-300">R$ <span x-text="fmt(volumeCompradores)"></span></p>
      </div>
    </div>
    <div class="admin-sim-bar mt-3">
      <div class="admin-sim-bar-you" style="width:95%"></div>
      <div class="admin-sim-bar-fee" style="width:5%"></div>
    </div>
    <p class="text-[10px] text-gray-400 mt-1.5">95% seu · 5% plataforma</p>
  </div>
  <% } %>
</div>
