<% const pgTitle = typeof pageTitle !== 'undefined' ? pageTitle : 'Painel'; %>
<div class="admin-app" x-data="{ sidebarOpen: false }">
  <div x-show="sidebarOpen" x-cloak @click="sidebarOpen = false" class="admin-sidebar-backdrop lg:hidden"></div>

  <aside class="admin-sidebar" :class="{ 'is-open': sidebarOpen }">
    <div class="admin-sidebar-brand">
      <a href="<%= adminBase %>" class="admin-sidebar-logo-link">
        <%- include('../../partials/vourifar-logo', { logoClass: 'h-8 w-[8.5rem] max-w-none', logoTheme: 'light' }) %>
      </a>
      <p class="admin-sidebar-store"><%= tenant.nome %></p>
      <a href="<%= tenantBase %>" target="_blank" class="admin-sidebar-store-link">
        <i data-lucide="globe" class="w-3 h-3"></i>
        <%= tenantBase %>
        <i data-lucide="external-link" class="w-3 h-3 opacity-60"></i>
      </a>
    </div>

    <nav class="admin-sidebar-nav">
      <p class="admin-sidebar-label">Menu</p>
      <a href="<%= adminBase %>" class="admin-sidebar-link <%= typeof active !== 'undefined' && active === 'dashboard' ? 'is-active' : '' %>">
        <i data-lucide="layout-dashboard" class="w-[18px] h-[18px]"></i>
        Visão geral
      </a>
      <a href="<%= adminBase %>/rifas" class="admin-sidebar-link <%= typeof active !== 'undefined' && active === 'rifas' ? 'is-active' : '' %>">
        <i data-lucide="ticket" class="w-[18px] h-[18px]"></i>
        Rifas
      </a>
      <a href="<%= adminBase %>/carteira" class="admin-sidebar-link <%= typeof active !== 'undefined' && active === 'carteira' ? 'is-active' : '' %>">
        <i data-lucide="wallet" class="w-[18px] h-[18px]"></i>
        Carteira
      </a>
      <a href="<%= adminBase %>/config" class="admin-sidebar-link <%= typeof active !== 'undefined' && active === 'config' ? 'is-active' : '' %>">
        <i data-lucide="user" class="w-[18px] h-[18px]"></i>
        Minha conta
      </a>
      <a href="<%= adminBase %>/logs" class="admin-sidebar-link <%= typeof active !== 'undefined' && active === 'logs' ? 'is-active' : '' %>">
        <i data-lucide="scroll-text" class="w-[18px] h-[18px]"></i>
        Atividades
      </a>
    </nav>

    <div class="admin-sidebar-footer">
      <% if (typeof adminUsuario !== 'undefined' && adminUsuario) { %>
        <div class="admin-sidebar-user">
          <div class="admin-sidebar-avatar"><%= adminUsuario.charAt(0).toUpperCase() %></div>
          <div class="min-w-0">
            <p class="admin-sidebar-user-name"><%= adminUsuario %></p>
            <p class="admin-sidebar-user-role">Organizador</p>
          </div>
        </div>
      <% } %>
      <div class="admin-sidebar-actions">
        <button type="button" onclick="toggleAdminTheme()" class="admin-sidebar-icon-btn" title="Alternar tema">
          <span class="dark:hidden"><i data-lucide="moon" class="w-4 h-4"></i></span>
          <span class="hidden dark:inline"><i data-lucide="sun" class="w-4 h-4"></i></span>
        </button>
        <a href="<%= adminBase %>/logout" class="admin-sidebar-icon-btn admin-sidebar-icon-btn-danger" title="Sair">
          <i data-lucide="log-out" class="w-4 h-4"></i>
        </a>
      </div>
    </div>
  </aside>

  <div class="admin-workspace">
    <header class="admin-topbar">
      <div class="admin-topbar-left">
        <button type="button" @click="sidebarOpen = true" class="admin-topbar-menu lg:hidden" aria-label="Menu">
          <i data-lucide="menu" class="w-5 h-5"></i>
        </button>
        <div>
          <h1 class="admin-topbar-title"><%= pgTitle %></h1>
          <% if (typeof pageSubtitle !== 'undefined' && pageSubtitle) { %>
            <p class="admin-topbar-subtitle"><%= pageSubtitle %></p>
          <% } %>
        </div>
      </div>
      <div class="admin-topbar-actions">
        <a href="<%= tenantBase %>" target="_blank" class="admin-btn-secondary hidden sm:inline-flex">
          <i data-lucide="external-link" class="w-4 h-4"></i>
          Ver rifas
        </a>
        <% if (typeof openModal !== 'undefined') { %>
          <button type="button" @click="$dispatch('open-nova-rifa')" class="admin-btn-primary inline-flex items-center gap-2 px-4 py-2.5 text-sm">
            <i data-lucide="plus" class="w-4 h-4"></i>
            <span class="hidden sm:inline">Nova rifa</span>
            <span class="sm:hidden">Nova</span>
          </button>
        <% } else { %>
          <a href="<%= adminBase %>/rifas?nova=1" class="admin-btn-primary inline-flex items-center gap-2 px-4 py-2.5 text-sm">
            <i data-lucide="plus" class="w-4 h-4"></i>
            <span class="hidden sm:inline">Nova rifa</span>
          </a>
        <% } %>
      </div>
    </header>

    <div class="admin-page">
