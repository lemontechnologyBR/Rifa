<!-- Modal nova rifa — onboarding -->
<div x-show="modalNovaRifa" x-cloak class="fixed inset-0 z-[60] flex items-center justify-center p-4"
  @keydown.escape.window="modalNovaRifa = false">
  <div class="admin-modal-backdrop absolute inset-0" @click="modalNovaRifa = false"></div>
  <div class="relative bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-xl max-h-[92vh] overflow-hidden border border-gray-200 dark:border-gray-700 flex flex-col"
    x-transition @click.outside="">

    <div class="shrink-0 bg-white dark:bg-slate-900 border-b border-gray-100 dark:border-gray-800 px-6 py-4">
      <div class="flex items-center justify-between mb-4">
        <h3 class="font-bold text-lg flex items-center gap-2">
          <i data-lucide="plus-circle" class="w-5 h-5 text-emerald-600"></i>
          <span x-text="wizardStep === 1 ? 'O prêmio' : wizardStep === 2 ? 'Sorteio' : 'Revisão'"></span>
        </h3>
        <button type="button" @click="modalNovaRifa = false" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>

      <div class="admin-wizard-steps">
        <template x-for="(label, i) in ['Prêmio', 'Sorteio', 'Confirmar']" :key="i">
          <div class="admin-wizard-step" :class="{ 'is-done': wizardStep > i + 1, 'is-active': wizardStep === i + 1 }">
            <span class="admin-wizard-step-num" x-text="wizardStep > i + 1 ? '✓' : i + 1"></span>
            <span class="admin-wizard-step-label" x-text="label"></span>
          </div>
        </template>
      </div>
    </div>

    <form method="POST" action="<%= adminBase %>/rifas/nova" class="flex flex-col flex-1 min-h-0 overflow-y-auto">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="premio_titulo" value="Prêmio principal">
      <input type="hidden" name="modalidade" :value="modalidade">

      <div x-show="wizardStep === 1" class="p-6 space-y-4">
        <p class="text-sm text-gray-500 dark:text-gray-400">Defina o prêmio e quantas cotas serão vendidas.</p>
        <div>
          <label class="admin-label">Nome do sorteio *</label>
          <input type="text" name="titulo" required x-model="titulo" placeholder="Ex: iPhone 15 Pro Max 256GB" class="admin-input">
        </div>
        <%- include('rifa-imagem', { adminBase, imagemUrl: '' }) %>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="admin-label">Valor da cota (R$) *</label>
            <input type="number" name="valor_cota" step="0.01" min="0.01" required x-model.number="valorCota" class="admin-input">
          </div>
          <div>
            <label class="admin-label">Total de cotas *</label>
            <input type="number" name="total_numeros" required min="1" max="10000" x-model.number="totalCotas" class="admin-input">
          </div>
        </div>
        <%- include('rifa-simulacao') %>

        <!-- Modalidade -->
        <div>
          <label class="admin-label">Modalidade de participação</label>
          <div class="grid grid-cols-2 gap-3 mt-1">
            <label class="flex items-start gap-3 border rounded-xl p-3 cursor-pointer transition"
              :class="modalidade === 'cotas' ? 'border-emerald-500 bg-emerald-50 dark:bg-emerald-900/20' : 'border-gray-200 dark:border-gray-700'">
              <input type="radio" x-model="modalidade" value="cotas" class="mt-0.5 accent-emerald-500">
              <div>
                <p class="font-semibold text-sm">Por Cotas</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Números atribuídos aleatoriamente</p>
              </div>
            </label>
            <label class="flex items-start gap-3 border rounded-xl p-3 transition"
              :class="podeGrade ? 'cursor-pointer ' + (modalidade === 'numeros' ? 'border-emerald-500 bg-emerald-50 dark:bg-emerald-900/20' : 'border-gray-200 dark:border-gray-700') : 'opacity-40 cursor-not-allowed border-gray-200 dark:border-gray-700'"
              :title="podeGrade ? '' : 'Apenas disponível com até 100 cotas'">
              <input type="radio" x-model="modalidade" value="numeros" :disabled="!podeGrade" class="mt-0.5 accent-emerald-500">
              <div>
                <p class="font-semibold text-sm">Grade de Números</p>
                <p class="text-xs text-gray-500 dark:text-gray-400" x-text="podeGrade ? 'Participante escolhe os números' : 'Máx. 100 cotas'"></p>
              </div>
            </label>
          </div>
          <p x-show="!podeGrade && modalidade === 'numeros'" x-cloak class="text-xs text-amber-600 mt-1">
            ⚠️ Grade resetada para Cotas pois o total excede 100.
          </p>
          <!-- força reset quando ultrapassa 100 -->
          <span x-effect="if (!podeGrade && modalidade === 'numeros') modalidade = 'cotas'"></span>
        </div>
      </div>

      <div x-show="wizardStep === 2" x-cloak class="p-6 space-y-4">
        <p class="text-sm text-gray-500 dark:text-gray-400">Quando acontece o sorteio.</p>
        <div>
          <label class="admin-label">Data do sorteio *</label>
          <input type="datetime-local" name="data_sorteio" required x-model="dataSorteio" class="admin-input">
        </div>
        <%- include('recebimento-carteira-info') %>
      </div>

      <div x-show="wizardStep === 3" x-cloak class="p-6 space-y-4">
        <p class="text-sm text-gray-500 dark:text-gray-400">Confira os dados antes de publicar o sorteio.</p>
        <dl class="admin-config-dl">
          <div><dt>Nome</dt><dd x-text="titulo"></dd></div>
          <div><dt>Cota</dt><dd>R$ <span x-text="fmt(valorCota)"></span> · <span x-text="fmtInt(totalCotas)"></span> cotas</dd></div>
          <div><dt>Sorteio</dt><dd x-text="dataSorteio ? new Date(dataSorteio).toLocaleString('pt-BR') : '—'"></dd></div>
          <div><dt>Recebimento</dt><dd><% if (typeof mpSplitConfigured !== 'undefined' && mpSplitConfigured) { %><%= typeof mpConnected !== 'undefined' && mpConnected ? 'Mercado Pago — 95% automático' : 'Mercado Pago (conectar na Carteira)' %><% } else { %>Chave PIX da Carteira<% } %></dd></div>
        </dl>
        <%- include('rifa-simulacao', { full: true }) %>
      </div>

      <div class="shrink-0 border-t border-gray-100 dark:border-gray-800 px-6 py-4 flex gap-3 bg-white dark:bg-slate-900">
        <button type="button" x-show="wizardStep > 1" @click="wizardStep--" class="flex-1 py-3 rounded-xl border border-gray-200 dark:border-gray-600 font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition text-sm">
          Voltar
        </button>
        <button type="button" x-show="wizardStep < 3" @click="nextStep()" class="flex-1 admin-btn-primary py-3 text-sm">
          Continuar
        </button>
        <button type="submit" x-show="wizardStep === 3" class="flex-1 admin-btn-primary py-3 text-sm">
          <i data-lucide="rocket" class="w-4 h-4 inline-block mr-1 -mt-0.5"></i>
          Publicar sorteio
        </button>
        <button type="button" x-show="wizardStep === 1" @click="modalNovaRifa = false" class="py-3 px-4 rounded-xl border border-gray-200 dark:border-gray-600 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800">
          Cancelar
        </button>
      </div>
    </form>
  </div>
</div>
