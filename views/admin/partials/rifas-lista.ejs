<% if (rifas.length === 0) { %>
  <div class="admin-onboard">
    <div class="admin-onboard-icon">
      <i data-lucide="rocket" class="w-7 h-7"></i>
    </div>
    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-1">Comece sua primeira rifa</h3>
    <p class="text-sm text-gray-600 dark:text-gray-400 max-w-md mx-auto">Em poucos minutos suas rifas estarão no ar para receber PIX.</p>
    <button type="button" @click="openWizard()" class="admin-btn-primary inline-flex items-center gap-2 px-6 py-3 text-sm mt-4">
      <i data-lucide="plus" class="w-4 h-4"></i> Criar primeira rifa
    </button>
    <div class="admin-onboard-steps">
      <div class="admin-onboard-step">
        <span class="admin-onboard-step-num">1</span>
        <div>
          <p class="font-semibold text-sm">Configure a Carteira</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Informe sua chave PIX</p>
        </div>
      </div>
      <div class="admin-onboard-step">
        <span class="admin-onboard-step-num">2</span>
        <div>
          <p class="font-semibold text-sm">Crie a rifa</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">Nome, valor da cota e sorteio</p>
        </div>
      </div>
      <div class="admin-onboard-step">
        <span class="admin-onboard-step-num">3</span>
        <div>
          <p class="font-semibold text-sm">Receba automaticamente</p>
          <p class="text-xs text-gray-500 dark:text-gray-400">PIX confirmado pela plataforma</p>
        </div>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="space-y-3 mb-6">
    <% rifas.forEach(function(r) {
      const pct = r.stats.total > 0 ? Math.round((r.stats.vendidos / r.stats.total) * 100) : 0;
      const linkPublico = (typeof baseUrl !== 'undefined' ? baseUrl : '') + tenantBase + '/rifas/' + r.id;
      const statusClass = r.status === 'ativa' ? 'admin-badge-ativa' : r.status === 'finalizada' ? 'admin-badge-finalizada' : 'admin-badge-cancelada';
      const statusLabel = r.status === 'finalizada' ? 'encerrada' : r.status;
    %>
      <article class="admin-rifa-card">
        <div class="flex flex-col lg:flex-row lg:items-center gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-2 mb-2">
              <h3 class="font-bold text-base truncate"><%= r.titulo %></h3>
              <span class="text-[10px] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full <%= statusClass %>"><%= statusLabel %></span>
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500 dark:text-gray-400 mb-3">
              <span class="flex items-center gap-1">
                <i data-lucide="circle-dollar-sign" class="w-3.5 h-3.5 text-emerald-600"></i>
                <strong class="text-emerald-700 dark:text-emerald-400">R$ <%= r.valorCota.toFixed(2).replace('.', ',') %></strong>/cota
              </span>
              <span class="flex items-center gap-1">
                <i data-lucide="calendar" class="w-3.5 h-3.5"></i>
                <%= new Date(r.dataSorteio).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
              </span>
            </div>
            <div class="max-w-sm">
              <div class="flex justify-between text-[11px] mb-1">
                <span class="text-gray-500"><%= r.stats.vendidos %> / <%= r.stats.total %> vendidas</span>
                <span class="font-semibold text-emerald-600"><%= pct %>%</span>
              </div>
              <div class="admin-progress-track">
                <div class="admin-progress-fill" style="width: <%= pct %>%"></div>
              </div>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 lg:justify-end">
            <a href="<%= adminBase %>/rifas/<%= r.id %>/editar" class="admin-action-btn">
              <i data-lucide="pencil" class="w-3.5 h-3.5"></i> Editar rifa
            </a>
            <a href="<%= adminBase %>/rifas/<%= r.id %>/participantes" class="admin-action-btn">
              <i data-lucide="list-ordered" class="w-3.5 h-3.5"></i> Números
            </a>
            <button type="button" class="admin-action-btn btn-share" data-url="<%= linkPublico %>" data-titulo="<%= r.titulo %>">
              <i data-lucide="share-2" class="w-3.5 h-3.5"></i> Link
            </button>
            <% if (r.status === 'ativa') { %>
              <form method="POST" action="<%= adminBase %>/rifas/<%= r.id %>/sortear" class="inline"
                onsubmit="return confirm('Finalizar sorteio da rifa <%= r.titulo.replace(/'/g, "\\'") %>? Esta ação não pode ser desfeita.')">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <button type="submit" class="admin-action-btn border-amber-300 text-amber-700 dark:border-amber-700 dark:text-amber-300">
                  <i data-lucide="trophy" class="w-3.5 h-3.5"></i> Sortear
                </button>
              </form>
            <% } %>
          </div>
        </div>
      </article>
    <% }); %>
  </div>
<% } %>

<% if (paginas > 1) { %>
  <div class="flex justify-center gap-2 mb-6">
    <% for (let p = 1; p <= paginas; p++) { %>
      <a href="?page=<%= p %>"
         class="px-3 py-1.5 rounded-lg text-sm font-medium <%= p === page ? 'admin-btn-primary' : 'admin-panel-card border border-gray-200 dark:border-gray-700' %>"><%= p %></a>
    <% } %>
  </div>
<% } %>
