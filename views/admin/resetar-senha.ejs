<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Redefinir senha — <%= tenant.nome %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>:root{--brand:<%= tenant.corPrimaria %>}.btn-brand{background:<%= tenant.corPrimaria %>;color:#fff}</style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md">

  <!-- Logo / título -->
  <div class="text-center mb-6">
    <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3" style="background:<%= tenant.corPrimaria %>22;">
      <svg class="w-6 h-6" fill="none" stroke="<%= tenant.corPrimaria %>" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
    </div>
    <h1 class="text-xl font-bold text-gray-800">Redefinir senha</h1>
    <p class="text-sm text-gray-500 mt-1"><%= tenant.nome %></p>
  </div>

  <% if (erro) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-3 rounded-xl mb-5 text-sm"><%= erro %></div>
  <% } %>

  <% if (!token) { %>
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-700 p-4 rounded-xl text-sm">
      Link inválido. <a href="<%= adminBase %>/esqueci-senha" class="underline font-medium">Solicite uma nova recuperação</a>.
    </div>
  <% } else { %>
    <form method="POST" action="<%= adminBase %>/resetar-senha" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="token" value="<%= token %>">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nova senha</label>
        <input type="password" name="senha" required minlength="6" placeholder="Mínimo 6 caracteres"
          class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Confirmar nova senha</label>
        <input type="password" name="confirmar" required minlength="6" placeholder="Repita a senha"
          class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2">
      </div>

      <button type="submit" class="w-full btn-brand py-3 rounded-xl font-semibold text-sm">
        Salvar nova senha
      </button>
    </form>
  <% } %>

  <p class="text-center text-sm text-gray-500 mt-5">
    <a href="<%= adminBase %>/login" class="font-medium" style="color:<%= tenant.corPrimaria %>;">← Voltar ao login</a>
  </p>
</div>
</body>
</html>
