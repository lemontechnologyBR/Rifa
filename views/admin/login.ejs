<!DOCTYPE html>
<html lang="pt-BR">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Login — <%= tenant.nome %></title>
<script src="https://cdn.tailwindcss.com"></script>
<style>:root{--brand-from:<%= tenant.corPrimaria %>}.btn-brand{background:<%= tenant.corPrimaria %>;color:#fff}</style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md">
  <h1 class="text-2xl font-bold mb-2 text-center"><%= tenant.nome %></h1>
  <p class="text-sm text-gray-500 text-center mb-6">Painel do organizador</p>
  <% if (erro) { %><div class="bg-red-100 text-red-700 p-3 rounded-xl mb-4 text-sm"><%= erro %></div><% } %>

  <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
    <a href="<%= adminBase %>/auth/google" class="w-full flex items-center justify-center gap-3 border border-gray-300 rounded-xl py-3 mb-4 font-semibold text-gray-700 hover:bg-gray-50 transition">
      <svg class="w-5 h-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
      Entrar com Google
    </a>
    <div class="relative my-4"><div class="absolute inset-0 flex items-center"><div class="w-full border-t border-gray-200"></div></div><div class="relative flex justify-center text-xs uppercase"><span class="bg-white px-2 text-gray-400">ou</span></div></div>
  <% } %>

  <form method="POST" action="<%= adminBase %>/login" class="space-y-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="email" name="email" required placeholder="E-mail" class="w-full border rounded-xl px-4 py-2.5">
    <input type="password" name="senha" required placeholder="Senha" class="w-full border rounded-xl px-4 py-2.5">
    <button type="submit" class="w-full btn-brand py-3 rounded-xl font-semibold">Entrar com e-mail</button>
  </form>
  <p class="text-center text-sm text-gray-500 mt-4">
    <a href="<%= tenantBase %>" class="text-indigo-600">Ver sorteios online</a>
    · <a href="/acessar" class="text-indigo-600">Login central</a>
  </p>
</div>
</body></html>
