<!DOCTYPE html>
<html lang="pt-BR" class="admin-panel">
<head>
  <%- include('partials/head', { titulo, csrfToken }) %>
</head>
<body class="admin-panel">
  <%- include('partials/nav', {
    active: 'rifas',
    pageTitle: rifa && rifa.id ? 'Editar sorteio' : 'Novo sorteio',
    pageSubtitle: rifa && rifa.titulo ? rifa.titulo : 'Preencha os dados do sorteio',
    tenant, adminBase, tenantBase, adminUsuario
  }) %>

    <div class="max-w-3xl">
    <% if (erro) { %><div class="admin-alert admin-alert-error mb-4"><span><%= erro %></span></div><% } %>
    <form method="POST" action="<%= rifa && rifa.id ? adminBase+'/rifas/'+rifa.id+'/editar' : adminBase+'/rifas/nova' %>" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="admin-panel-card p-6 space-y-4">
      <div>
        <label class="text-sm font-medium text-gray-600">Título *</label>
        <input type="text" name="titulo" required value="<%= rifa ? (rifa.titulo || '') : '' %>" class="admin-input mt-1">
      </div>
      <div>
        <label class="text-sm font-medium text-gray-600">Descrição</label>
        <textarea name="descricao" rows="3" class="w-full border rounded-xl px-4 py-2 mt-1"><%= rifa ? (rifa.descricao || '') : '' %></textarea>
      </div>
      <%- include('partials/rifa-imagem', {
        adminBase,
        imagemUrl: rifa ? (rifa.imagemUrl || rifa.imagem_url || '') : ''
      }) %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="text-sm font-medium text-gray-600">Valor da cota *</label>
          <input type="number" name="valor_cota" step="0.01" min="0.01" required value="<%= rifa ? (rifa.valorCota ?? rifa.valor_cota ?? '') : '' %>" class="w-full border rounded-xl px-4 py-2 mt-1">
        </div>
        <% if (!rifa || !rifa.id) { %>
          <div>
            <label class="text-sm font-medium text-gray-600">Total de números *</label>
            <input type="number" name="total_numeros" id="input_total_numeros" required min="1" class="w-full border rounded-xl px-4 py-2 mt-1">
          </div>
        <% } else { %>
          <div>
            <label class="text-sm font-medium text-gray-600">Total de números</label>
            <input type="text" readonly value="<%= rifa.stats ? rifa.stats.total : '—' %>" class="w-full border rounded-xl px-4 py-2 mt-1 bg-gray-50 text-gray-500">
          </div>
        <% } %>
      </div>
      <div>
        <label class="text-sm font-medium text-gray-600">Data do sorteio *</label>
        <input type="datetime-local" name="data_sorteio" required
          value="<%= rifa && rifa.dataSorteio ? new Date(rifa.dataSorteio).toISOString().slice(0,16) : (rifa && rifa.data_sorteio ? rifa.data_sorteio.slice(0,16) : '') %>"
          class="w-full border rounded-xl px-4 py-2 mt-1">
      </div>
      <%
        const totalNumerosAtual = rifa ? (rifa.totalNumeros || rifa.stats?.total || 0) : 0;
        const podeGradeExistente = totalNumerosAtual > 0 && totalNumerosAtual <= 100;
        const modalidadeAtual = rifa ? (rifa.modalidade || 'cotas') : 'cotas';
      %>
      <div id="bloco_modalidade">
        <label class="text-sm font-medium text-gray-600 block mb-1">Modalidade de participação</label>
        <div class="flex gap-3">
          <label class="flex items-center gap-2 cursor-pointer flex-1 border rounded-xl px-4 py-3 transition hover:border-emerald-400 <%= modalidadeAtual === 'cotas' ? 'border-emerald-500 bg-emerald-50' : '' %>">
            <input type="radio" name="modalidade" value="cotas" class="accent-emerald-500" <%= modalidadeAtual === 'cotas' ? 'checked' : '' %>>
            <div>
              <p class="font-semibold text-sm">Por Cotas</p>
              <p class="text-xs text-gray-500">Números atribuídos aleatoriamente</p>
            </div>
          </label>
          <label id="label_numeros"
            class="flex items-center gap-2 flex-1 border rounded-xl px-4 py-3 transition <%= !rifa || !rifa.id ? '' : (podeGradeExistente ? 'cursor-pointer hover:border-emerald-400' : 'opacity-40') %> <%= modalidadeAtual === 'numeros' ? 'border-emerald-500 bg-emerald-50' : '' %>"
            title="<%= (!rifa || !rifa.id) ? 'Disponível para até 100 números' : (podeGradeExistente ? 'Participante escolhe os números' : 'Total de números excede 100') %>">
            <input type="radio" name="modalidade" value="numeros" id="radio_numeros" class="accent-emerald-500"
              <%= modalidadeAtual === 'numeros' ? 'checked' : '' %>
              <%= (!rifa || !rifa.id) ? '' : (podeGradeExistente ? '' : 'disabled') %>>
            <div>
              <p class="font-semibold text-sm">Grade de Números</p>
              <p class="text-xs text-gray-500" id="label_numeros_hint">
                <%= (!rifa || !rifa.id) ? 'Apenas para rifas com até 100 números' : (podeGradeExistente ? 'Participante escolhe os números' : 'Total excede 100 (indisponível)') %>
              </p>
            </div>
          </label>
        </div>
      </div>
      <input type="hidden" name="chave_pix" value="">
      <%- include('partials/recebimento-carteira-info', { compact: true }) %>
      <div>
        <label class="text-sm font-medium text-gray-600">Meta mínima % (opcional)</label>
        <input type="number" name="meta_minima_pct" step="0.1" min="0" max="100" value="<%= rifa ? (rifa.metaMinimaPct ?? rifa.meta_minima_pct ?? '') : '' %>" class="w-full border rounded-xl px-4 py-2 mt-1" placeholder="Ex: 70">
      </div>

      <% if (!rifa || !rifa.id) { %>
        <fieldset class="border rounded-xl p-4">
          <legend class="text-sm font-semibold px-2">Prêmios</legend>
          <input type="text" name="premio_titulo" placeholder="Prêmio principal" class="w-full border rounded-xl px-4 py-2 mb-2">
          <input type="text" name="premio_titulo" placeholder="Prêmio secundário (opcional)" class="w-full border rounded-xl px-4 py-2">
        </fieldset>
        <fieldset class="border rounded-xl p-4">
          <legend class="text-sm font-semibold px-2">Faixas de Desconto</legend>
          <div class="grid grid-cols-2 gap-2 mb-2">
            <input type="number" name="faixa_qtd" placeholder="Qtd mín" class="border rounded-xl px-4 py-2">
            <input type="number" name="faixa_valor" step="0.01" placeholder="Valor total" class="border rounded-xl px-4 py-2">
          </div>
          <div class="grid grid-cols-2 gap-2">
            <input type="number" name="faixa_qtd" placeholder="Qtd mín" class="border rounded-xl px-4 py-2">
            <input type="number" name="faixa_valor" step="0.01" placeholder="Valor total" class="border rounded-xl px-4 py-2">
          </div>
        </fieldset>
      <% } else if (rifa.premios && rifa.premios.length) { %>
        <fieldset class="border rounded-xl p-4 bg-gray-50">
          <legend class="text-sm font-semibold px-2">Prêmios cadastrados</legend>
          <ul class="space-y-2 text-sm">
            <% rifa.premios.forEach(function(p) { %>
              <li class="flex justify-between gap-2">
                <span class="font-medium"><%= p.titulo %></span>
                <span class="text-gray-500"><%= p.descricao || '—' %></span>
              </li>
            <% }); %>
          </ul>
          <p class="text-xs text-gray-400 mt-2">Prêmios não podem ser alterados após a criação.</p>
        </fieldset>
      <% } %>

      <% if (rifa && rifa.id && rifa.faixasDesconto && rifa.faixasDesconto.length) { %>
        <fieldset class="border rounded-xl p-4 bg-gray-50">
          <legend class="text-sm font-semibold px-2">Faixas de desconto</legend>
          <ul class="space-y-1 text-sm">
            <% rifa.faixasDesconto.forEach(function(f) { %>
              <li><%= f.quantidadeMin %>+ números → R$ <%= f.valorTotal.toFixed(2).replace('.', ',') %></li>
            <% }); %>
          </ul>
        </fieldset>
      <% } %>
      </div>

      <%- include('partials/rifa-aparencia') %>

      <div class="flex gap-3 pt-2">
        <% if (rifa && rifa.id) { %>
          <a href="<%= adminBase %>/rifas/<%= rifa.id %>/participantes" class="flex-1 text-center border border-gray-300 font-semibold py-3 rounded-xl hover:bg-gray-50 transition">Participantes</a>
        <% } %>
        <button type="submit" class="flex-1 admin-btn-primary py-3 text-sm"><%= rifa && rifa.id ? 'Salvar alterações' : 'Criar sorteio' %></button>
      </div>
    </form>
    </div>

  <%- include('partials/layout-end') %>
  <script>lucide.createIcons();</script>
<script>
(function() {
  const inputTotal = document.getElementById('input_total_numeros');
  const radioNumeros = document.getElementById('radio_numeros');
  const labelNumeros = document.getElementById('label_numeros');
  const labelHint = document.getElementById('label_numeros_hint');
  if (!inputTotal || !radioNumeros) return;

  function atualizarModalidade() {
    const n = parseInt(inputTotal.value, 10);
    const ok = !isNaN(n) && n >= 1 && n <= 100;
    radioNumeros.disabled = !ok;
    labelNumeros.classList.toggle('opacity-40', !ok);
    labelNumeros.classList.toggle('opacity-100', ok);
    if (ok) {
      labelHint.textContent = 'Participantes escolhem os números';
    } else {
      labelHint.textContent = 'Apenas para rifas com até 100 números';
      if (radioNumeros.checked) {
        document.querySelector('input[name="modalidade"][value="cotas"]').checked = true;
      }
    }
  }

  inputTotal.addEventListener('input', atualizarModalidade);
  atualizarModalidade();
})();
</script>
</body>
</html>
