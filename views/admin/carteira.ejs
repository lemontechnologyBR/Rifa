<!DOCTYPE html>
<html lang="pt-BR" class="admin-panel">
<head>
  <%- include('partials/head', { titulo: 'Carteira — ' + tenant.nome, csrfToken }) %>
</head>
<body class="admin-panel">
  <%- include('partials/nav', {
    active: 'carteira',
    pageTitle: 'Carteira',
    pageSubtitle: typeof usesSplit !== 'undefined' && usesSplit
      ? 'Pagamentos repassados automaticamente via Mercado Pago'
      : 'Onde você recebe os pagamentos dos sorteios',
    tenant,
    adminBase,
    tenantBase,
    adminUsuario
  }) %>

    <% if (msg) { %>
      <div class="admin-alert admin-alert-success"><i data-lucide="check-circle" class="w-4 h-4 shrink-0"></i><span><%= msg %></span></div>
    <% } %>
    <% if (erro) { %>
      <div class="admin-alert admin-alert-error"><i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i><span><%= erro %></span></div>
    <% } %>
    <% if (typeof onboarding !== 'undefined' && onboarding) { %>
      <div class="admin-alert admin-alert-success mb-4">
        <i data-lucide="party-popper" class="w-4 h-4 shrink-0"></i>
        <span><strong>Bem-vindo ao VouRifar!</strong>
          <% if (typeof mpSplitConfigured !== 'undefined' && mpSplitConfigured) { %>
            Primeiro passo: conecte sua conta Mercado Pago abaixo para começar a vender.
          <% } else { %>
            Primeiro passo: cadastre sua chave PIX abaixo para começar a vender.
          <% } %>
        </span>
      </div>
    <% } %>

    <% const splitAtivo = typeof usesSplit !== 'undefined' && usesSplit; %>
    <% const mpSplit = typeof mpSplitConfigured !== 'undefined' && mpSplitConfigured; %>
    <% const mpOk = typeof mpConnected !== 'undefined' && mpConnected; %>

    <%# Modalidade badge %>
    <div class="flex items-center gap-3 mb-5">
      <% if (mpOk) { %>
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300 border border-emerald-200 dark:border-emerald-700">
          <i data-lucide="zap" class="w-3.5 h-3.5"></i> Modalidade: Mercado Pago Direto
        </span>
        <span class="text-xs text-gray-500"><%= Math.round((organizadorPercentual||0.95)*100) %>% cai na sua conta MP na hora do pagamento</span>
      <% } else { %>
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold bg-sky-100 text-sky-800 dark:bg-sky-900/40 dark:text-sky-300 border border-sky-200 dark:border-sky-700">
          <i data-lucide="building-2" class="w-3.5 h-3.5"></i> Modalidade: Plataforma VouRifar
        </span>
        <span class="text-xs text-gray-500">Plataforma coleta e você saca quando quiser</span>
      <% } %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-6">
      <article class="admin-metric-card">
        <p class="admin-metric-label mb-1">Saldo confirmado</p>
        <p class="admin-metric-value text-emerald-600">R$ <%= resumo.saldoConfirmado.toFixed(2).replace('.', ',') %></p>
        <p class="text-xs text-gray-400 mt-1"><%= resumo.cotasConfirmadas %> cota(s) pagas</p>
      </article>
      <article class="admin-metric-card">
        <% const saldoSaque = resumo.saldoDisponivel != null ? resumo.saldoDisponivel : resumo.saldoConfirmado * 0.95; %>
        <% if (mpOk) { %>
          <p class="admin-metric-label mb-1">Sua parte (<%= Math.round((organizadorPercentual||0.95)*100) %>%)</p>
          <p class="admin-metric-value text-violet-600">R$ <%= (resumo.saldoConfirmado * (organizadorPercentual||0.95)).toFixed(2).replace('.', ',') %></p>
          <p class="text-xs text-gray-400 mt-1">Creditado direto na sua conta MP</p>
        <% } else { %>
          <p class="admin-metric-label mb-1">Disponível para saque</p>
          <p class="admin-metric-value text-violet-600">R$ <%= saldoSaque.toFixed(2).replace('.', ',') %></p>
          <p class="text-xs text-gray-400 mt-1"><%= Math.round((organizadorPercentual||0.93)*100) %>% do saldo confirmado<% if (resumo.totalSacado > 0) { %> · R$ <%= resumo.totalSacado.toFixed(2).replace('.', ',') %> já sacado<% } %></p>
        <% } %>
      </article>
      <article class="admin-metric-card">
        <p class="admin-metric-label mb-1">Aguardando PIX</p>
        <p class="admin-metric-value">R$ <%= resumo.pendente.toFixed(2).replace('.', ',') %></p>
        <p class="text-xs text-gray-400 mt-1"><%= resumo.reservasPendentes %> reserva(s)</p>
      </article>
      <article class="admin-metric-card">
        <p class="admin-metric-label mb-1">Mercado Pago</p>
        <% if (mpOk) { %>
          <p class="text-sm font-bold mt-2 text-emerald-600 flex items-center gap-1.5">
            <i data-lucide="check-circle-2" class="w-4 h-4"></i> Conectada
          </p>
          <p class="text-xs text-gray-500 mt-1 truncate" title="<%= tenant.mpNickname || tenant.mpUserId %>"><%= tenant.mpNickname || ('Conta #' + tenant.mpUserId) %></p>
        <% } else { %>
          <p class="text-sm font-bold mt-2 text-amber-600 flex items-center gap-1.5">
            <i data-lucide="circle-dashed" class="w-4 h-4"></i> Não conectada
          </p>
          <p class="text-xs text-gray-400 mt-1"><%= tenant.pixChave ? 'Usando Plataforma' : 'Configure abaixo' %></p>
        <% } %>
      </article>
    </div>

    <% if (mpOk) { %>
    <div class="admin-alert mb-4" style="background:#fef9c3;border:1px solid #fde047;color:#713f12;border-radius:12px;padding:14px 16px;display:flex;gap:10px;align-items:flex-start;">
      <i data-lucide="info" class="w-5 h-5 shrink-0 mt-0.5" style="color:#b45309;"></i>
      <div class="text-sm">
        <strong>Chave PIX obrigatória no Mercado Pago</strong><br>
        Para que seus clientes consigam pagar, sua conta Mercado Pago precisa ter uma <strong>chave PIX cadastrada</strong>.<br>
        <span class="mt-1 block">Acesse o app ou site do Mercado Pago → <strong>PIX</strong> → <strong>Minhas chaves</strong> → cadastre qualquer chave (pode ser aleatória).</span>
      </div>
    </div>
    <% } %>

    <% if (mpSplitConfigured) { %>
    <div class="admin-panel-card p-6 mb-6 border-l-4 <%= mpOk ? 'border-emerald-500' : 'border-sky-500' %>">
      <div class="admin-config-section-head mb-4">
        <div class="admin-config-section-icon blue"><i data-lucide="link" class="w-5 h-5"></i></div>
        <div>
          <h2 class="font-bold text-base">Conta Mercado Pago</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400">Conecte sua conta para receber <strong><%= Math.round((mpPercentual||0.95)*100) %>%</strong> de cada venda automaticamente — sem taxa de saque. A plataforma retém apenas <strong><%= Math.round((mpTaxa||0.05)*100) %>%</strong>.</p>
        </div>
      </div>

      <% if (mpOk) { %>
      <div class="rounded-xl border border-emerald-200 bg-emerald-50 dark:bg-emerald-950/30 dark:border-emerald-800/50 p-4 mb-4">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4">
          <div class="flex items-start gap-3 flex-1">
            <div class="w-9 h-9 rounded-lg bg-emerald-100 dark:bg-emerald-900/50 flex items-center justify-center shrink-0">
              <i data-lucide="badge-check" class="w-5 h-5 text-emerald-600"></i>
            </div>
            <div>
              <p class="font-semibold text-emerald-800 dark:text-emerald-300 text-sm">Conta conectada</p>
              <p class="text-sm text-emerald-700 dark:text-emerald-400 mt-0.5"><%= tenant.mpNickname || ('Usuário MP #' + tenant.mpUserId) %></p>
              <% if (tenant.mpConnectedAt) { %>
              <p class="text-xs text-emerald-600/80 mt-1">Desde <%= new Date(tenant.mpConnectedAt).toLocaleDateString('pt-BR') %></p>
              <% } %>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-2">Cada PIX pago cai na sua conta MP — sem saque manual, sem espera.</p>
            </div>
          </div>
          <form method="POST" action="<%= adminBase %>/carteira/mp/desconectar" onsubmit="return confirm('Desconectar Mercado Pago? Novas vendas ficarão bloqueadas até reconectar.')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-300 dark:border-gray-600 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 transition shrink-0">
              <i data-lucide="unlink" class="w-4 h-4"></i>
              Desconectar
            </button>
          </form>
        </div>
      </div>
      <% } else { %>
      <div class="rounded-xl border border-sky-200 bg-sky-50 dark:bg-sky-950/20 dark:border-sky-800/40 p-4 mb-4">
        <p class="font-semibold text-sky-800 dark:text-sky-300 text-sm mb-1">Conecte sua conta para vender</p>
        <p class="text-xs text-sky-700 dark:text-sky-400">Você será redirecionado ao Mercado Pago para autorizar o recebimento dos pagamentos na sua conta.</p>
      </div>
      <a href="<%= adminBase %>/carteira/mp/conectar" class="admin-mp-connect-btn">
        <img src="/img/mercadopago.svg?v=2" alt="Mercado Pago" class="admin-mp-connect-btn__logo">
        Conectar conta
      </a>
      <% } %>
    </div>
    <% } %>

    <% if (!mpOk) { %>
    <%
      const saldoDisp = saque ? saque.saldoDisponivel : (resumo.saldoDisponivel != null ? resumo.saldoDisponivel : resumo.saldoConfirmado * 0.95);
      const saqueGratis = saque ? saque.saqueGratis : saldoDisp >= 500;
      const podeSacar = saque ? saque.podeSacar : saldoDisp >= 50;
      const taxaSaque = saque ? saque.taxa : (saqueGratis ? 0 : (taxaSaqueValor || 5.50));
      const saldoLiquido = saque ? saque.saldoLiquido : (podeSacar ? (saqueGratis ? saldoDisp : saldoDisp - taxaSaque) : 0);
      const saqueMinimo = saque ? saque.saqueMinimo : 50;
    %>
    <div
      x-data="carteiraSaqueData(<%= saldoDisp %>, <%= taxaSaqueValor || 5.50 %>, <%= saqueGratis ? 'true' : 'false' %>, <%= saqueMinimo %>, '<%= saldoDisp.toFixed(2) %>')"
      @keydown.escape.window="fecharModal()">
    <div class="admin-panel-card p-5 mb-6 border-l-4 <%= saqueGratis ? 'border-emerald-500' : podeSacar ? 'border-violet-400' : 'border-gray-300 dark:border-gray-700' %>">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4">
        <div class="flex items-start gap-3 flex-1">
          <div class="w-10 h-10 rounded-xl <%= saqueGratis ? 'bg-emerald-100 dark:bg-emerald-900/40' : podeSacar ? 'bg-violet-100 dark:bg-violet-900/30' : 'bg-gray-100 dark:bg-gray-800' %> flex items-center justify-center shrink-0">
            <i data-lucide="<%= saqueGratis ? 'arrow-down-to-line' : podeSacar ? 'wallet' : 'clock' %>" class="w-5 h-5 <%= saqueGratis ? 'text-emerald-600' : podeSacar ? 'text-violet-600' : 'text-gray-400' %>"></i>
          </div>
          <div>
            <% if (saqueGratis) { %>
              <p class="font-bold text-sm text-emerald-800 dark:text-emerald-300">✅ Saque gratuito disponível — R$ <%= saldoDisp.toFixed(2).replace('.', ',') %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Saldo acima de R$ 500,00 — <strong>saque sem taxa</strong>. Você receberá R$ <strong><%= saldoDisp.toFixed(2).replace('.', ',') %></strong> na sua chave PIX.</p>
            <% } else if (podeSacar) { %>
              <p class="font-bold text-sm text-violet-800 dark:text-violet-300">💰 Saque disponível — R$ <%= saldoDisp.toFixed(2).replace('.', ',') %></p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Taxa de saque: <strong>R$ <%= (taxaSaqueValor||5.50).toFixed(2).replace('.', ',') %></strong>. Você receberá <strong>R$ <%= saldoLiquido.toFixed(2).replace('.', ',') %></strong> na chave PIX (saque total). Saques acima de R$ 500,00 são gratuitos.</p>
            <% } else { %>
              <p class="font-bold text-sm text-gray-600 dark:text-gray-400">⏳ Saldo insuficiente para saque</p>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Mínimo para saque: <strong>R$ 50,00</strong>. Disponível: R$ <%= saldoDisp.toFixed(2).replace('.', ',') %>. Faltam R$ <%= Math.max(0, 50 - saldoDisp).toFixed(2).replace('.', ',') %>.</p>
            <% } %>
          </div>
        </div>
        <% if (podeSacar && tenant.pixChave) { %>
        <button type="button" @click="abrirModal()"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl <%= saqueGratis ? 'bg-emerald-600 hover:bg-emerald-700' : 'bg-violet-600 hover:bg-violet-700' %> text-white text-sm font-bold transition shrink-0 shadow">
          <i data-lucide="arrow-down-to-line" class="w-4 h-4"></i>
          Sacar agora
        </button>
        <% } else if (!tenant.pixChave && !mpOk) { %>
        <span class="text-xs text-gray-400 shrink-0">Configure a chave PIX para sacar</span>
        <% } %>
      </div>
    </div>

    <!-- Modal saque: valor → confirmação -->
    <div x-show="modalSaque" x-cloak class="fixed inset-0 z-[60] flex items-center justify-center p-4">
      <div class="admin-modal-backdrop absolute inset-0" @click="fecharModal()"></div>
      <div class="relative bg-white dark:bg-slate-900 rounded-2xl shadow-2xl w-full max-w-md border border-gray-200 dark:border-gray-700 flex flex-col overflow-hidden"
        x-transition @click.outside="">

        <div class="shrink-0 border-b border-gray-100 dark:border-gray-800 px-6 py-4 flex items-center justify-between">
          <h3 class="font-bold text-lg flex items-center gap-2">
            <i data-lucide="arrow-down-to-line" class="w-5 h-5 text-violet-600"></i>
            <span x-text="step === 1 ? 'Quanto sacar?' : 'Confirmar saque'"></span>
          </h3>
          <button type="button" @click="fecharModal()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500">
            <i data-lucide="x" class="w-5 h-5"></i>
          </button>
        </div>

        <!-- Passo 1: valor -->
        <div x-show="step === 1" class="p-6 space-y-4">
          <div class="rounded-xl bg-gray-50 dark:bg-slate-800/50 p-3 text-sm">
            <span class="text-gray-500">Saldo disponível:</span>
            <strong class="text-violet-600 dark:text-violet-400"> R$ <span x-text="fmt(saldoDisp)"></span></strong>
          </div>

          <div>
            <label class="admin-label" for="saque_valor">Valor do saque (R$)</label>
            <div class="flex gap-2">
              <input type="text" id="saque_valor" x-model="valor" inputmode="decimal"
                class="admin-input flex-1" placeholder="0,00" autocomplete="off">
              <button type="button" @click="usarSaldoTotal()"
                class="shrink-0 px-3 py-2 rounded-xl border border-gray-200 dark:border-gray-600 text-xs font-semibold text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800">
                Tudo
              </button>
            </div>
            <p class="admin-hint">Mínimo R$ <%= saqueMinimo.toFixed(2).replace('.', ',') %>. Máximo R$ <%= saldoDisp.toFixed(2).replace('.', ',') %>.</p>
          </div>

          <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-4 space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-500">Taxa de saque</span>
              <span class="font-medium" x-text="taxaAtual() > 0 ? 'R$ ' + fmt(taxaAtual()) : 'Grátis'"></span>
            </div>
            <div class="flex justify-between border-t border-gray-100 dark:border-gray-800 pt-2">
              <span class="font-semibold">Você recebe</span>
              <span class="font-bold text-emerald-600" x-text="'R$ ' + fmt(liquido())"></span>
            </div>
          </div>

          <p x-show="!valorValido() && parseValor() > 0" x-cloak class="text-xs text-red-600">
            Informe um valor entre R$ <%= saqueMinimo.toFixed(2).replace('.', ',') %> e R$ <%= saldoDisp.toFixed(2).replace('.', ',') %><% if (!saqueGratis) { %>, acima da taxa<% } %>.
          </p>

          <div class="flex gap-3 pt-1">
            <button type="button" @click="fecharModal()" class="flex-1 py-3 rounded-xl border border-gray-200 dark:border-gray-600 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800">
              Cancelar
            </button>
            <button type="button" @click="avancar()" :disabled="!valorValido()"
              class="flex-1 py-3 rounded-xl bg-violet-600 hover:bg-violet-700 disabled:opacity-40 disabled:cursor-not-allowed text-white text-sm font-bold">
              Continuar
            </button>
          </div>
        </div>

        <!-- Passo 2: confirmação -->
        <form x-show="step === 2" method="POST" action="<%= adminBase %>/carteira/saque" class="p-6 space-y-4"
          @submit="enviando = true">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="valor" :value="parseValor().toFixed(2)">

          <div class="rounded-xl border-2 border-violet-200 dark:border-violet-800/50 bg-violet-50 dark:bg-violet-950/20 p-4 space-y-3 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Valor solicitado</span>
              <span class="font-semibold" x-text="'R$ ' + fmt(parseValor())"></span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-600 dark:text-gray-400">Taxa</span>
              <span class="font-medium" x-text="taxaAtual() > 0 ? 'R$ ' + fmt(taxaAtual()) : 'Grátis'"></span>
            </div>
            <div class="flex justify-between border-t border-violet-200 dark:border-violet-800/50 pt-3">
              <span class="font-bold">Receberá na chave PIX</span>
              <span class="font-bold text-emerald-600 text-base" x-text="'R$ ' + fmt(liquido())"></span>
            </div>
            <div class="pt-2 border-t border-violet-200 dark:border-violet-800/50">
              <p class="text-xs text-gray-500 mb-1">Chave de destino</p>
              <p class="text-xs font-mono break-all text-gray-700 dark:text-gray-300"><%= tenant.pixChave %></p>
            </div>
          </div>

          <p class="text-xs text-gray-500 flex items-start gap-2">
            <i data-lucide="info" class="w-4 h-4 shrink-0 mt-0.5"></i>
            O PIX será enviado pela plataforma VouRifar. Confira se a chave está correta antes de confirmar.
          </p>

          <div class="flex gap-3 pt-1">
            <button type="button" @click="step = 1" :disabled="enviando"
              class="flex-1 py-3 rounded-xl border border-gray-200 dark:border-gray-600 text-sm font-medium hover:bg-gray-50 dark:hover:bg-gray-800 disabled:opacity-50">
              Voltar
            </button>
            <button type="submit" :disabled="enviando"
              class="flex-1 py-3 rounded-xl bg-emerald-600 hover:bg-emerald-700 disabled:opacity-60 text-white text-sm font-bold inline-flex items-center justify-center gap-2">
              <span x-show="!enviando" class="inline-flex items-center gap-2"><i data-lucide="check" class="w-4 h-4"></i> Confirmar saque</span>
              <span x-show="enviando" x-cloak>Processando…</span>
            </button>
          </div>
        </form>
      </div>
    </div>
    </div>
    <% } %>

    <% if (!mpOk && typeof extratoSaques !== 'undefined' && extratoSaques.length) { %>
    <div class="admin-panel-card p-5 mb-6">
      <div class="flex items-center justify-between gap-3 mb-4">
        <div class="flex items-center gap-2">
          <i data-lucide="receipt" class="w-5 h-5 text-gray-400"></i>
          <h2 class="font-bold text-base">Extrato de saques</h2>
        </div>
        <% if (resumo.totalSacado > 0) { %>
        <span class="text-xs text-gray-500">Total sacado: <strong>R$ <%= resumo.totalSacado.toFixed(2).replace('.', ',') %></strong></span>
        <% } %>
      </div>
      <div class="overflow-x-auto -mx-1">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs uppercase tracking-wider text-gray-400 border-b border-gray-100 dark:border-gray-800">
              <th class="pb-2 pr-4 font-semibold">Data</th>
              <th class="pb-2 pr-4 font-semibold">Valor</th>
              <th class="pb-2 pr-4 font-semibold">Taxa</th>
              <th class="pb-2 pr-4 font-semibold">Recebido</th>
              <th class="pb-2 font-semibold">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <% extratoSaques.forEach(function(s) {
              const st = s.status || 'solicitado';
              const stLabel = st === 'concluido' ? 'Concluído' : st === 'processando' ? 'Processando' : st === 'falhou' ? 'Falhou' : 'Solicitado';
              const stClass = st === 'concluido' ? 'text-emerald-600 bg-emerald-50 dark:bg-emerald-950/30' : st === 'processando' ? 'text-amber-600 bg-amber-50 dark:bg-amber-950/30' : st === 'falhou' ? 'text-red-600 bg-red-50 dark:bg-red-950/30' : 'text-gray-600 bg-gray-50 dark:bg-gray-800/50';
            %>
            <tr>
              <td class="py-3 pr-4 text-gray-600 dark:text-gray-400 whitespace-nowrap"><%= new Date(s.createdAt).toLocaleString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
              <td class="py-3 pr-4 font-medium">R$ <%= s.valorBruto.toFixed(2).replace('.', ',') %></td>
              <td class="py-3 pr-4 text-gray-500"><%= s.taxa > 0 ? 'R$ ' + s.taxa.toFixed(2).replace('.', ',') : '—' %></td>
              <td class="py-3 pr-4 font-semibold text-emerald-600">R$ <%= s.valorLiquido.toFixed(2).replace('.', ',') %></td>
              <td class="py-3"><span class="inline-flex px-2 py-0.5 rounded-full text-xs font-semibold <%= stClass %>"><%= stLabel %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
    <% } else if (!mpOk && saque && saque.podeSacar) { %>
    <div class="admin-panel-card p-5 mb-6">
      <div class="flex items-center gap-2 text-sm text-gray-500">
        <i data-lucide="receipt" class="w-4 h-4"></i>
        <span>Nenhum saque realizado ainda. O histórico aparecerá aqui após o primeiro saque.</span>
      </div>
    </div>
    <% } else if (!mpOk && resumo.totalSacado > 0) { %>
    <div class="admin-panel-card p-5 mb-6">
      <p class="text-sm text-gray-500">Total já sacado: <strong>R$ <%= resumo.totalSacado.toFixed(2).replace('.', ',') %></strong></p>
    </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-5">
      <% if (!mpOk) { %>
      <form method="POST" action="<%= adminBase %>/carteira" class="admin-panel-card p-6 space-y-5 lg:col-span-3"
        x-data="{
          tipo: '<%= pixTipo %>',
          pixAtiva: <%= tenant.pixChave ? 'true' : 'false' %>,
          tipos: {
            cpf: { label: 'CPF', placeholder: '000.000.000-00', hint: 'Somente números do CPF (11 dígitos).' },
            cnpj: { label: 'CNPJ', placeholder: '00.000.000/0000-00', hint: 'CNPJ da empresa (14 dígitos).' },
            email: { label: 'E-mail', placeholder: 'seu@email.com', hint: 'E-mail cadastrado como chave PIX no banco.' },
            telefone: { label: 'Telefone', placeholder: '(11) 99999-8888', hint: 'Celular com DDD. Pode incluir +55.' },
            aleatoria: { label: 'Chave aleatória', placeholder: 'xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx', hint: 'Chave EVP (UUID) gerada no app do banco.' }
          },
          placeholder() { return this.tipos[this.tipo]?.placeholder || ''; },
          hint() { return this.tipos[this.tipo]?.hint || ''; },
          labelAtivo() { return this.tipos[this.tipo]?.label || 'Chave PIX'; }
        }">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="admin-config-section-head">
          <div class="admin-config-section-icon pix"><img src="/img/pix.svg?v=2" alt="PIX" width="40" height="40"></div>
          <div>
            <h2 class="font-bold text-base">Sua chave PIX para saque</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400">A plataforma processa os pagamentos. Informe sua chave PIX para sacar o saldo acumulado.</p>
          </div>
        </div>

        <div x-show="pixAtiva" x-cloak class="rounded-xl border border-emerald-200 bg-emerald-50 dark:bg-emerald-950/30 dark:border-emerald-800/50 p-4">
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-emerald-100 dark:bg-emerald-900/50 flex items-center justify-center shrink-0">
              <i data-lucide="badge-check" class="w-5 h-5 text-emerald-600"></i>
            </div>
            <div class="min-w-0">
              <p class="font-semibold text-emerald-800 dark:text-emerald-300 text-sm">Chave PIX ativa nesta loja</p>
              <p class="text-sm text-emerald-700 dark:text-emerald-400 mt-0.5 break-all">
                <% if (tenant.pixChave) { %>
                  <span class="font-medium"><%= pixTipoLabel %></span>: <%= tenant.pixChave %>
                <% } %>
              </p>
              <p class="text-xs text-emerald-600/80 dark:text-emerald-500 mt-1">Para trocar, escolha o tipo, informe a nova chave e salve.</p>
            </div>
          </div>
        </div>

        <div x-show="!pixAtiva" x-cloak class="rounded-xl border border-amber-200 bg-amber-50 dark:bg-amber-950/20 dark:border-amber-800/40 p-4">
          <div class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-amber-100 dark:bg-amber-900/40 flex items-center justify-center shrink-0">
              <i data-lucide="info" class="w-5 h-5 text-amber-600"></i>
            </div>
            <div>
              <p class="font-semibold text-amber-800 dark:text-amber-300 text-sm">Nenhuma chave cadastrada</p>
              <p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5">Escolha o tipo da chave e informe o valor exatamente como está no seu banco.</p>
            </div>
          </div>
        </div>

        <div>
          <label class="admin-label" for="pix_tipo">Tipo da chave *</label>
          <select id="pix_tipo" name="pix_tipo" required class="admin-input" x-model="tipo">
            <option value="cpf">CPF</option>
            <option value="cnpj">CNPJ</option>
            <option value="email">E-mail</option>
            <option value="telefone">Telefone (celular)</option>
            <option value="aleatoria">Chave aleatória (EVP)</option>
          </select>
          <p class="admin-hint">Selecione o mesmo tipo cadastrado no seu banco — evita erros na hora de receber.</p>
        </div>

        <div>
          <label class="admin-label" for="pix_chave">
            <span x-text="labelAtivo()"></span> *
          </label>
          <input type="text" id="pix_chave" name="pix_chave" value="<%= tenant.pixChave || '' %>" required class="admin-input"
            :placeholder="placeholder()"
            autocomplete="off"
            spellcheck="false">
          <p class="admin-hint" x-text="hint()"></p>
          <p class="admin-hint mt-1">A plataforma retém <strong><%= Math.round((wooviTaxa||0.07)*100) %>%</strong> do valor arrecadado. Você recebe <strong><%= Math.round((wooviPercentual||0.93)*100) %>%</strong> de cada venda — solicite o saque quando quiser.</p>
        </div>

        <button type="submit" class="admin-btn-primary px-6 py-3 text-sm">
          <i data-lucide="save" class="w-4 h-4 inline-block mr-1 -mt-0.5"></i>
          <span x-text="pixAtiva ? 'Atualizar chave PIX' : 'Salvar chave PIX'"></span>
        </button>
      </form>
      <% } else { %>
      <div class="admin-panel-card p-6 lg:col-span-3">
        <h2 class="font-bold text-base mb-3">Como funciona o repasse automático</h2>
        <ol class="text-sm text-gray-500 dark:text-gray-400 space-y-3 list-none">
          <li class="flex items-start gap-2.5">
            <span class="w-5 h-5 rounded-full bg-sky-100 dark:bg-sky-900/40 text-sky-700 dark:text-sky-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">1</span>
            <span>Comprador paga o <strong class="text-gray-700 dark:text-gray-200">valor exato</strong> da cota via PIX</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-5 h-5 rounded-full bg-sky-100 dark:bg-sky-900/40 text-sky-700 dark:text-sky-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">2</span>
            <span>O Mercado Pago confirma o pagamento e reserva a cota automaticamente</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-5 h-5 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">3</span>
            <span><strong class="text-gray-700 dark:text-gray-200"><%= Math.round((mpPercentual||0.95)*100) %>%</strong> cai na sua conta MP na hora — a plataforma retém <strong class="text-gray-700 dark:text-gray-200"><%= Math.round((mpTaxa||0.05)*100) %>%</strong> automaticamente</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="w-5 h-5 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">✓</span>
            <span>Sem saque manual, sem taxa de saque — o dinheiro já é seu no Mercado Pago</span>
          </li>
        </ol>
      </div>
      <% } %>

      <aside class="lg:col-span-2 space-y-4">
        <% if (!mpOk) { %>
        <div class="admin-panel-card p-5">
          <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-3">Tipos de chave</p>
          <ul class="text-sm text-gray-500 dark:text-gray-400 space-y-2">
            <li><strong class="text-gray-700 dark:text-gray-300">CPF / CNPJ</strong> — documento titular da conta</li>
            <li><strong class="text-gray-700 dark:text-gray-300">E-mail</strong> — endereço cadastrado no banco</li>
            <li><strong class="text-gray-700 dark:text-gray-300">Telefone</strong> — celular com DDD</li>
            <li><strong class="text-gray-700 dark:text-gray-300">Aleatória</strong> — código EVP gerado no app</li>
          </ul>
        </div>

        <div class="admin-panel-card p-5">
          <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-3">Como funciona</p>
          <ol class="text-sm text-gray-500 dark:text-gray-400 space-y-2.5 list-none">
            <li class="flex items-start gap-2.5">
              <span class="w-5 h-5 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">1</span>
              <span>Comprador paga o <strong class="text-gray-700 dark:text-gray-200">valor exato</strong> da cota via PIX</span>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="w-5 h-5 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">2</span>
              <span>Pagamento confirmado automaticamente — cota reservada</span>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="w-5 h-5 rounded-full bg-violet-100 dark:bg-violet-900/40 text-violet-700 dark:text-violet-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">3</span>
            <span><strong class="text-gray-700 dark:text-gray-200"><%= Math.round((wooviPercentual||0.93)*100) %>%</strong> acumula no seu saldo — a plataforma retém <%= Math.round((wooviTaxa||0.07)*100) %>%</span>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="w-5 h-5 rounded-full bg-sky-100 dark:bg-sky-900/40 text-sky-700 dark:text-sky-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">4</span>
              <span>Clique em <strong class="text-gray-700 dark:text-gray-200">"Sacar agora"</strong> para receber na sua chave PIX</span>
            </li>
            <li class="flex items-start gap-2.5">
              <span class="w-5 h-5 rounded-full bg-emerald-100 dark:bg-emerald-900/40 text-emerald-700 dark:text-emerald-400 text-[11px] font-bold flex items-center justify-center shrink-0 mt-0.5">✓</span>
              <span>Saldo <strong class="text-gray-700 dark:text-gray-200">≥ R$ 500,00</strong>: saque gratuito. Abaixo: taxa de <strong class="text-gray-700 dark:text-gray-200">R$ <%= (taxaSaqueValor||5.50).toFixed(2).replace('.', ',') %></strong></span>
            </li>
          </ol>
        </div>

        <div class="admin-panel-card p-5">
          <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-3">Regras de saque</p>
          <ul class="text-sm space-y-2">
            <li class="flex items-center gap-2 text-emerald-700 dark:text-emerald-400">
              <i data-lucide="check-circle-2" class="w-4 h-4 shrink-0"></i>
              <span><strong>Grátis</strong> — saldo ≥ R$ 500,00</span>
            </li>
            <li class="flex items-center gap-2 text-amber-700 dark:text-amber-400">
              <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i>
              <span><strong>R$ <%= (taxaSaqueValor||5.50).toFixed(2).replace('.', ',') %></strong> — saque abaixo de R$ 500,00</span>
            </li>
            <li class="flex items-center gap-2 text-gray-500 dark:text-gray-400">
              <i data-lucide="arrow-up" class="w-4 h-4 shrink-0"></i>
              <span>Saldo mínimo para saque: <strong>R$ 50,00</strong></span>
            </li>
          </ul>
        </div>

        <div class="admin-tip !mb-0">
          <i data-lucide="shield-check" class="w-4 h-4 text-emerald-600 shrink-0"></i>
          <span>Cada conta usa uma chave PIX exclusiva. A mesma chave não pode ser cadastrada em dois sistemas.</span>
        </div>
        <% } else { %>
        <div class="admin-panel-card p-5">
          <p class="text-xs font-bold uppercase tracking-wider text-gray-400 mb-3">Segurança</p>
          <ul class="text-sm text-gray-500 dark:text-gray-400 space-y-2">
            <li class="flex items-start gap-2">
              <i data-lucide="shield-check" class="w-4 h-4 text-emerald-600 shrink-0 mt-0.5"></i>
              <span>O dinheiro nunca passa pela conta da plataforma — vai direto para você</span>
            </li>
            <li class="flex items-start gap-2">
              <i data-lucide="lock" class="w-4 h-4 text-emerald-600 shrink-0 mt-0.5"></i>
              <span>Autorização OAuth oficial do Mercado Pago — revogável a qualquer momento</span>
            </li>
            <li class="flex items-start gap-2">
              <i data-lucide="user-check" class="w-4 h-4 text-emerald-600 shrink-0 mt-0.5"></i>
              <span>Cada conta MP só pode ser vinculada a uma loja VouRifar</span>
            </li>
          </ul>
        </div>

        <div class="admin-tip !mb-0">
          <i data-lucide="info" class="w-4 h-4 text-sky-600 shrink-0"></i>
          <span>Use a mesma conta Mercado Pago onde você já recebe PIX. Contas PJ e PF são aceitas.</span>
        </div>
        <% } %>
      </aside>
    </div>

  <%- include('partials/layout-end') %>
  <script>
    function carteiraSaqueData(saldoDisp, taxaFixa, saqueGratis, saqueMinimo, valorInicial) {
      return {
        modalSaque: false,
        step: 1,
        enviando: false,
        saldoDisp: Number(saldoDisp),
        taxaFixa: Number(taxaFixa),
        saqueGratis: !!saqueGratis,
        saqueMinimo: Number(saqueMinimo),
        valor: String(valorInicial || ''),
        abrirModal() {
          this.valor = this.saldoDisp.toFixed(2);
          this.step = 1;
          this.enviando = false;
          this.modalSaque = true;
          this.$nextTick(function () { lucide.createIcons(); });
        },
        fecharModal() {
          if (this.enviando) return;
          this.modalSaque = false;
          this.step = 1;
        },
        parseValor() {
          var n = parseFloat(String(this.valor).replace(',', '.'));
          return Number.isFinite(n) ? n : 0;
        },
        taxaAtual() {
          return this.saqueGratis ? 0 : this.taxaFixa;
        },
        liquido() {
          return Math.max(0, Math.round((this.parseValor() - this.taxaAtual()) * 100) / 100);
        },
        valorValido() {
          var v = this.parseValor();
          return v >= this.saqueMinimo
            && v <= this.saldoDisp + 0.009
            && (this.taxaAtual() === 0 || v > this.taxaAtual());
        },
        fmt(n) {
          return Number(n).toFixed(2).replace('.', ',');
        },
        usarSaldoTotal() {
          this.valor = this.saldoDisp.toFixed(2);
        },
        avancar() {
          if (!this.valorValido()) return;
          this.step = 2;
          this.$nextTick(function () { lucide.createIcons(); });
        }
      };
    }
  </script>
  <script>lucide.createIcons();</script>
</body>
</html>
