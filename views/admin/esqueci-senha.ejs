<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recuperar senha — <%= tenant.nome %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>:root{--brand:<%= tenant.corPrimaria %>}.btn-brand{background:<%= tenant.corPrimaria %>;color:#fff}</style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">
<div class="bg-white rounded-2xl shadow-lg p-8 w-full max-w-md">

  <!-- Logo / título -->
  <div class="text-center mb-6">
    <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-3" style="background:<%= tenant.corPrimaria %>22;">
      <svg class="w-6 h-6" fill="none" stroke="<%= tenant.corPrimaria %>" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/>
      </svg>
    </div>
    <h1 class="text-xl font-bold text-gray-800">Recuperar senha</h1>
    <p class="text-sm text-gray-500 mt-1"><%= tenant.nome %></p>
  </div>

  <% if (mensagem) { %>
    <div class="bg-green-50 border border-green-200 text-green-700 p-4 rounded-xl mb-5 text-sm flex gap-2">
      <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span><%= mensagem %></span>
    </div>
  <% } %>

  <% if (erro) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 p-3 rounded-xl mb-5 text-sm"><%= erro %></div>
  <% } %>

  <% if (!mensagem) { %>
    <p class="text-sm text-gray-600 mb-5">Informe seu e-mail de cadastro e enviaremos um link para redefinir sua senha.</p>

    <form method="POST" action="<%= adminBase %>/esqueci-senha" class="space-y-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
        <input type="email" name="email" required placeholder="seu@email.com"
          class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2"
          style="--tw-ring-color:<%= tenant.corPrimaria %>;">
      </div>
      <button type="submit" class="w-full btn-brand py-3 rounded-xl font-semibold text-sm">
        Enviar link de recuperação
      </button>
    </form>
  <% } %>

  <p class="text-center text-sm text-gray-500 mt-5">
    <a href="<%= adminBase %>/login" class="font-medium" style="color:<%= tenant.corPrimaria %>;">← Voltar ao login</a>
  </p>
</div>
</body>
</html>
