# ============================================================
# .env — VouRifar PRODUÇÃO (vourifar.com.br)
# Copie para .env na VPS: cp .env.production.example .env
# ============================================================

# Servidor
PORT=3000
NODE_ENV=production

# Sessão — gere com: openssl rand -hex 32
SESSION_SECRET=ALTERE_PARA_UMA_CHAVE_ALEATORIA_LONGA_32_CHARS

# Webhook de pagamento
WEBHOOK_SECRET=ALTERE_PARA_UM_SEGREDO_PARA_WEBHOOK

# URL pública (sem barra final)
APP_URL=https://vourifar.com.br

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Adicione no Google Console como URI autorizado:
# https://vourifar.com.br/auth/google/organizador/callback

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# MERCADOPAGO_CALLBACK_URL=https://vourifar.com.br/auth/mercadopago/callback
# Webhook MP — configure no painel Mercado Pago:
# https://vourifar.com.br/webhooks/mercadopago
# Redirect OAuth — configure no painel Mercado Pago:
# https://vourifar.com.br/auth/mercadopago/callback

# Woovi (legado — desativado)
WOOVI_ENABLED=false
WOOVI_APP_ID=

# Seed (somente na 1ª subida — cria super admin admin/admin123)
RUN_SEED=true
